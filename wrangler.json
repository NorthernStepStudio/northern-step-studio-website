{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "northern-step-studio-website",
	"main": "./src/worker/index.ts",
	"compatibility_date": "2025-06-17",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"rules": [
		{
			"type": "Text",
			"globs": [
				"**/*.html*"
			],
			"fallthrough": true
		}
	],
	"observability": {
		"enabled": true
	},
	"upload_source_maps": true,
	"assets": {
		"directory": "dist",
		"not_found_handling": "single-page-application"
	},
	"services": [],
	"routes": [
		{
			"pattern": "northernstepstudio.com",
			"zone_name": "northernstepstudio.com",
			"custom_domain": true
		},
		{
			"pattern": "www.northernstepstudio.com",
			"zone_name": "northernstepstudio.com",
			"custom_domain": true
		}
	],
	"workers_dev": true
}

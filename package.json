{
  "name": "nstep-workspace",
  "private": true,
  "workspaces": [
    "apps/nstep-dashboard",
    "apps/nstep-fix",
    "apps/nstep-publish",
    "apps/neurormoves",
    "packages/nstep-os"
  ],
  "scripts": {
    "check": "npm run check --workspace packages/nstep-os && npm run check --workspace apps/nstep-dashboard",
    "build": "npm run compile --workspace packages/nstep-os && npm run build --workspace apps/nstep-dashboard",
    "test": "npm run test --workspace packages/nstep-os",
    "dev": "node scripts/dev.mjs",
    "dev:dashboard": "npm run dev --workspace apps/nstep-dashboard",
    "dev:server": "npm run start --workspace packages/nstep-os",
    "dev:worker": "npm run worker --workspace packages/nstep-os",
    "worker": "npm run worker --workspace packages/nstep-os",
    "hygiene:check": "node scripts/repo-hygiene-check.mjs",
    "hygiene:clean": "node scripts/repo-hygiene-clean.mjs --apply"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "dependencies": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  }
}

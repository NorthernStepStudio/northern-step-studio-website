{
  "version": 2,
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://northern-step-studio-website.proyectgate.workers.dev/api/:path*"
    },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "installCommand": "npm install",
  "buildCommand": "npm run build"
}

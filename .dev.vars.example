# Required for Google auth in local development.
MOCHA_USERS_SERVICE_API_KEY=replace-with-your-users-service-api-key

# Optional. The users-service package defaults to https://getmocha.com/u.
MOCHA_USERS_SERVICE_API_URL=https://getmocha.com/u

# Optional Supabase integration for backend connectivity and future migration work.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=replace-with-your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-your-supabase-service-role-key
SUPABASE_PROJECT_REF=your-project-ref

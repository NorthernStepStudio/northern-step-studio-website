# Frontend auth vars for Vite.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id
VITE_BACKEND_URL=http://localhost:8787
VITE_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_SECRET_KEY=replace-with-your-stripe-secret-key

# Supported legacy names used by the existing repo and local dev setup.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# NStepOS runtime.
NSTEP_OS_PORT=3060
NSTEP_OS_PROVIDER_MODE=mock
NSTEP_OS_OPENAI_API_KEY=replace-with-openai-api-key
NSTEP_OS_GEMINI_API_KEY=replace-with-gemini-api-key
NSTEP_OS_INTERNAL_TOKEN=replace-with-local-internal-token
DATABASE_URL=postgres://user:password@localhost:5432/nstep
REDIS_URL=redis://localhost:6379
TWILIO_ACCOUNT_SID=replace-with-twilio-account-sid
TWILIO_AUTH_TOKEN=replace-with-twilio-auth-token
TWILIO_FROM_NUMBER=+15555550100

# Dashboard integration. The dashboard must reuse the existing website/admin auth flow.
NSTEP_OS_API_URL=http://127.0.0.1:3060
NSTEP_DASHBOARD_AUTH_BASE_URL=http://localhost:5173
NSTEP_DASHBOARD_ALLOWED_ADMIN_ROLES=owner,admin
NSTEP_DASHBOARD_AUTH_COOKIE_NAMES=studio_session_token
NSTEP_DASHBOARD_LOCAL_DEV_AUTH=0
NSTEP_DASHBOARD_ALLOW_LOCAL_ME=0
NSTEP_DASHBOARD_LOCAL_DEV_USER=localdev
NSTEP_DASHBOARD_LOCAL_DEV_EMAIL=localdev@local.dev

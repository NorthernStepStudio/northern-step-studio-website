{
  "name": "@nstep/os",
  "version": "0.1.0",
  "private": true,
  "description": "NStepOS, the orchestration runtime for goal-driven autonomous work and internal agent execution.",
  "type": "module",
  "main": "./out/index.js",
  "types": "./out/index.d.ts",
  "exports": {
    ".": {
      "types": "./out/index.d.ts",
      "import": "./out/index.js",
      "default": "./out/index.js"
    },
    "./phase-1": {
      "types": "./out/phase-1/index.d.ts",
      "import": "./out/phase-1/index.js",
      "default": "./out/phase-1/index.js"
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "start": "node out/server.js",
    "worker": "node out/worker.js",
    "dev": "npm run compile && npm run start",
    "test": "npm run compile && node scripts/run-tests.mjs",
    "seed:knowledge": "npm run compile && node out/scripts/seed-knowledge.js",
    "check": "npm run compile"
  },
  "dependencies": {
    "pg": "^8.16.3",
    "redis": "^5.10.0"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/pg": "^8.15.5",
    "typescript": "^5.9.2"
  }
}

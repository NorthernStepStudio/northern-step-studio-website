{
  "expo": {
    "name": "ProvLy: Home Inventory",
    "slug": "provly",
    "scheme": "provly",
    "description": "ProvLy is a local-first home inventory app by Northern Step Studio.",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B1220"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.provly.inventory",
      "infoPlist": {
        "NSCameraUsageDescription": "ProvLy uses the camera to scan items and add photos to your inventory.",
        "NSPhotoLibraryUsageDescription": "ProvLy needs access to your photos to let you attach receipts and item images.",
        "NSMicrophoneUsageDescription": "ProvLy uses the microphone for video recording during item scans."
      }
    },
    "android": {
      "package": "com.provly.inventory",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.WAKE_LOCK",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-localization",
      "expo-sqlite",
      "expo-secure-store",
      [
        "expo-background-fetch",
        {
          "isAllowedWithSensors": false
        }
      ],
      "expo-mail-composer",
      [
        "expo-build-properties",
        {
          "android": {
            "extraProguardRules": "-include ./proguard-rules.pro",
            "networkSecurityConfig": "./network_security_config.xml"
          }
        }
      ],
      [
        "./plugins/withAndroidWindowBackground",
        {
          "color": "#0B1220",
          "colorName": "app_background"
        }
      ]
    ],
    "extra": {
      "companyName": "Northern Step Studio",
      "supabaseUrl": "https://frlcnipgnxzeemitzkmd.supabase.co",
      "supabaseAnonKey": "sb_publishable_Nr7s8KKJPJ8mN-Xrj1jglQ_YP7A2T2a",
      "eas": {
        "projectId": "14ef98f8-0c2e-459a-9648-dfe0cc1dcfaf"
      },
      "developerName": "Northern Step Studio"
    },
    "owner": "northernstep"
  }
}

{
  "name": "nss-workspace-ai",
  "displayName": "NSS Workspace AI",
  "description": "VS Code extension app scaffold for the Northern Step Studio workspace AI.",
  "version": "0.1.0",
  "private": true,
  "publisher": "northern-step-studio",
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "engines": {
    "vscode": "^1.85.0"
  },
  "activationEvents": [
    "onView:nssWorkspaceAi.sidebar",
    "onStartupFinished"
  ],
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "smoke": "node out/test/runSmoke.js",
    "test:extension-host": "node out/test/runExtensionHost.js",
    "check": "npm run compile && npm run smoke && node --check src/sidebar/webview/main.js",
    "verify:runtime": "npm run check && npm run test:extension-host"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "nssWorkspaceAi",
          "title": "NSS",
          "icon": "media/studio-mark.svg"
        }
      ]
    },
    "views": {
      "nssWorkspaceAi": [
        {
          "type": "webview",
          "id": "nssWorkspaceAi.sidebar",
          "name": "Workspace AI",
          "icon": "media/studio-mark.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "nssWorkspaceAi.askWorkspaceAi",
        "title": "NSS: Ask Workspace AI",
        "category": "NSS"
      },
      {
        "command": "nssWorkspaceAi.explainThisFile",
        "title": "NSS: Explain This File",
        "category": "NSS"
      },
      {
        "command": "nssWorkspaceAi.generateFromSelection",
        "title": "NSS: Generate From Selection",
        "category": "NSS"
      },
      {
        "command": "nssWorkspaceAi.askAboutCurrentFile",
        "title": "NSS: Ask About Current File",
        "category": "NSS"
      },
      {
        "command": "nssWorkspaceAi.explainProjectStructure",
        "title": "NSS: Explain Project Structure",
        "category": "NSS"
      },
      {
        "command": "nssWorkspaceAi.proposeEditForCurrentFile",
        "title": "NSS: Propose Edit for Current File",
        "category": "NSS"
      },
      {
        "command": "nssWorkspaceAi.applyProposedEditToActiveFile",
        "title": "NSS: Apply Proposed Edit to Active File",
        "category": "NSS"
      },
      {
        "command": "nssWorkspaceAi.searchCodebase",
        "title": "NSS: Search Codebase",
        "category": "NSS"
      },
      {
        "command": "nssWorkspaceAi.findRelatedFiles",
        "title": "NSS: Find Related Files",
        "category": "NSS"
      },
      {
        "command": "nssWorkspaceAi.planChange",
        "title": "NSS: Plan Change",
        "category": "NSS"
      },
      {
        "command": "nssWorkspaceAi.insertLatestResponseIntoCurrentFile",
        "title": "NSS: Insert Latest Response Into Current File",
        "category": "NSS"
      },
      {
        "command": "nssWorkspaceAi.createNewFileFromLatestResponse",
        "title": "NSS: Create New File From Latest Response",
        "category": "NSS"
      },
      {
        "command": "nssWorkspaceAi.runWorkspaceTask",
        "title": "NSS: Run Workspace Task",
        "category": "NSS"
      },
      {
        "command": "nssWorkspaceAi.explainLastTaskFailure",
        "title": "NSS: Explain Last Task Failure",
        "category": "NSS"
      },
      {
        "command": "nssWorkspaceAi.suggestFixForLastTaskFailure",
        "title": "NSS: Suggest Fix For Last Task Failure",
        "category": "NSS"
      },
      {
        "command": "nssWorkspaceAi.reRunLastWorkspaceTask",
        "title": "NSS: Re-run Last Workspace Task",
        "category": "NSS"
      },
      {
        "command": "nssWorkspaceAi.findLikelyErrorFiles",
        "title": "NSS: Find Likely Error Files",
        "category": "NSS"
      },
      {
        "command": "nssWorkspaceAi.askAboutErrorFile",
        "title": "NSS: Ask About This Error File",
        "category": "NSS"
      },
      {
        "command": "nssWorkspaceAi.proposeFixForErrorFile",
        "title": "NSS: Propose Fix For This Error File",
        "category": "NSS"
      },
      {
        "command": "nssWorkspaceAi.proposeMultiFileChange",
        "title": "NSS: Propose Multi-File Change",
        "category": "NSS"
      },
      {
        "command": "nssWorkspaceAi.openSidebar",
        "title": "NSS: Focus Sidebar",
        "category": "NSS"
      },
      {
        "command": "nssWorkspaceAi.showQuickStart",
        "title": "NSS: Show Quick Start",
        "category": "NSS"
      },
      {
        "command": "nssWorkspaceAi.showBuildFoundation",
        "title": "NSS: Show Build Foundation",
        "category": "NSS"
      },
      {
        "command": "nssWorkspaceAi.startDiagnosticSession",
        "title": "NSS: Start Diagnostic Session From Last Failure",
        "category": "NSS"
      },
      {
        "command": "nssWorkspaceAi.viewActiveSession",
        "title": "NSS: View Active Diagnostic Session",
        "category": "NSS"
      },
      {
        "command": "nssWorkspaceAi.addNoteToSession",
        "title": "NSS: Add Note To Diagnostic Session",
        "category": "NSS"
      },
      {
        "command": "nssWorkspaceAi.compareLastTwoResults",
        "title": "NSS: Compare Last Two Task Results",
        "category": "NSS"
      },
      {
        "command": "nssWorkspaceAi.resolveSession",
        "title": "NSS: Mark Diagnostic Session Resolved",
        "category": "NSS"
      },
      {
        "command": "nssWorkspaceAi.abandonSession",
        "title": "NSS: Mark Diagnostic Session Abandoned",
        "category": "NSS"
      },
      {
        "command": "nssWorkspaceAi.addProjectRule",
        "title": "NSS: Add Project Rule",
        "category": "NSS"
      },
      {
        "command": "nssWorkspaceAi.saveRepairPattern",
        "title": "NSS: Save Repair Pattern From Current Session",
        "category": "NSS"
      },
      {
        "command": "nssWorkspaceAi.recallSimilarFailure",
        "title": "NSS: Recall Similar Past Failure Fix",
        "category": "NSS"
      },
      {
        "command": "nssWorkspaceAi.clearWorkspaceMemory",
        "title": "NSS: Clear Workspace Memory",
        "category": "NSS"
      },
      {
        "command": "nssWorkspaceAi.switchActiveStudioProject",
        "title": "NSS: Switch Active Studio Project",
        "category": "NSS"
      },
      {
        "command": "nssWorkspaceAi.showStudioDashboard",
        "title": "NSS: Show Studio Dashboard",
        "category": "NSS"
      },
      {
        "command": "nssWorkspaceAi.addRoadmapNote",
        "title": "NSS: Add Roadmap Note",
        "category": "NSS"
      },
      {
        "command": "nssWorkspaceAi.showRoadmapNotesForActiveProject",
        "title": "NSS: Show Roadmap Notes For Active Project",
        "category": "NSS"
      },
      {
        "command": "nssWorkspaceAi.whatShouldIWorkOnNext",
        "title": "NSS: What Should I Work On Next?",
        "category": "NSS"
      },
      {
        "command": "nssWorkspaceAi.showCrossProjectSummary",
        "title": "NSS: Show Cross-Project Summary",
        "category": "NSS"
      },
      {
        "command": "nssWorkspaceAi.suggestStudioProjectForWorkspace",
        "title": "NSS: Suggest Studio Project For Workspace",
        "category": "NSS"
      },
      {
        "command": "nss.switchMode",
        "title": "NSS: Switch Mode",
        "category": "NSS"
      },
      {
        "command": "nss.showModeDetails",
        "title": "NSS: Show Current Mode Details",
        "category": "NSS"
      },
      {
        "command": "nss.runWorkflow",
        "title": "NSS: Run Workflow",
        "category": "NSS"
      },
      {
        "command": "nss.nextWorkflowStep",
        "title": "NSS: Next Workflow Step",
        "category": "NSS"
      },
      {
        "command": "nss.cancelWorkflow",
        "title": "NSS: Cancel Active Workflow",
        "category": "NSS"
      },
      {
        "command": "nss.showWorkflows",
        "title": "NSS: Show Available Workflows",
        "category": "NSS"
      },
      {
        "command": "nss.switchPreset",
        "title": "NSS: Switch Preset",
        "category": "NSS"
      },
      {
        "command": "nss.showPreset",
        "title": "NSS: Show Current Preset",
        "category": "NSS"
      },
      {
        "command": "nss.suggestPreset",
        "title": "NSS: Suggest Preset For Workspace",
        "category": "NSS"
      },
      {
        "command": "nss.rebuildKnowledge",
        "title": "NSS: Rebuild Knowledge Packs",
        "category": "NSS"
      },
      {
        "command": "nss.showBriefing",
        "title": "NSS: Show Workspace Briefing",
        "category": "NSS"
      },
      {
        "command": "nss.searchKnowledge",
        "title": "NSS: Search Knowledge Packs",
        "category": "NSS"
      },
      {
        "command": "nss.openReviewCenter",
        "title": "NSS: Open Review Center",
        "category": "NSS"
      },
      {
        "command": "nss.previewReviewItem",
        "title": "NSS: Preview Review Item",
        "category": "NSS"
      },
      {
        "command": "nss.showDiffForReviewItem",
        "title": "NSS: Show Diff For Review Item",
        "category": "NSS"
      },
      {
        "command": "nss.approveReviewItem",
        "title": "NSS: Approve Review Item",
        "category": "NSS"
      },
      {
        "command": "nss.rejectReviewItem",
        "title": "NSS: Reject Review Item",
        "category": "NSS"
      },
      {
        "command": "nss.applyApprovedItem",
        "title": "NSS: Apply Approved Review Item",
        "category": "NSS"
      },
      {
        "command": "nss.applyReviewItemToSelection",
        "title": "NSS: Apply Review Item To Selection",
        "category": "NSS"
      },
      {
        "command": "nss.applyReviewItemToFile",
        "title": "NSS: Apply Review Item To File",
        "category": "NSS"
      },
      {
        "command": "nss.refreshReviewItemAgainstCurrentFile",
        "title": "NSS: Refresh Review Item Against Current File",
        "category": "NSS"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "nssWorkspaceAi.explainThisFile",
          "group": "nss@1",
          "when": "editorTextFocus"
        },
        {
          "command": "nssWorkspaceAi.askAboutCurrentFile",
          "group": "nss@2",
          "when": "editorHasSelection"
        },
        {
          "command": "nssWorkspaceAi.generateFromSelection",
          "group": "nss@3",
          "when": "editorHasSelection"
        }
      ]
    },
    "configuration": {
      "title": "NSS Workspace AI",
      "properties": {
        "nssWorkspaceAi.serverUrl": {
          "type": "string",
          "default": "http://localhost:3001",
          "description": "Base URL for the local NSS Workspace AI server."
        },
        "nssWorkspaceAi.maxReviewHistory": {
          "type": "number",
          "default": 50,
          "minimum": 10,
          "description": "Maximum number of review items NSS keeps in memory."
        },
        "nssWorkspaceAi.maxDiagnosticSessionHistory": {
          "type": "number",
          "default": 10,
          "minimum": 3,
          "description": "Maximum number of completed diagnostic sessions NSS keeps in history."
        },
        "nssWorkspaceAi.autoSuggestPresetForWorkspace": {
          "type": "boolean",
          "default": true,
          "description": "Automatically infer a likely NSS preset from the current workspace path when no preset has been chosen yet."
        },
        "nssWorkspaceAi.defaultMode": {
          "type": "string",
          "default": "coding",
          "enum": [
            "coding",
            "debugging",
            "product",
            "marketing",
            "research"
          ],
          "markdownDescription": "Default NSS mode to use before a workspace-specific mode is selected."
        }
      }
    }
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "uuid": "^13.0.0"
  }
}

// \f1\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\f0\par
// LEVEL UP\par
// \f1\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\f0\par
function showLU()\{\par
  const p=G.player;document.getElementById('ludesc').textContent=`Level $\{p.level\}!`;\par
  const perks=[...PERKS].sort(()=>Math.random()-.5).slice(0,3);\par
  const el=document.getElementById('luperks');el.innerHTML='';\par
  perks.forEach(pk=>\{const b=document.createElement('button');b.className='pkchoice';b.innerHTML=`<span class="pn">$\{pk.name\}</span><span class="pd">$\{pk.desc\}</span>`;b.onclick=()=>applyPerk(pk);el.appendChild(b);\});\par
  document.getElementById('luov').classList.add('active');addLog(`\f4\u-10180?\u-8311?\f2  \f0 LVL UP! Lv$\{p.level\}!`,'loot');\par
  sfx('rgba(170,68,255,.3)',400);\par
  const c=document.getElementById('combatov').classList.contains('active')?gctr('player'):\{x:window.innerWidth/2,y:window.innerHeight/2\};\par
  spPt(c.x,c.y,'#aa44ff',20,\{speed:4,spread:5,grav:0,decay:.03\});spRi(c.x,c.y,'#aa44ff');\par
\}\par
function applyPerk(pk)\{\par
  const p=G.player,e=pk.effect;\par
  if(e.atk)p.atk+=e.atk;if(e.def)p.def+=e.def;if(e.spd)p.spd+=e.spd;if(e.crit)p.crit+=e.crit;\par
  if(e.maxHp)\{p.maxHp+=e.maxHp;p.hp+=e.maxHp;\}if(e.maxMp)\{p.maxMp+=e.maxMp;p.mp+=e.maxMp;\}\par
  if(e.lifesteal)p.perks.lifesteal=(p.perks.lifesteal||0)+e.lifesteal;\par
  if(e.potBoost)p.perks.potBoost=(p.perks.potBoost||0)+e.potBoost;\par
  if(e.goldBoost)p.perks.goldBoost=(p.perks.goldBoost||0)+e.goldBoost;\par
  if(e.bombBoost)p.perks.bombBoost=(p.perks.bombBoost||0)+e.bombBoost;\par
  if(e.cannibal)p.perks.cannibal=e.cannibal;\par
  G.perkList.push(pk.name);addLog(`\f1\u10024?\f2  \f0 Perk: $\{pk.name\}!`,'loot');\par
  document.getElementById('luov').classList.remove('active');updateHUD();saveG();\par
\}\par
\par
// \f1\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\f0\par
// FLOOR\par
// \f1\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\f0\par
function descend()\{\par
  const p=G.player;if(G.map.cells[p.y][p.x].entity!=='stairs')\{addLog('Step onto stairs first!','info');return;\}\par
  if(G.floor>=5)\{G.didWin=true;showRunSummary(true);return;\}\par
  G.floor++;p.hp=Math.min(p.maxHp,p.hp+Math.floor(p.maxHp*.2));p.mp=Math.min(p.maxMp,p.mp+Math.floor(p.maxMp*.3));\par
  G.shopStock=[];\par
  // Floor corruption\par
  const corrSlow=G.metaBonus?.corruptionSlow||0;\par
  addCorruption(Math.max(0,15*(1-corrSlow)));\par
  // Clear elixir buffs on floor change\par
  if(G.elixirBuffs&&G.elixirBuffs.length)\{\par
    G.elixirBuffs.forEach(b=>\{if(b.stat==='atk')p.atk-=b.val;else if(b.stat==='def')p.def-=b.val;else if(b.stat==='spd')p.spd-=b.val;else if(b.stat==='crit')p.crit-=b.val;\});\par
    G.elixirBuffs=[];addLog('\f1\u9203?\f2  \f0 Elixir buffs wore off.','info');\par
  \}\par
  addLog(`\f3\u11015?\u-497?\f2  \f0 Floor $\{G.floor\}! \f3\u9760?\u-497?\f2  \f0 Corruption now $\{G.corruption||0\}%`, 'info');\par
  sfx('rgba(0,0,0,.8)',600);generateMap();placeEntities();updateVision(p.x,p.y);renderMap();updateHUD();updateDoomBar();updateModBar();saveG();\par
\}\par
\par
// \f1\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\f0\par
// LOG\par
// \f1\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\f0\par
function addLog(tx,type='info')\{const l=document.getElementById('log-list'),d=document.createElement('div');d.className=`le $\{type\}`;d.textContent=tx;l.appendChild(d);while(l.children.length>100)l.removeChild(l.firstChild);if(openPanel==='log')l.scrollTop=l.scrollHeight;\}\par
\par
// \f1\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\f0\par
// FLOATERS\par
// \f1\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\f0\par
function spawnDmg(v,col='#ff4444',isH=false)\{\par
  const el=document.createElement('div');el.className='dmgf';el.style.color=col;el.textContent=isH?`+$\{v\}`:`-$\{v\}`;\par
  const cin=document.getElementById('combatov').classList.contains('active')?(isH?gctr('player'):gctr('enemy')):\{x:window.innerWidth/2+(Math.random()-.5)*60,y:window.innerHeight*.4\};\par
  el.style.left=`$\{cin.x+(Math.random()-.5)*40\}px`;el.style.top=`$\{cin.y+(Math.random()-.5)*20\}px`;\par
  document.body.appendChild(el);setTimeout(()=>el.remove(),1000);\par
\}\par
\par
// \f1\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\f0\par
// GAME OVER\par
// \f1\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\f0\par
function gameOver(killer)\{\par
  const p=G.player;const ep=EPITAPHS[Math.floor(Math.random()*EPITAPHS.length)];\par
  document.getElementById('gotitle').textContent='\f4\u-10179?\u-9088?\f2  \f0 YOU DIED \f4\u-10179?\u-9088?\f0 ';\par
  document.getElementById('gotitle').style.color='var(--red)';\par
  document.getElementById('goep').textContent=`Killed by $\{killer\}. $\{ep\}`;\par
  document.getElementById('gost').innerHTML=`Floor: $\{G.floor\} \f2\bullet  Kills: $\{G.kills\} \bullet  Gold: $\{G.goldTotal\}g \bullet  Level: $\{p.level\}`;\par
  localStorage.removeItem(SK);endCombat();\par
  sfx('rgba(200,0,0,.6)',500);\par
  setTimeout(()=>\{document.getElementById('gov').style.display='flex';\},600);\par
  setTimeout(()=>showRunSummary(false),1800);\par
\}\par
function showWin()\{showRunSummary(true);\}\par
\par
// \f1\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\f0\par
// BLACKSMITH\par
// \f1\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\f0\par
function openBlacksmith()\{\par
  const p=G.player;\par
  const el=document.getElementById('bs-content');\par
  if(!el)return;\par
  document.getElementById('bs-gold').textContent=`\f4\u-10179?\u-9040?\f2  \f0 $\{p.gold\}g`;\par
  // Group blueprints by category\par
  const cats=\{\};\par
  BLUEPRINTS.forEach(bp=>\{\par
    if(!cats[bp.cat])cats[bp.cat]=[];\par
    cats[bp.cat].push(bp);\par
  \});\par
  let html='';\par
  for(const [cat,bps] of Object.entries(cats))\{\par
    html+=`<div class="shop-section-title" style="margin-top:10px">$\{getCatEmoji(cat)\} $\{cat\}s</div>`;\par
    bps.forEach(bp=>\{\par
      const canCraft=canCraftBP(bp);\par
      const missing=getMissingMats(bp);\par
      const afford=p.gold>=bp.goldCost;\par
      const ready=canCraft&&afford;\par
      html+=`<div class="bp-card $\{ready?'bp-ready':''\}" onclick="$\{ready?`craftItem('$\{bp.id\}')`:''\}" style="opacity:$\{ready||canCraft?'1':'.65'\}">\par
        <div class="bp-header">\par
          <span class="bp-icon">$\{bp.emoji\}</span>\par
          <div class="bp-info">\par
            <div class="bp-name">$\{bp.name\} <span class="tier-$\{bp.tier\}">[T$\{bp.tier\}]</span></div>\par
            <div class="bp-stats">$\{fmtSt(bp)\}</div>\par
          </div>\par
          <div class="bp-cost $\{afford?'':'cant-afford'\}">$\{bp.goldCost\}g</div>\par
        </div>\par
        <div class="bp-mats">$\{bp.mats.map(m=>\{\par
          const mat=MATERIALS[m.id],have=countMat(m.id);\par
          const ok=have>=m.qty;\par
          return`<span class="mat-tag $\{ok?'mat-ok':'mat-missing'\}">$\{mat?.emoji||'?'\}$\{mat?.name||m.id\} $\{have\}/$\{m.qty\}</span>`;\par
        \}).join('')\}</div>\par
        $\{!ready?`<div class="bp-hint">$\{!afford?'Not enough gold. ':''\}$\{missing.length?'Missing: '+missing.join(', '):''\}</div>`:'<div class="bp-hint" style="color:var(--green)">\f1\u10003?\f2  \f0 Ready to craft!</div>'\}\par
      </div>`;\par
    \});\par
  \}\par
  el.innerHTML=html;\par
\}\par
\par
function getCatEmoji(cat)\{\par
  return\{Sword:'\f3\u9876?\u-497?\f0 ',Mace:'\f4\u-10179?\u-8920?\f0 ',Spear:'\f3\u-10179?\u-8735?\u-497?\f0 ',Staff:'\f3\u-10178?\u-8572?\f0 ',Armor:'\f3\u-10179?\u-8479?\u-497?\f0 ',Boots:'\f4\u-10179?\u-9118?\f0 ',Helmet:'\f3\u9937?\u-497?\f0 ',Ring:'\f4\u-10179?\u-9075?\f0 '\}[cat]||'\f4\u-10179?\u-8921?\f0 ';\par
\}\par
\par
function countMat(id)\{\par
  return G.inventory.filter(i=>i.type==='material'&&i.id===id).length;\par
\}\par
\par
function getMissingMats(bp)\{\par
  const missing=[];\par
  bp.mats.forEach(m=>\{\par
    const have=countMat(m.id);\par
    if(have<m.qty)missing.push(`$\{MATERIALS[m.id]?.emoji||'?'\}$\{MATERIALS[m.id]?.name\} ($\{m.qty-have\} more)`);\par
  \});\par
  return missing;\par
\}\par
\par
function canCraftBP(bp)\{\par
  return bp.mats.every(m=>countMat(m.id)>=m.qty);\par
\}\par
\par
function craftItem(bpId)\{\par
  const bp=BLUEPRINTS.find(b=>b.id===bpId);\par
  if(!bp)return;\par
  const p=G.player;\par
  if(!canCraftBP(bp))\{addLog('Missing materials!','damage');return;\}\par
  if(p.gold<bp.goldCost)\{addLog(`Need $\{bp.goldCost\}g!`,'damage');return;\}\par
  if(G.inventory.length>=G.maxInvSlots)\{addLog('Inventory full!','damage');return;\}\par
  // Consume materials\par
  bp.mats.forEach(m=>\{\par
    let qty=m.qty;\par
    G.inventory=G.inventory.filter(i=>\{\par
      if(qty>0&&i.type==='material'&&i.id===m.id)\{qty--;return false;\}\par
      return true;\par
    \});\par
  \});\par
  p.gold-=bp.goldCost;\par
  // Create the crafted item\par
  const crafted=\{...bp,uid:Math.random().toString(36).slice(2),crafted:true\};\par
  delete crafted.mats;delete crafted.goldCost;delete crafted.cat;delete crafted.desc;\par
  crafted.desc=`Crafted at the Blacksmith. $\{bp.desc\}`;\par
  G.inventory.push(crafted);\par
  addLog(`\f4\u-10179?\u-8920?\f2  \f0 Crafted $\{bp.emoji\} $\{bp.name\} [T$\{bp.tier\}]!`,'loot');\par
  sfx('rgba(255,140,0,.3)',400);\par
  spPt(window.innerWidth*.5,window.innerHeight*.5,'#ff8800',18,\{speed:4,spread:5,grav:-.02,decay:.04\});\par
  spRi(window.innerWidth*.5,window.innerHeight*.5,'#ffaa00');\par
  updateHUD();openBlacksmith();saveG();\par
\}\par
\par
// \f1\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\f0\par
// ALCHEMIST\par
// \f1\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\f0\par
function openAlchemist()\{\par
  const p=G.player;\par
  const el=document.getElementById('alch-content');\par
  if(!el)return;\par
  document.getElementById('alch-gold').textContent=`\f4\u-10179?\u-9040?\f2  \f0 $\{p.gold\}g`;\par
  const isMage=p.classType==='mage';\par
  const recipes=ALCH_RECIPES.filter(r=>!r.mageOnly||isMage);\par
  let html='';\par
  if(!isMage)\{\par
    html+=`<div style="background:#0a0a1a;border:2px solid #2a1a3a;border-radius:4px;padding:8px;margin-bottom:10px;font-family:'VT323',monospace;font-size:13px;color:#aa88cc">\par
\f2       \f4\u-10179?\u-8914?\f2  \f0 Chaos Wizards get exclusive mage-only recipes! Some things are available to all heroes.\par
    </div>`;\par
  \}\par
  // Group by type\par
  const potions=recipes.filter(r=>!r.mageOnly);\par
  const mageRecipes=recipes.filter(r=>r.mageOnly);\par
  if(potions.length)\{\par
    html+=`<div class="shop-section-title">\f3\u-10178?\u-8726?\f2  \f0 BREWS (All Classes)</div>`;\par
    potions.forEach(r=>html+=renderRecipe(r,p));\par
  \}\par
  if(mageRecipes.length)\{\par
    html+=`<div class="shop-section-title" style="margin-top:10px">\f4\u-10179?\u-8914?\f2  \f0 MAGE RECIPES (Chaos Wizard Only)</div>`;\par
    mageRecipes.forEach(r=>html+=renderRecipe(r,p));\par
  \}\par
  el.innerHTML=html;\par
\}\par
\par
function renderRecipe(r,p)\{\par
  const canBrew=r.mats.every(m=>countMat(m.id)>=m.qty);\par
  const afford=p.gold>=r.goldCost;\par
  const ready=canBrew&&afford;\par
  return`<div class="bp-card $\{ready?'bp-ready':''\}" onclick="$\{ready?`brewRecipe('$\{r.id\}')`:''\}" style="opacity:$\{ready||canBrew?'1':'.65'\}">\par
    <div class="bp-header">\par
      <span class="bp-icon">$\{r.emoji\}</span>\par
      <div class="bp-info">\par
        <div class="bp-name">$\{r.name\}$\{r.mageOnly?` <span style="color:#aa44ff;font-size:6px">MAGE</span>`:''\}</div>\par
        <div class="bp-stats" style="color:var(--gray);font-family:'VT323',monospace;font-size:12px">$\{r.desc\}</div>\par
      </div>\par
      <div class="bp-cost $\{afford?'':'cant-afford'\}">$\{r.goldCost\}g</div>\par
    </div>\par
    <div class="bp-mats">$\{r.mats.map(m=>\{\par
      const mat=MATERIALS[m.id],have=countMat(m.id);\par
      const ok=have>=m.qty;\par
      return`<span class="mat-tag $\{ok?'mat-ok':'mat-missing'\}">$\{mat?.emoji||'?'\}$\{mat?.name||m.id\} $\{have\}/$\{m.qty\}</span>`;\par
    \}).join('')\}</div>\par
    $\{ready?'<div class="bp-hint" style="color:var(--green)">\f1\u10003?\f2  \f0 Ready to brew!</div>':''\}\par
  </div>`;\par
\}\par
\par
function brewRecipe(recipeId)\{\par
  const r=ALCH_RECIPES.find(x=>x.id===recipeId);\par
  if(!r)return;\par
  const p=G.player;\par
  if(r.mageOnly&&p.classType!=='mage')\{addLog('Only Chaos Wizards can brew this!','damage');return;\}\par
  if(!r.mats.every(m=>countMat(m.id)>=m.qty))\{addLog('Missing ingredients!','damage');return;\}\par
  if(p.gold<r.goldCost)\{addLog(`Need $\{r.goldCost\}g!`,'damage');return;\}\par
  if(G.inventory.length>=G.maxInvSlots)\{addLog('Inventory full!','damage');return;\}\par
  // Consume mats\par
  r.mats.forEach(m=>\{\par
    let qty=m.qty;\par
    G.inventory=G.inventory.filter(i=>\{\par
      if(qty>0&&i.type==='material'&&i.id===m.id)\{qty--;return false;\}\par
      return true;\par
    \});\par
  \});\par
  p.gold-=r.goldCost;\par
  // Handle transmutation (material result)\par
  let result;\par
  if(r.result.type==='material')\{\par
    result=\{...makeMaterial(r.result.matId),desc:r.result.desc\};\par
  \}else\{\par
    result=\{...r.result,uid:Math.random().toString(36).slice(2)\};\par
  \}\par
  G.inventory.push(result);\par
  addLog(`\f3\u9879?\u-497?\f2  \f0 Brewed: $\{r.emoji\} $\{r.name\}!`,'loot');\par
  sfx('rgba(170,68,255,.35)',400);\par
  spPt(window.innerWidth*.5,window.innerHeight*.5,'#aa44ff',16,\{speed:4,spread:5,grav:-.05,decay:.04\});\par
  spRi(window.innerWidth*.5,window.innerHeight*.5,'#7722ff');\par
  updateHUD();openAlchemist();saveG();\par
\}\par
\par
// \f1\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\f0\par
// \f1\u9472?\u9472?\u9472?\u9472?\u9472?\f2  \f0 DOOM CORRUPTION SYSTEM \f1\u9472?\u9472?\u9472?\u9472?\u9472?\f0\par
// \f1\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\f0\par
\par
// Corruption thresholds \f2\emdash  each triggers a new modifier stack\par
const DOOM_THRESHOLDS = [\par
  \{pct:20, name:'DOOM LV.1', emoji:'\f3\u-10178?\u-8584?\f0 ', color:'#ff8844'\},\par
  \{pct:40, name:'DOOM LV.2', emoji:'\f4\u-10179?\u-9088?\f0 ', color:'#ff4422'\},\par
  \{pct:60, name:'DOOM LV.3', emoji:'\f3\u9760?\u-497?\f0 ',  color:'#ff2266'\},\par
  \{pct:80, name:'DOOM LV.4', emoji:'\f3\u-10179?\u-9151?\u-497?\f0 ',  color:'#ff00ff'\},\par
  \{pct:100,name:'DOOM LV.5 \f2\emdash  TOTAL DOOM', emoji:'\f4\u-10180?\u-8431?\f0 ', color:'#ff0044'\},\par
];\par
\par
// All possible dungeon modifiers \f2\emdash  data-driven\par
const ALL_MODIFIERS = [\par
  \{id:'greedy_shops',   name:'GREEDY SHOPS',    emoji:'\f4\u-10179?\u-9032?\f0 ', desc:'Shop prices +25%.',    effect:\{shopMult:1.25\}, positive:false\},\par
  \{id:'heal_curse',     name:'HEAL CURSE',       emoji:'\f3\u-10178?\u-8583?\f0 ', desc:'All healing -35%.',   effect:\{healMult:0.65\}, positive:false\},\par
  \{id:'enemies_explode',name:'VOLATILE FOES',    emoji:'\f4\u-10179?\u-9051?\f0 ', desc:'Enemies explode on death, dealing 15% max HP to you.', effect:\{enemyExplode:true\}, positive:false\},\par
  \{id:'slippery',       name:'SLIPPERY FLOORS',  emoji:'\f3\u-10178?\u-8758?\f0 ', desc:'10% chance per move to slip an extra tile.', effect:\{slippery:true\}, positive:false\},\par
  \{id:'fusion_tax',     name:'FUSION TAX',       emoji:'\f3\u9879?\u-497?\f0 ', desc:'Fusion costs 2\'d7 gold but 20% chance to jump +1 extra tier.', effect:\{fusionTax:true\}, positive:false\},\par
  \{id:'enemy_regen',    name:'ENEMY REGEN',      emoji:'\f4\u-10179?\u-8956?\f0 ', desc:'Enemies regain 3% max HP each turn.', effect:\{enemyRegen:true\}, positive:false\},\par
  \{id:'cursed_loot',    name:'CURSED LOOT',      emoji:'\f4\u-10178?\u-8926?\f0 ', desc:'All dropped items are 1 tier lower.',  effect:\{lootCurse:true\}, positive:false\},\par
  \{id:'no_flee',        name:'INESCAPABLE',      emoji:'\f4\u-10179?\u-8942?\f0 ', desc:'Cannot flee from combat.',            effect:\{noFlee:true\}, positive:false\},\par
  \{id:'mp_drain',       name:'MANA DRAIN',       emoji:'\f4\u-10179?\u-9049?\f0 ', desc:'Lose 5 MP per combat action.',        effect:\{mpDrain:5\}, positive:false\},\par
  \{id:'elite_surge',    name:'ELITE SURGE',      emoji:'\f1\u11088?\f0 ', desc:'All enemies become Elite (+50% HP, +25% ATK, better loot).', effect:\{eliteSurge:true\}, positive:false\},\par
  // Positive (silver lining) modifiers \f2\emdash  appear at high corruption\par
  \{id:'doom_loot',      name:'DOOM REWARD',      emoji:'\f4\u-10180?\u-8319?\f0 ', desc:'Kill rewards +50% gold and XP.', effect:\{killBoost:1.5\}, positive:true\},\par
  \{id:'power_surge',    name:'POWER SURGE',      emoji:'\f1\u9889?\f0 ', desc:'You deal +20% damage.', effect:\{dmgBoost:1.2\}, positive:true\},\par
  \{id:'blood_pact',     name:'BLOOD PACT',       emoji:'\f3\u-10178?\u-8584?\f0 ', desc:'Gain 15% lifesteal.', effect:\{lifeStealBoost:.15\}, positive:true\},\par
];\par
\par
// Get active modifier effects as a merged object\par
function getModEffects()\{\par
  if(!G||!G.activeModifiers)return\{\};\par
  const out=\{\};\par
  G.activeModifiers.forEach(id=>\{\par
    const m=ALL_MODIFIERS.find(x=>x.id===id);\par
    if(m)Object.assign(out,m.effect);\par
  \});\par
  return out;\par
\}\par
\par
function getDoomLevel()\{\par
  if(!G)return 0;\par
  const pct=G.corruption||0;\par
  let lvl=0;\par
  DOOM_THRESHOLDS.forEach((t,i)=>\{if(pct>=t.pct)lvl=i+1;\});\par
  return lvl;\par
\}\par
\par
// Add corruption and trigger modifiers if threshold crossed\par
function addCorruption(amount)\{\par
  if(!G)return;\par
  const prev=G.corruption||0;\par
  const next=Math.min(100,prev+amount);\par
  G.corruption=next;\par
\par
  // Check threshold crossings\par
  DOOM_THRESHOLDS.forEach((t,i)=>\{\par
    if(prev<t.pct&&next>=t.pct)\{\par
      triggerDoomLevel(i);\par
    \}\par
  \});\par
  updateDoomBar();\par
\}\par
\par
function triggerDoomLevel(idx)\{\par
  const thresh=DOOM_THRESHOLDS[idx];\par
  addLog(`$\{thresh.emoji\} $\{thresh.name\} REACHED!`,'damage');\par
  sfx('rgba(255,0,50,.5)',500);\par
  spPt(window.innerWidth*.5,window.innerHeight*.4,'#ff2266',25,\{speed:5,spread:6,grav:.05,decay:.03\});\par
  spRi(window.innerWidth*.5,window.innerHeight*.4,'#ff0044');\par
  document.getElementById('game-screen').classList.add('bigshake');\par
  setTimeout(()=>document.getElementById('game-screen').classList.remove('bigshake'),500);\par
\par
  // Inject a new modifier (pick random unused, prefer negative at low doom, mix positive later)\par
  if(!G.activeModifiers)G.activeModifiers=[];\par
  const used=new Set(G.activeModifiers);\par
  const pool=ALL_MODIFIERS.filter(m=>\{\par
    if(used.has(m.id))return false;\par
    if(m.positive)return idx>=3; // positive modifiers only at doom 4+\par
    return true;\par
  \});\par
  if(pool.length)\{\par
    const pick=pool[Math.floor(Math.random()*pool.length)];\par
    if(G.activeModifiers.length>=3)\{G.activeModifiers.shift();\} // max 3 active\par
    G.activeModifiers.push(pick.id);\par
    addLog(`\f4\u-10179?\u-8908?\f2  \f0 NEW MODIFIER: $\{pick.emoji\} $\{pick.name\} \f2\emdash  $\{pick.desc\}`,'damage');\par
    showModifierBanner(pick);\par
  \}\par
  updateDoomBar();\par
  updateModBar();\par
\}\par
\par
function showModifierBanner(mod)\{\par
  const b=document.createElement('div');\par
  b.style.cssText=`position:fixed;top:20%;left:50%;transform:translateX(-50%);background:#1a0010;border:3px solid #ff2266;color:#ff6688;font-family:'Press Start 2P',monospace;font-size:9px;padding:12px 20px;z-index:600;text-align:center;border-radius:6px;box-shadow:0 0 30px rgba(255,34,102,.4);max-width:90vw;`;\par
  b.innerHTML=`$\{mod.emoji\} $\{mod.name\}<br><span style="font-size:7px;color:#ff9999;font-family:'VT323',monospace;font-size:15px">$\{mod.desc\}</span>`;\par
  document.body.appendChild(b);\par
  setTimeout(()=>b.style.transition='opacity .5s',1200);\par
  setTimeout(()=>b.style.opacity='0',1700);\par
  setTimeout(()=>b.remove(),2200);\par
\}\par
\par
function updateDoomBar()\{\par
  if(!G)return;\par
  const pct=G.corruption||0;\par
  const lvl=getDoomLevel();\par
  const colors=['#880033','#cc4400','#cc2222','#cc0044','#ff00ff'];\par
  const fills=['#660033,#cc0044,#ff2266','#884400,#cc6600,#ff8800','#660000,#cc0000,#ff2222','#660033,#cc0044,#ff00aa','#660066,#aa00aa,#ff00ff'];\par
  const fill=document.getElementById('doom-fill');\par
  const lbl=document.getElementById('doom-label');\par
  if(fill)\{fill.style.width=pct+'%';fill.style.background=`linear-gradient(90deg,$\{fills[Math.min(lvl,4)]\})`;fill.style.boxShadow=`0 0 $\{6+lvl*3\}px $\{colors[Math.min(lvl,4)]\}`;\}\par
  if(lbl)\{const lvlNames=['','LV1','LV2','LV3','LV4','MAX'];lbl.textContent=`\f1\u9760?\f2  \f0 $\{pct\}%$\{lvl>0?' '+lvlNames[lvl]:''\}`;lbl.style.color=lvl>0?colors[lvl-1]:'#ff2266';\}\par
\}\par
\par
function updateModBar()\{\par
  if(!G)return;\par
  const bar=document.getElementById('mod-bar');\par
  if(!bar)return;\par
  const mods=G.activeModifiers||[];\par
  if(!mods.length)\{bar.style.display='none';return;\}\par
  bar.style.display='block';\par
  bar.innerHTML=mods.map(id=>\{\par
    const m=ALL_MODIFIERS.find(x=>x.id===id);\par
    if(!m)return'';\par
    return`<span class="mod-badge $\{m.positive?'positive':''\}">$\{m.emoji\} $\{m.name\}</span>`;\par
  \}).join('');\par
\}\par
\par
function openDoomPanel()\{\par
  const el=document.getElementById('doom-panel-content');\par
  if(!el)return;\par
  const pct=G.corruption||0;\par
  const lvl=getDoomLevel();\par
  const mods=G.activeModifiers||[];\par
  let html=`<div class="doom-card">\par
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">\par
      <div style="font-size:8px;color:#ff2266">\f1\u9760?\f2  \f0 CORRUPTION: $\{pct\}%</div>\par
      <div style="font-size:7px;color:#ff6688">Doom Level: $\{lvl\}/5</div>\par
    </div>\par
    <div style="background:#1a0010;border-radius:4px;height:10px;overflow:hidden;margin-bottom:8px;">\par
      <div style="height:100%;width:$\{pct\}%;background:linear-gradient(90deg,#660033,#ff2266);transition:width .3s;"></div>\par
    </div>\par
    <div style="font-family:'VT323',monospace;font-size:13px;color:var(--gray)">Higher corruption = better loot, stronger enemies, stranger rules.<br>Each 20% triggers a new dungeon modifier.</div>\par
  </div>`;\par
\par
  if(mods.length)\{\par
    html+=`<div style="font-size:7px;color:#ff2266;margin-bottom:6px">\f4\u-10179?\u-8908?\f2  \f0 ACTIVE MODIFIERS ($\{mods.length\}/3)</div>`;\par
    mods.forEach(id=>\{\par
      const m=ALL_MODIFIERS.find(x=>x.id===id);\par
      if(!m)return;\par
      html+=`<div class="doom-card active-mod">\par
        <div style="font-size:8px;color:$\{m.positive?'#66ff66':'#ff6688'\};margin-bottom:4px">$\{m.emoji\} $\{m.name\}</div>\par
        <div style="font-family:'VT323',monospace;font-size:14px;color:var(--gray)">$\{m.desc\}</div>\par
      </div>`;\par
    \});\par
  \}else\{\par
    html+=`<div style="font-family:'VT323',monospace;font-size:15px;color:var(--gray);padding:8px;text-align:center">No active modifiers yet. Gain corruption to unlock doom!</div>`;\par
  \}\par
\par
  html+=`<div style="font-size:7px;color:#ff2266;margin-bottom:6px;margin-top:10px">\f4\u-10179?\u-9011?\f2  \f0 UPCOMING THRESHOLDS</div>`;\par
  DOOM_THRESHOLDS.forEach(t=>\{\par
    const reached=pct>=t.pct;\par
    html+=`<div class="doom-threshold $\{reached?'reached':'upcoming'\}">\par
      <span>$\{reached?'\f1\u10003?\f0 ':t.emoji\}</span>\par
      <span style="flex:1">$\{t.name\} @ $\{t.pct\}%</span>\par
      $\{reached?`<span style="color:#ff2266">ACTIVE</span>`:`<span>$\{t.pct-pct\}% away</span>`\}\par
    </div>`;\par
  \});\par
\par
  html+=`<div style="font-family:'VT323',monospace;font-size:13px;color:var(--gray);margin-top:12px;padding:8px;background:#080808;border-radius:4px;line-height:1.8">\par
    <div style="color:#ff2266;font-size:12px;margin-bottom:4px">\f4\u-10179?\u-9016?\f2  \f0 CORRUPTION SOURCES</div>\par
    Each floor: +15% \f2\bullet  Each enemy killed: +1% \bullet  Boss kill: +8%<br>\par
    Floor milestone: +5% \bullet  Using chaos spells: +2%\par
  </div>`;\par
\par
  el.innerHTML=html;\par
\}\par

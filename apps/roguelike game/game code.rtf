  \{id:'start_potion', name:'MEDIC PACK',          emoji:'\f3\u-10178?\u-8726?\f0 ', desc:'Start each run with 1 extra HP potion.', maxLevel:1, baseCost:4, costPerLevel:0, apply:(lvl)=>(\{startPotion:lvl>0\})\},\par
  \{id:'corruption_slow',name:'DOOM RESISTANCE',  emoji:'\f3\u9760?\u-497?\f0 ', desc:'-20% corruption gain per level.', maxLevel:3, baseCost:5, costPerLevel:6, apply:(lvl)=>(\{corruptionSlow:lvl*.2\})\},\par
  \{id:'xp_boost',    name:'QUICK LEARNER',        emoji:'\f1\u11088?\f0 ', desc:'+15% XP gain per level.', maxLevel:3, baseCost:3, costPerLevel:4, apply:(lvl)=>(\{xpBonus:lvl*.15\})\},\par
];\par
\par
function loadMeta()\{\par
  try\{return JSON.parse(localStorage.getItem(META_SK))||\{shards:0,upgrades:\{\}\};\}catch(e)\{return\{shards:0,upgrades:\{\}\};\}\par
\}\par
function saveMeta(meta)\{\par
  try\{localStorage.setItem(META_SK,JSON.stringify(meta));\}catch(e)\{\}\par
\}\par
function getMetaBonus()\{\par
  const meta=loadMeta();\par
  const bonus=\{\};\par
  META_UPGRADES.forEach(u=>\{\par
    const lvl=meta.upgrades[u.id]||0;\par
    if(lvl>0)Object.assign(bonus,u.apply(lvl));\par
  \});\par
  return bonus;\par
\}\par
function getUpgradeCost(u, currentLevel)\{\par
  return u.baseCost + currentLevel * u.costPerLevel;\par
\}\par
\par
function openMetaScreen()\{\par
  document.getElementById('meta-screen').style.display='block';\par
  renderMetaScreen();\par
\}\par
function closeMetaScreen()\{\par
  document.getElementById('meta-screen').style.display='none';\par
\}\par
function renderMetaScreen()\{\par
  const meta=loadMeta();\par
  document.getElementById('meta-shards-display').textContent=`\f4\u-10179?\u-9056?\f2  \f0 $\{meta.shards\} Doom Shards available`;\par
  const el=document.getElementById('meta-upgrades-list');\par
  el.innerHTML='';\par
  META_UPGRADES.forEach(u=>\{\par
    const lvl=meta.upgrades[u.id]||0;\par
    const maxed=lvl>=u.maxLevel;\par
    const cost=getUpgradeCost(u,lvl);\par
    const canAfford=meta.shards>=cost;\par
    const div=document.createElement('div');\par
    div.className='meta-upgrade-card'+(maxed?' maxed':'');\par
    div.innerHTML=`\par
      <div class="meta-upgrade-icon">$\{u.emoji\}</div>\par
      <div class="meta-upgrade-info">\par
        <div class="meta-upgrade-name">$\{u.name\}</div>\par
        <div class="meta-upgrade-desc">$\{u.desc\}</div>\par
        <div class="meta-upgrade-level">$\{maxed?'\f1\u10003?\f2  \f0 MAX':'Lv '+lvl+'/'+u.maxLevel\}</div>\par
      </div>\par
      <div class="meta-upgrade-cost $\{!canAfford&&!maxed?'cant-afford':''\}">\par
        $\{maxed?'MAXED':cost+'\f4\u-10179?\u-9056?\f0 '\}\par
      </div>`;\par
    if(!maxed)\{\par
      div.onclick=()=>\{\par
        const m=loadMeta();\par
        const l=m.upgrades[u.id]||0;\par
        const c=getUpgradeCost(u,l);\par
        if(m.shards<c)\{return;\}\par
        m.shards-=c;\par
        m.upgrades[u.id]=(l+1);\par
        saveMeta(m);\par
        renderMetaScreen();\par
        if(document.getElementById('title-shard-count'))\par
          document.getElementById('title-shard-count').textContent=m.shards;\par
      \};\par
    \}\par
    el.appendChild(div);\par
  \});\par
\}\par
\par
// \f1\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\f0\par
// \f1\u9472?\u9472?\u9472?\u9472?\u9472?\f2  \f0 RUN SUMMARY \f1\u9472?\u9472?\u9472?\u9472?\u9472?\f0\par
// \f1\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\f0\par
function calcRunShards()\{\par
  const p=G.player;\par
  let shards=0;\par
  const breakdown=[];\par
  // Floor milestones\par
  const floorBonus=G.floor*2;\par
  shards+=floorBonus;breakdown.push(`Floor $\{G.floor\}: +$\{floorBonus\}\f4\u-10179?\u-9056?\f0 `);\par
  // Kill bonus\par
  const killBonus=Math.floor(G.kills/5);\par
  if(killBonus>0)\{shards+=killBonus;breakdown.push(`$\{G.kills\} kills: +$\{killBonus\}\f4\u-10179?\u-9056?\f0 `);\}\par
  // Corruption bonus\par
  const corrBonus=Math.floor((G.corruption||0)/20)*2;\par
  if(corrBonus>0)\{shards+=corrBonus;breakdown.push(`Corruption $\{G.corruption\}%: +$\{corrBonus\}\f4\u-10179?\u-9056?\f0 `);\}\par
  // Win bonus\par
  if(G.didWin)\{shards+=10;breakdown.push('RUN COMPLETE: +10\f4\u-10179?\u-9056?\f0 ');\}\par
  // Boss kills\par
  const bossBonus=(G.bossKills||0)*5;\par
  if(bossBonus>0)\{shards+=bossBonus;breakdown.push(`$\{G.bossKills\} boss(es): +$\{bossBonus\}\f4\u-10179?\u-9056?\f0 `);\}\par
  // High doom\par
  const doomLvl=getDoomLevel();\par
  const doomBonus=doomLvl*2;\par
  if(doomBonus>0)\{shards+=doomBonus;breakdown.push(`Doom Lv$\{doomLvl\}: +$\{doomBonus\}\f4\u-10179?\u-9056?\f0 `);\}\par
  return\{shards,breakdown\};\par
\}\par
\par
function showRunSummary(won)\{\par
  G.didWin=won;\par
  const p=G.player;\par
  const \{shards,breakdown\}=calcRunShards();\par
\par
  // Save shards to meta\par
  const meta=loadMeta();\par
  meta.shards+=shards;\par
  meta.totalRuns=(meta.totalRuns||0)+1;\par
  if(won)meta.wins=(meta.wins||0)+1;\par
  if((G.floor||1)>(meta.bestFloor||0))meta.bestFloor=G.floor;\par
  saveMeta(meta);\par
\par
  // Update title screen shard count if visible\par
  if(document.getElementById('title-shard-count'))\par
    document.getElementById('title-shard-count').textContent=meta.shards;\par
\par
  document.getElementById('rs-title').textContent=won?'\f4\u-10180?\u-8250?\f2  \f0 VICTORY ROYALE':'\f4\u-10179?\u-9088?\f2  \f0 YOU PERISHED';\par
  document.getElementById('rs-title').style.color=won?'var(--gold)':'var(--red)';\par
  document.getElementById('rs-sub').textContent=won\par
    ?'Against all odds, you cleared the dungeon. The dungeon is disappointed.'\par
    :`Floor $\{G.floor\} was your undoing. The rats mourn. Briefly.`;\par
\par
  const stats=[\par
    ['\f3\u-10180?\u-8230?\u-497?\f2  \f0 Floor Reached',G.floor],\par
    ['\f4\u-10179?\u-9088?\f2  \f0 Enemies Killed',G.kills],\par
    ['\f4\u-10179?\u-9040?\f2  \f0 Gold Earned',G.goldTotal+'g'],\par
    ['\f1\u11088?\f2  \f0 Level Reached',p.level],\par
    ['\f3\u9760?\u-497?\f2  \f0 Corruption',`$\{G.corruption||0\}%`],\par
    ['\f4\u-10179?\u-9135?\f2  \f0 Doom Level',getDoomLevel()],\par
    ['\f4\u-10179?\u-8908?\f2  \f0 Modifiers Active',(G.activeModifiers||[]).length],\par
    ['\f3\u9879?\u-497?\f2  \f0 Items Fused',G.fusionCount||0],\par
  ];\par
  document.getElementById('rs-stats').innerHTML=stats.map(([k,v])=>`<div class="rs-stat"><span class="rs-stat-k">$\{k\}</span><span class="rs-stat-v">$\{v\}</span></div>`).join('');\par
  document.getElementById('rs-shard-breakdown').innerHTML=breakdown.map(s=>`<div>$\{s\}</div>`).join('');\par
  document.getElementById('rs-shard-total').textContent=`Total earned: $\{shards\}\f4\u-10179?\u-9056?\f2  \f0 (Bank: $\{meta.shards\}\f4\u-10179?\u-9056?\f0 )`;\par
\par
  document.getElementById('gov').style.display='none';\par
  document.getElementById('run-summary').style.display='flex';\par
\}\par
\par
// \f1\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\f0\par
// SETUP\par
// \f1\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\f0\par
let SC=null;\par
function selectClass(el)\{document.querySelectorAll('.class-card').forEach(c=>c.classList.remove('selected'));el.classList.add('selected');SC=el.dataset.class;document.getElementById('start-btn').disabled=false;\}\par
\par
function equipDirect(it)\{\par
  const p=G.player;\par
  if(it.type==='weapon')\{if(G.equippedWeapon)\{p.atk-=G.equippedWeapon.effect.atk||0;\}G.equippedWeapon=it;p.atk+=it.effect.atk||0;if(it.effect.crit)p.crit+=it.effect.crit;if(it.effect.def)p.def+=it.effect.def||0;\}\par
\}\par
\par
function startNewGame()\{\par
  if(!SC)return;localStorage.removeItem(SK);\par
  const cls=CLS[SC];\par
  const meta=getMetaBonus();\par
\par
  G=\{\par
    player:\{x:0,y:0,emoji:cls.emoji,className:cls.name,classType:SC,classData:cls,\par
      level:1,xp:0,hp:cls.hp,maxHp:cls.hp,mp:cls.mp,maxMp:cls.mp,\par
      atk:cls.atk,def:cls.def,spd:cls.spd,crit:cls.crit,gold:50,perks:\{\},status:\{\}\},\par
    map:null,enemies:[],items:[],\par
    floor:1,turn:0,inCombat:false,currentEnemy:null,\par
    inventory:[],equippedWeapon:null,equippedArmor:null,equippedRing:null,\par
    kills:0,goldTotal:0,perkList:[],maxInvSlots:8+(meta.invBonus||0),shopStock:[],elixirBuffs:[],\par
    corruption:0,activeModifiers:[],bossKills:0,fusionCount:0,\par
    metaBonus:meta,shopRerollsLeft:meta.vendorReroll?1:0\par
  \};\par
\par
  // Starting weapon\par
  const startWpnData=WEAPON_TIERS[0].find(w=>w.id===cls.sw)||WEAPON_TIERS[0][0];\par
  const sw=\{...startWpnData,type:'weapon',tier:1,uid:Math.random().toString(36).slice(2)\};\par
  G.inventory.push(sw);\par
  G.inventory.push(\{...CONSUMABLES[0],uid:Math.random().toString(36).slice(2)\});\par
  G.inventory.push(\{...CONSUMABLES[0],uid:Math.random().toString(36).slice(2)\});\par
  G.inventory.push(\{...CONSUMABLES[2],uid:Math.random().toString(36).slice(2)\});\par
  if(meta.startPotion)G.inventory.push(\{...CONSUMABLES[0],uid:Math.random().toString(36).slice(2)\});\par
  // Meta: start with materials\par
  if(meta.startMat)\{\par
    G.inventory.push(makeMaterial('iron_ore'));\par
    G.inventory.push(makeMaterial('leather'));\par
  \}\par
  equipDirect(sw);\par
  showGS();generateMap();placeEntities();updateVision(G.player.x,G.player.y);\par
  addLog(`\f4\u-10180?\u-8274?\f2  \f0 Welcome, $\{cls.name\}! 50g to start.`,'info');\par
  addLog(`\f4\u-10179?\u-9055?\f2  \f0 Walk to \f4\u-10180?\u-8214?\f2  \f0 Shop \f2\bullet  \f4\u-10179?\u-8920?\f2  \f0 Blacksmith \f2\bullet  \f3\u9879?\u-497?\f2  \f0 Alchemist! Kill enemies for materials.`,'info');\par
  if(meta.invBonus)addLog(`\f4\u-10180?\u-8302?\f2  \f0 Meta bonus: +$\{meta.invBonus\} inventory slots!`,'loot');\par
  updateDoomBar();updateModBar();\par
  renderMap();updateHUD();saveG();\par
\}\par
\par
function showGS()\{document.getElementById('title-screen').style.display='none';document.getElementById('game-screen').style.display='flex';\}\par
\par
// \f1\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\f0\par
// KEYBOARD\par
// \f1\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\f0\par
document.addEventListener('keydown',e=>\{\par
  if(document.getElementById('luov').classList.contains('active'))return;\par
  if(G.inCombat)\{if(e.key==='Escape')ca('flee');if(e.key==='1')ca('attack');if(e.key==='2')ca('skill');if(e.key==='3')ca('item');if(e.key.toLowerCase()==='q')ca('item');return;\}\par
  const dirs=\{ArrowUp:[0,-1],w:[0,-1],W:[0,-1],ArrowDown:[0,1],s:[0,1],S:[0,1],ArrowLeft:[-1,0],a:[-1,0],A:[-1,0],ArrowRight:[1,0],d:[1,0],D:[1,0]\};\par
  if(dirs[e.key])\{e.preventDefault();handleMove(...dirs[e.key]);\}\par
  if(e.key===' ')\{e.preventDefault();doWait();\}\par
  if(e.key==='.'||e.key==='g')tryPickup();\par
  if(e.key==='i')togglePanel('inv');\par
  if(e.key==='m')togglePanel('menu');\par
  if(e.key==='f')togglePanel('fuse');\par
  if(e.key==='c')togglePanel('stats');\par
  if(e.key==='l')togglePanel('log');\par
  if(e.key.toLowerCase()==='q')quickUse('hp');\par
  if(e.key.toLowerCase()==='e')quickUse('mp');\par
  if(e.key==='='||e.key==='+')adjustZoom(1);\par
  if(e.key==='-')adjustZoom(-1);\par
  if(e.key==='Enter')\{const c=G.map?.cells[G.player?.y]?.[G.player?.x];if(c?.entity==='stairs')descend();if(c?.entity==='shop')togglePanel('shop');\}\par
  if(e.key==='Escape')closeAllPanels();\par
\});\par
window.addEventListener('keydown',e=>\{if(['ArrowUp','ArrowDown','ArrowLeft','ArrowRight',' '].includes(e.key))e.preventDefault();\});\par
window.addEventListener('resize',()=>\{rzV();if(G.map)renderMap();\});\par
window.addEventListener('load',()=>\{\par
  const sf=checkSave();\par
  if(sf)\{document.getElementById('continue-btn').style.display='block';document.getElementById('sfl').textContent=sf;\}\par
  const meta=loadMeta();\par
  if(document.getElementById('title-shard-count'))document.getElementById('title-shard-count').textContent=meta.shards;\par
\});\par
</script>\par
</body>\par

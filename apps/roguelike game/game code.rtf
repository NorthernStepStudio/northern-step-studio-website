    <div id="inv-grid"></div>\par
    <div style="font-size:7px;color:var(--gray);line-height:2.4;margin-top:6px">\par
\f2       \f3\u9876?\u-497?\f2  \f0 <span id="eqw" style="color:#ff9944">\f2\emdash </span><br>\par
      \f3\u-10179?\u-8479?\u-497?\f2  \f0 <span id="eqa" style="color:var(--blue)">\f2\emdash </span><br>\par
      \f4\u-10179?\u-9075?\f2  \f0 <span id="eqr" style="color:var(--purple)">\f2\emdash </span>\par
    </div>\par
    <div class="shop-section-title" style="margin-top:12px">\f3\u-10178?\u-8536?\f2  \f0 CRAFTING MATERIALS</div>\par
    <div id="mat-grid" style="display:flex;flex-wrap:wrap;gap:4px;margin-top:4px"></div>\par
  </div>\par
</div>\par
\par
<!-- SHOP -->\par
<div class="spanel" id="panel-shop">\par
  <div class="sph"><div class="spt">\f4\u-10180?\u-8214?\f2  \f0 SHOP \f2\emdash  <span id="shop-gold-disp" style="color:var(--gold)">\f4\u-10179?\u-9040?\f2  \f0 0g</span></div><button class="spc" onclick="closeAllPanels()">\f1\u10005?\f0 </button></div>\par
  <div class="spb">\par
    <div class="shop-section">\par
      <div class="shop-section-title">\f4\u-10179?\u-8494?\f2  \f0 BUY ITEMS</div>\par
      <div id="shop-buy-list"></div>\par
    </div>\par
    <div class="shop-section">\par
      <div class="shop-section-title">\f4\u-10179?\u-8986?\f2  \f0 EXPAND INVENTORY</div>\par
      <div id="shop-expand"></div>\par
    </div>\par
    <div style="font-size:7px;color:var(--gray);padding:6px;text-align:center;font-family:'VT323',monospace;font-size:13px">\par
\f2       \f4\u-10179?\u-9055?\f2  \f0 To sell items, open \f4\u-10180?\u-8302?\f2  \f0 ITEMS and tap any item \f5\u8594?\f2  \f0 SELL\par
    </div>\par
  </div>\par
</div>\par
\par
<!-- FUSION -->\par
<div class="spanel" id="panel-fuse">\par
  <div class="sph"><div class="spt">\f3\u9879?\u-497?\f2  \f0 ITEM FUSION</div><button class="spc" onclick="closeAllPanels()">\f1\u10005?\f0 </button></div>\par
  <div class="spb">\par
    <div style="font-size:7px;color:var(--gray);margin-bottom:10px;font-family:'VT323',monospace;font-size:14px;line-height:1.5">\par
      Combine 2 items of the same type & tier to forge a better one!<br>\par
      <span style="color:var(--purple)">Costs 50g per fusion.</span> Higher tiers = more powerful.\par
    </div>\par
    <div class="fusion-grid">\par
      <div class="fusion-slot" id="fs1" onclick="openFuseSelect(1)">\par
        <div class="fusion-slot-icon" id="fs1-icon">?</div>\par
        <div class="fusion-slot-name" id="fs1-name">Tap to pick</div>\par
      </div>\par
      <div class="fusion-arrow">\f3\u9879?\u-497?\f0 <br>+</div>\par
      <div class="fusion-slot" id="fs2" onclick="openFuseSelect(2)">\par
        <div class="fusion-slot-icon" id="fs2-icon">?</div>\par
        <div class="fusion-slot-name" id="fs2-name">Tap to pick</div>\par

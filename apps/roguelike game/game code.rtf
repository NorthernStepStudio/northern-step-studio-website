function makeItem(type, tier0, subIdx=0) \{\par
  // tier0 = 0-indexed (0=T1)\par
  let tbl, itype;\par
  if(type==='weapon')\{ tbl=WEAPON_TIERS; itype='weapon'; \}\par
  else if(type==='armor')\{ tbl=ARMOR_TIERS; itype='armor'; \}\par
  else \{ tbl=RING_TIERS; itype='ring'; \}\par
  const row=tbl[Math.min(tier0,tbl.length-1)];\par
  const base=row[subIdx%row.length];\par
  return \{...base, type:itype, tier:tier0+1, uid:Math.random().toString(36).slice(2)\};\par
\}\par

function loadSprite(ev)\{const f=ev.target.files[0];if(!f)return;const r=new FileReader();r.onload=e=>\{customSprite=e.target.result;if(G.player)\{rhS();renderMap();\}\};r.readAsDataURL(f);\}\par
function rhS()\{const el=document.getElementById('hsprite');if(customSprite)el.innerHTML=`<img src="$\{customSprite\}" style="width:28px;height:28px;object-fit:contain;image-rendering:pixelated">`;else el.textContent=G.player?.emoji||'\f3\u-10179?\u-8735?\u-497?\f0 ';\}\par
function updCS()\{const pw=document.getElementById('cpsprite');if(customSprite)pw.innerHTML=`<img src="$\{customSprite\}" style="width:56px;height:56px;object-fit:contain;image-rendering:pixelated">`;else pw.textContent=G.player?.emoji||'\f3\u-10179?\u-8735?\u-497?\f0 ';\}\par
\par
// \f1\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\f0\par
// SAVE / LOAD\par
// \f1\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\f0\par
function saveG()\{try\{localStorage.setItem(SK,JSON.stringify(\{G,customSprite,zoomLevel\}));\}catch(e)\{\}\}\par
function loadGame()\{try\{const d=JSON.parse(localStorage.getItem(SK));if(!d)return false;G=d.G;if(d.customSprite)customSprite=d.customSprite;if(d.zoomLevel!==undefined)zoomLevel=d.zoomLevel;showGS();updateVision(G.player.x,G.player.y);renderMap();updateHUD();updateDoomBar();updateModBar();addLog('\f4\u-10179?\u-9026?\f2  \f0 Loaded! Welcome back.','info');return true;\}catch(e)\{return false;\}\}\par
function checkSave()\{try\{return JSON.parse(localStorage.getItem(SK))?.G?.floor||null;\}catch(e)\{return null;\}\}\par
\par
// \f1\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\f0\par
// ENEMY SCALING (key fix!)\par
// \f1\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\f0\par
function scaleEnemy(tmpl, floor, playerLevel)\{\par
  const lvl = Math.max(1, Math.round((floor * 2 + playerLevel) / 2));\par
  let hpScale = 1 + (lvl - 1) * 0.35;\par
  let atkScale = 1 + (lvl - 1) * 0.28;\par
  const xpScale = 1 + (lvl - 1) * 0.2;\par
  const goldScale = 1 + (lvl - 1) * 0.15;\par
  let scaledDef = tmpl.def + Math.floor((lvl - 1) * 0.5);\par
\par
  // Corruption bonus: enemies get harder at high doom\par
  const doomLvl=getDoomLevel();\par
  const doomScale=1+(doomLvl*.08);\par
  hpScale*=doomScale; atkScale*=doomScale;\par
\par
  // Elite surge modifier\par
  const mods=getModEffects();\par
  let isElite=tmpl.elite||false;\par
  if(mods.eliteSurge)\{hpScale*=1.5;atkScale*=1.25;isElite=true;\}\par
\par
  const en=\{\par
    ...tmpl,\par
    hp: Math.floor(tmpl.baseHp * hpScale),\par
    maxHp: Math.floor(tmpl.baseHp * hpScale),\par
    atk: Math.floor(tmpl.baseAtk * atkScale),\par
    def: scaledDef,\par
    xp: Math.floor(tmpl.xp * xpScale),\par
    gold: Math.floor(tmpl.gold * goldScale),\par
    level: lvl,\par
    id: Math.random().toString(36).slice(2),\par
    poisoned: 0,\par
    status:\{\},\par
    isElite\par
  \};\par
  if(isElite)\{en.name=`\f1\u9733?\f2  \f0 $\{en.name\}`;en.elite=true;\}\par
  return en;\par
\}\par
\par
// \f1\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\f0\par
// MAP GEN\par
// \f1\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\f0\par
function generateMap()\{\par
  let map=Array.from(\{length:MH\},()=>Array(MW).fill('wall'));\par
  const rooms=[],nr=5+Math.min(G.floor,5);\par
  for(let a=0;a<200&&rooms.length<nr;a++)\{\par
    const w=4+Math.floor(Math.random()*5),h=3+Math.floor(Math.random()*4);\par
    const x=1+Math.floor(Math.random()*(MW-w-2)),y=1+Math.floor(Math.random()*(MH-h-2));\par
    if(rooms.some(r=>x<r.x+r.w+1&&x+w>r.x-1&&y<r.y+r.h+1&&y+h>r.y-1))continue;\par
    rooms.push(\{x,y,w,h\});\par
    for(let ry=y;ry<y+h;ry++)for(let rx=x;rx<x+w;rx++)map[ry][rx]='floor';\par
  \}\par
  for(let i=1;i<rooms.length;i++)\{\par
    const a=rooms[i-1],b=rooms[i];let cx=Math.floor(a.x+a.w/2),cy=Math.floor(a.y+a.h/2);\par
    const bx=Math.floor(b.x+b.w/2),by=Math.floor(b.y+b.h/2);\par
    while(cx!==bx)\{map[cy][cx]='floor';cx+=bx>cx?1:-1;\}\par
    while(cy!==by)\{map[cy][cx]='floor';cy+=by>cy?1:-1;\}\par
  \}\par
  G.map=\{cells:map.map(row=>row.map(t=>(\{type:t,visible:false,seen:false,entity:null\}))),rooms\};\par
\}\par
\par
function freeTile(rm,excluded)\{\par
  for(let a=0;a<80;a++)\{\par
    const tx=rm.x+Math.floor(Math.random()*rm.w);\par
    const ty=rm.y+Math.floor(Math.random()*rm.h);\par
    if(tx<1||ty<1||tx>=MW-1||ty>=MH-1)continue;\par
    if(G.map.cells[ty][tx].type!=='floor')continue;\par
    if(excluded.some(([ex,ey])=>ex===tx&&ey===ty))continue;\par
    return[tx,ty];\par
  \}\par
  return null;\par
\}\par
\par
function placeEntities()\{\par
  const rooms=G.map.rooms;G.enemies=[];G.items=[];\par
\par
  // Player starts in room 0\par
  const st=rooms[0];\par
  G.player.x=Math.floor(st.x+st.w/2);\par
  G.player.y=Math.floor(st.y+st.h/2);\par
\par
  // Stairs: hidden in a CORNER of the last room (not center), not marked on minimap until adjacent\par
  const ls=rooms[rooms.length-1];\par
  // Pick a random corner offset inside the room\par
  const corners=[\par
    [ls.x+1, ls.y+1],[ls.x+ls.w-2, ls.y+1],\par
    [ls.x+1, ls.y+ls.h-2],[ls.x+ls.w-2, ls.y+ls.h-2]\par
  ].filter(([cx,cy])=>cx>=0&&cy>=0&&cx<MW&&cy<MH&&G.map.cells[cy][cx].type==='floor');\par
  const [sx,sy] = corners.length ? corners[Math.floor(Math.random()*corners.length)] : [Math.floor(ls.x+ls.w/2),Math.floor(ls.y+ls.h/2)];\par
  G.map.cells[sy][sx].entity='stairs';\par
\par
  // Shop: random intermediate room center\par
  const shopRoomIdx = 1 + Math.floor(Math.random() * Math.max(1, rooms.length - 2));\par
  const shopRoom = rooms[shopRoomIdx];\par
  const shopX=Math.floor(shopRoom.x+shopRoom.w/2), shopY=Math.floor(shopRoom.y+shopRoom.h/2);\par
  if(!(shopX===sx&&shopY===sy)) G.map.cells[shopY][shopX].entity='shop';\par
\par
  // Blacksmith: place in another different room\par
  const usedRooms=new Set([0,shopRoomIdx,rooms.length-1]);\par
  let smithRoomIdx=-1;\par
  for(let r=1;r<rooms.length;r++)\{if(!usedRooms.has(r))\{smithRoomIdx=r;usedRooms.add(r);break;\}\}\par
  if(smithRoomIdx>=0)\{\par
    const sr=rooms[smithRoomIdx];\par
    const smithX=Math.floor(sr.x+sr.w/2)+1,smithY=Math.floor(sr.y+sr.h/2);\par
    if(smithX<MW&&smithY<MH&&G.map.cells[smithY][smithX].type==='floor'&&!(smithX===sx&&smithY===sy))\par
      G.map.cells[smithY][smithX].entity='blacksmith';\par
  \}\par
\par
  // Alchemist: another room (floor 2+, or same room as blacksmith if no space)\par
  if(G.floor>=2)\{\par
    let alchRoomIdx=-1;\par
    for(let r=1;r<rooms.length;r++)\{if(!usedRooms.has(r))\{alchRoomIdx=r;usedRooms.add(r);break;\}\}\par
    if(alchRoomIdx>=0)\{\par
      const ar=rooms[alchRoomIdx];\par
      const alchX=Math.floor(ar.x+ar.w/2),alchY=Math.floor(ar.y+ar.h/2)+1;\par
      if(alchX<MW&&alchY<MH&&G.map.cells[alchY][alchX].type==='floor'&&!(alchX===sx&&alchY===sy))\par
        G.map.cells[alchY][alchX].entity='alchemist';\par
    \}\par
  \}\par
\par
  const pool=ENEMIES.filter(e=>e.floor<=G.floor);\par
  const floorTier=Math.min(4,Math.floor((G.floor-1)/1.2));\par
\par
  for(let i=1;i<rooms.length;i++)\{\par
    const rm=rooms[i];\par
    const num=1+Math.floor(Math.random()*3);\par
    for(let e=0;e<num;e++)\{\par
      const occ=[[G.player.x,G.player.y],...G.enemies.map(en=>[en.x,en.y]),...G.items.map(it=>[it.x,it.y])];\par
      const pos=freeTile(rm,occ);\par
      if(!pos)continue;\par
      const[ex,ey]=pos;\par
      const tmpl=(G.floor===5&&i===rooms.length-1&&e===0)?ENEMIES[ENEMIES.length-1]:pool[Math.floor(Math.random()*pool.length)];\par
      const enemy=scaleEnemy(tmpl,G.floor,G.player.level);\par
      enemy.x=ex;enemy.y=ey;\par
      G.enemies.push(enemy);\par
    \}\par
    if(Math.random()<.6)\{\par
      const occ=[[G.player.x,G.player.y],...G.enemies.map(en=>[en.x,en.y]),...G.items.map(it=>[it.x,it.y])];\par
      const pos=freeTile(rm,occ);\par
      if(!pos)continue;\par
      const[ix,iy]=pos;\par
      const roll=Math.random();let it;\par
      if(roll<.25)it=\{...CONSUMABLES[0],uid:Math.random().toString(36).slice(2)\};\par
      else if(roll<.38)it=\{...CONSUMABLES[2],uid:Math.random().toString(36).slice(2)\};\par
      else if(roll<.58)it=makeItem('weapon',floorTier,Math.floor(Math.random()*4));\par
      else if(roll<.74)it=makeItem('armor',floorTier,0);\par
      else if(roll<.88)it=makeItem('ring',Math.min(floorTier,4),0);\par
      else it=\{...CONSUMABLES[4],uid:Math.random().toString(36).slice(2)\};\par
      it.x=ix;it.y=iy;\par
      G.items.push(it);\par
    \}\par
  \}\par
\}\par
\par
// \f1\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\f0\par
// VISION\par
// \f1\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\f0\par
function updateVision(px,py)\{\par
  const r=5;\par
  for(let y=0;y<MH;y++)for(let x=0;x<MW;x++)G.map.cells[y][x].visible=false;\par
  for(let dy=-r;dy<=r;dy++)for(let dx=-r;dx<=r;dx++)\{\par
    if(dx*dx+dy*dy>r*r)continue;\par
    const nx=px+dx,ny=py+dy;\par
    if(nx<0||ny<0||nx>=MW||ny>=MH)continue;\par
    G.map.cells[ny][nx].visible=true;G.map.cells[ny][nx].seen=true;\par
  \}\par
  // Reveal stairs on minimap only when player is within 2 tiles\par
  for(let y=0;y<MH;y++)for(let x=0;x<MW;x++)\{\par
    if(G.map.cells[y][x].entity==='stairs')\{\par
      const dist=Math.abs(x-px)+Math.abs(y-py);\par
      if(dist<=2) G.map.cells[y][x].stairsRevealed=true;\par
    \}\par
  \}\par
\}\par
\par
// \f1\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\f0\par
// RENDER \f2\emdash  scrollable, zoom-based\par
// \f1\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\f0\par
function renderMap()\{\par
  const p=G.player,cs=getCellSize();\par
  const el=document.getElementById('dungeon-map');\par
  const fs=Math.max(8,cs-4);\par
  el.style.gridTemplateColumns=`repeat($\{MW\},$\{cs\}px)`;\par
  el.style.gridTemplateRows=`repeat($\{MH\},$\{cs\}px)`;\par
  el.innerHTML='';\par
\par
  for(let y=0;y<MH;y++)for(let x=0;x<MW;x++)\{\par
    const cell=G.map.cells[y][x],div=document.createElement('div');\par
    div.className='cell';div.style.width=cs+'px';div.style.height=cs+'px';\par
    if(!cell.seen)\{div.classList.add('fog');\}\par
    else if(cell.type==='wall')\{div.classList.add('wall');if(cell.visible)div.innerHTML=`<span class="ce" style="font-size:$\{fs\}px">\f3\u-10178?\u-8719?\f0 </span>`;\}\par
    else\{\par
      div.classList.add('floor');if(!cell.visible)div.classList.add('seen');\par
      if(cell.visible)\{\par
        const en=G.enemies.find(e=>e.x===x&&e.y===y),it=G.items.find(i=>i.x===x&&i.y===y);\par
        if(x===p.x&&y===p.y)\{\par
          if(customSprite)div.innerHTML=`<img class="pmap" src="$\{customSprite\}" style="width:$\{cs-2\}px;height:$\{cs-2\}px">`;\par
          else div.innerHTML=`<span class="ce idle" style="font-size:$\{fs\}px">$\{p.emoji\}</span>`;\par
        \}else if(en)\{\par
          div.innerHTML=`<span class="ce bob" style="font-size:$\{fs\}px">$\{en.emoji\}</span>`;\par
          div.style.cursor='pointer';div.title=`$\{en.name\} LV$\{en.level\} HP:$\{en.hp\}`;div.onclick=()=>startCombat(en);\par
          // Show level dot for visible enemies\par
          if(cs>=20)\{const lvBadge=document.createElement('div');lvBadge.style.cssText=`position:absolute;bottom:0;right:0;font-size:$\{Math.max(5,cs/5)\}px;color:#ff88ff;font-family:'Press Start 2P',monospace;line-height:1;`;lvBadge.textContent=en.level;div.appendChild(lvBadge);\}\par
        \}else if(cell.entity==='stairs')\{\par
          div.innerHTML=`<span class="ce" style="font-size:$\{fs\}px">\f3\u11015?\u-497?\f0 </span>`;\par
          div.style.cursor='pointer';div.onclick=descend;div.title='Stairs';\par
        \}else if(cell.entity==='shop')\{\par
          div.innerHTML=`<span class="ce" style="font-size:$\{fs\}px;display:inline-block;animation:bob 1s ease-in-out infinite">\f4\u-10180?\u-8214?\f0 </span>`;\par
          div.style.cursor='pointer';\par
          div.title='Shop';\par
          div.onclick=()=>\{\par
            if(x===p.x&&y===p.y)togglePanel('shop');\par
            else addLog('\f4\u-10180?\u-8214?\f2  \f0 Walk to the shop to enter!','info');\par
          \};\par
        \}else if(cell.entity==='blacksmith')\{\par
          div.innerHTML=`<span class="ce" style="font-size:$\{fs\}px;display:inline-block;animation:bob 1.2s ease-in-out infinite">\f4\u-10179?\u-8920?\f0 </span>`;\par
          div.style.cursor='pointer';div.title='Blacksmith';\par
          div.onclick=()=>\{\par
            if(x===p.x&&y===p.y)togglePanel('blacksmith');\par
            else addLog('\f4\u-10179?\u-8920?\f2  \f0 Walk to the Blacksmith to craft!','info');\par
          \};\par
        \}else if(cell.entity==='alchemist')\{\par
          div.innerHTML=`<span class="ce" style="font-size:$\{fs\}px;display:inline-block;animation:bob 1.4s ease-in-out infinite">\f3\u9879?\u-497?\f0 </span>`;\par
          div.style.cursor='pointer';div.title='Alchemist';\par
          div.onclick=()=>\{\par
            if(x===p.x&&y===p.y)togglePanel('alchemist');\par
            else addLog('\f3\u9879?\u-497?\f2  \f0 Walk to the Alchemist to brew!','info');\par
          \};\par
        \}else if(it)\{\par
          div.innerHTML=`<span class="ce" style="font-size:$\{fs\}px">$\{it.emoji\}</span>`;\par
          div.style.cursor='pointer';div.title=it.name;div.onclick=()=>pickupItem(it);\par
        \}else div.innerHTML=`<span style="font-size:6px;opacity:.04">\'b7</span>`;\par
      \}\par
    \}\par
    el.appendChild(div);\par
  \}\par
\par
  // Center map on player\par
  const wrap=document.getElementById('map-wrap');\par
  const ww=wrap.clientWidth,wh=wrap.clientHeight;\par
  const mapW=MW*cs,mapH=MH*cs;\par
  const px_screen=p.x*cs+cs/2,py_screen=p.y*cs+cs/2;\par
  let ox=ww/2-px_screen, oy=wh/2-py_screen;\par
  ox=Math.min(0,Math.max(ww-mapW,ox));\par
  oy=Math.min(0,Math.max(wh-mapH,oy));\par
  el.style.left=ox+'px'; el.style.top=oy+'px';\par
\par
  renderMM();\par
\}\par
\par
function renderMM()\{\par
  const p=G.player,mm=document.getElementById('minimap');\par
  mm.style.gridTemplateColumns=`repeat($\{MW\},4px)`;mm.innerHTML='';\par
  for(let y=0;y<MH;y++)for(let x=0;x<MW;x++)\{\par
    const cell=G.map.cells[y][x],d=document.createElement('div');d.className='mc';\par
    if(!cell.seen)d.classList.add('mg');\par
    else if(cell.type==='wall')d.classList.add('mw');\par
    else if(x===p.x&&y===p.y)d.classList.add('mp');\par
    else if(G.enemies.find(e=>e.x===x&&e.y===y))d.classList.add('me');\par
    else if(G.items.find(i=>i.x===x&&i.y===y))d.classList.add('mi');\par
    else if(cell.entity==='stairs'&&cell.stairsRevealed)d.classList.add('ms');\par
    else if(cell.entity==='shop')d.classList.add('msh');\par
    else if(cell.entity==='blacksmith')d.classList.add('msm');\par
    else if(cell.entity==='alchemist')d.classList.add('mal');\par
    else d.classList.add('mf');\par
    mm.appendChild(d);\par
  \}\par
\}\par
\par
function cntPot(t)\{return G.inventory.filter(i=>t==='hp'?i.isHp:i.isMp).length;\}\par
\par
function updateHUD()\{\par
  const p=G.player;\par
  rhS();\par
  document.getElementById('hname').textContent=p.className;\par
  document.getElementById('hlvl').textContent=`LV.$\{p.level\}`;\par
  document.getElementById('bhp').style.width=`$\{(p.hp/p.maxHp)*100\}%`;\par
  document.getElementById('thp').textContent=`$\{p.hp\}/$\{p.maxHp\}`;\par
  document.getElementById('bmp').style.width=`$\{(p.mp/p.maxMp)*100\}%`;\par
  document.getElementById('tmp').textContent=`$\{p.mp\}/$\{p.maxMp\}`;\par
  document.getElementById('hfl').textContent=`\f1\u11015?\f0 F$\{G.floor\}`;\par
  document.getElementById('hgo').textContent=`\f4\u-10179?\u-9040?\f0 $\{p.gold\}`;\par
  document.getElementById('hki').textContent=`\f4\u-10179?\u-9088?\f0 $\{G.kills\}`;\par
  document.getElementById('xp-fill').style.width=`$\{(p.xp/(p.level*100))*100\}%`;\par
  // Doom shards badge\par
  const meta=loadMeta();\par
  const dsEl=document.getElementById('hds');\par
  if(dsEl&&meta.shards>0)\{dsEl.style.display='block';dsEl.textContent=`\f4\u-10179?\u-9056?\f0 $\{meta.shards\}`;\}\par
  else if(dsEl)dsEl.style.display='none';\par
  const hc=cntPot('hp'),mc=cntPot('mp');\par
  document.getElementById('qshpc').textContent=hc;\par
  document.getElementById('qsmpc').textContent=mc;\par
  document.getElementById('qshp').classList.toggle('qs-empty',hc===0);\par
  document.getElementById('qsmp').classList.toggle('qs-empty',mc===0);\par
  document.getElementById('qswpn').textContent=G.equippedWeapon?`$\{G.equippedWeapon.emoji\} $\{G.equippedWeapon.name\}`:'\f2\emdash  No weapon';\par
  document.getElementById('qsatk').textContent=`ATK:$\{p.atk\}`;\par
  updateDoomBar();updateModBar();\par
  rInv();rStats();\par
  document.getElementById('inv-count').textContent=G.inventory.length;\par
  document.getElementById('inv-max').textContent=G.maxInvSlots;\par
\}\par
\par
function tierLabel(t)\{return`<span class="$\{'tier-'+t\}">[$\{TIER_NAMES[t]||'T'+t\}]</span>`;\}\par
\par
function rInv()\{\par
  const g=document.getElementById('inv-grid');g.innerHTML='';\par
  // Only show non-material items in the main grid\par
  const gear=G.inventory.filter(it=>it.type!=='material');\par
  const freeSlots=G.maxInvSlots-gear.length;\par
  for(let i=0;i<G.maxInvSlots;i++)\{\par
    const sl=document.createElement('div');sl.className='isl';\par
    const it=gear[i];\par
    if(it)\{\par
      sl.innerHTML=it.emoji;\par
      if(it.tier)\{const lvEl=document.createElement('span');lvEl.className='isl-tier '+('tier-'+(it.tier||1));lvEl.textContent='T'+(it.tier||1);sl.appendChild(lvEl);\}\par
      sl.title=it.name+(it.tier?' [T'+it.tier+']':'');\par
      if(it===G.equippedWeapon||it===G.equippedArmor||it===G.equippedRing)sl.classList.add('equipped');\par
      sl.onclick=()=>showIP(it);\par
    \}else\{sl.classList.add('empty');sl.textContent='\f0\'b7';\}\par
    g.appendChild(sl);\par
  \}\par
  document.getElementById('eqw').textContent=G.equippedWeapon?`$\{G.equippedWeapon.emoji\} $\{G.equippedWeapon.name\} [T$\{G.equippedWeapon.tier||1\}]`:'\f2\emdash  bare hands';\par
  document.getElementById('eqa').textContent=G.equippedArmor?`$\{G.equippedArmor.emoji\} $\{G.equippedArmor.name\} [T$\{G.equippedArmor.tier||1\}]`:'\emdash  nothing';\par
  document.getElementById('eqr').textContent=G.equippedRing?`$\{G.equippedRing.emoji\} $\{G.equippedRing.name\}`:'\emdash  none';\par
  // Materials summary\par
  const mg=document.getElementById('mat-grid');if(!mg)return;\par
  const mats=G.inventory.filter(it=>it.type==='material');\par
  if(!mats.length)\{mg.innerHTML='<div style="font-family:\\'VT323\\',monospace;font-size:13px;color:var(--gray)">None yet. Kill enemies to find materials!</div>';return;\}\par
  // Count by id\par
  const counts=\{\};mats.forEach(m=>\{counts[m.id]=(counts[m.id]||0)+1;\});\par
  mg.innerHTML=Object.entries(counts).map(([id,qty])=>\{\par
    const m=MATERIALS[id]||\{emoji:'?',name:id\};\par
    return`<div class="mat-tag mat-ok" style="cursor:pointer;padding:3px 7px" onclick="showMatInfo('$\{id\}')" title="$\{m.name\}: $\{m.desc||''\}">$\{m.emoji\} $\{m.name\} \f0\'d7$\{qty\}</div>`;\par
  \}).join('');\par
\}\par
\par
function showMatInfo(id)\{\par
  const m=MATERIALS[id];if(!m)return;\par
  const qty=countMat(id);\par
  addLog(`\f3\u-10178?\u-8536?\f2  \f0 $\{m.emoji\} $\{m.name\} \'d7$\{qty\} \f2\emdash  $\{m.desc\} [Rarity $\{'\f1\u9733?\f0 '.repeat(m.rarity)\}]`,'info');\par
\}\par
\par
function rStats()\{\par
  const p=G.player;\par
  document.getElementById('sgrid').innerHTML=[\par
    ['\f3\u10084?\u-497?\f2  \f0 HP',`$\{p.hp\}/$\{p.maxHp\}`],['\f1\u10024?\f2  \f0 MP',`$\{p.mp\}/$\{p.maxMp\}`],\par
    ['\f3\u9876?\u-497?\f2  \f0 ATK',p.atk],['\f3\u-10179?\u-8479?\u-497?\f2  \f0 DEF',p.def],['\f4\u-10179?\u-9048?\f2  \f0 SPD',p.spd],['\f4\u-10180?\u-8273?\f2  \f0 CRIT',`$\{p.crit\}%`],\par
    ['\f4\u-10179?\u-9040?\f2  \f0 GOLD',p.gold+'g'],['\f4\u-10179?\u-9088?\f2  \f0 KILLS',G.kills],['\f3\u-10180?\u-8230?\u-497?\f2  \f0 FLOOR',G.floor],['\f1\u11088?\f2  \f0 LVL',p.level],\par
    ['\f3\u9760?\u-497?\f2  \f0 CORRUPTION',`$\{G.corruption||0\}%`],['\f4\u-10179?\u-8908?\f2  \f0 DOOM LVL',getDoomLevel()],\par
    ['\f3\u-10178?\u-8726?\f2  \f0 HP Pots',cntPot('hp')],['\f4\u-10179?\u-9049?\f2  \f0 MP Pots',cntPot('mp')],\par
    ['\f4\u-10180?\u-8302?\f2  \f0 Inventory',`$\{G.inventory.length\}/$\{G.maxInvSlots\}`],['\f4\u-10179?\u-9088?\f2  \f0 Enemy Lvl',`~$\{Math.max(1,Math.round((G.floor*2+p.level)/2))\}`],\par
  ].map(([k,v])=>`<div class="sgi"><span class="sgk">$\{k\}</span><span class="sgv">$\{v\}</span></div>`).join('');\par
  const pl=document.getElementById('plst');\par
  let extra='';\par
  if((G.activeModifiers||[]).length)\{\par
    extra+='<div style="font-size:7px;color:#ff2266;margin:8px 0 4px">ACTIVE MODIFIERS:</div>';\par
    extra+=(G.activeModifiers||[]).map(id=>\{const m=ALL_MODIFIERS.find(x=>x.id===id);return m?`<span class="mod-badge $\{m.positive?'positive':''\}">$\{m.emoji\} $\{m.name\}</span>`:''\}).join('');\par
  \}\par
  pl.innerHTML=(G.perkList.length?'<div style="font-size:7px;color:var(--gray);margin:8px 0 4px">PERKS:</div>'+G.perkList.map(n=>`<span class="ptag">$\{n\}</span>`).join(''):'<div style="font-size:7px;color:var(--gray);margin-top:8px">No perks yet.</div>')+extra;\par
\}\par
\par
// \f1\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\f0\par
// SHOP\par
// \f1\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\f0\par
function generateShopStock()\{\par
  const p=G.player,fl=G.floor;\par
  const tier=Math.min(4,Math.floor((fl-1)/1.2)+Math.floor((p.level-1)/3));\par
  const stock=[];\par
  // Weapons\par
  stock.push(\{...rollAffix(makeItem('weapon',tier,Math.floor(Math.random()*4))), shopCost:null\});\par
  stock.push(\{...rollAffix(makeItem('weapon',Math.max(0,tier-1),Math.floor(Math.random()*4))), shopCost:null\});\par
  // Armor\par
  stock.push(\{...rollAffix(makeItem('armor',tier,0)), shopCost:null\});\par
  // Ring\par
  stock.push(\{...rollAffix(makeItem('ring',Math.min(tier,4),0)), shopCost:null\});\par
  // Consumables\par
  stock.push(\{...CONSUMABLES[0],uid:Math.random().toString(36).slice(2),shopCost:null\}); // hp pot\par
  stock.push(\{...CONSUMABLES[2],uid:Math.random().toString(36).slice(2),shopCost:null\}); // mp pot\par
  stock.push(\{...CONSUMABLES[4],uid:Math.random().toString(36).slice(2),shopCost:null\}); // bomb\par
  // Common crafting materials (buyable from shop)\par
  const shopMats=['iron_ore','iron_bar','leather','wood_shard','bone_shard','mushroom'];\par
  const floorMats=fl>=2?['steel_bar','magic_dust','beast_fang','firebloom']:[];\par
  const rareMats=fl>=3?['rune_stone','shadow_silk','void_shard','moonpetal','chaos_gem']:[];\par
  const matPool=[...shopMats,...floorMats,...rareMats];\par
  const picked=matPool.sort(()=>Math.random()-.5).slice(0,4);\par
  picked.forEach(mid=>\{\par
    const m=makeMaterial(mid);\par
    if(m)\{m.shopCost=Math.ceil(m.value*1.8);stock.push(m);\}\par
  \});\par
  // Set costs = 1.3x item value\par
  stock.forEach(it=>\{it.shopCost=Math.ceil((it.value||30)*1.3/5)*5;\});\par
  return stock;\par
\}\par
\par
function openShop()\{\par
  if(!G.shopStock||G.shopStock.length===0) G.shopStock=generateShopStock();\par
  const mods=getModEffects();\par
  const priceMult=mods.shopMult||1;\par
  document.getElementById('shop-gold-disp').textContent=`\f4\u-10179?\u-9040?\f2  \f0 $\{G.player.gold\}g`;\par
  const buyList=document.getElementById('shop-buy-list');\par
  buyList.innerHTML='';\par
\par
  // Reroll button\par
  if(G.shopRerollsLeft>0||G.player.gold>=50)\{\par
    const rerollCost=G.shopRerollsLeft>0?'FREE':50+'g';\par
    const rBtn=document.createElement('div');\par
    rBtn.style.cssText='margin-bottom:8px;';\par
    rBtn.innerHTML=`<button onclick="rerollShop()" style="background:#0d0d1a;border:2px solid var(--cyan);color:var(--cyan);font-family:'Press Start 2P',monospace;font-size:7px;padding:7px 14px;cursor:pointer;width:100%;border-radius:4px;">\f4\u-10179?\u-8959?\f2  \f0 REROLL STOCK ($\{rerollCost\}) $\{G.shopRerollsLeft>0?'[FREE REROLL AVAILABLE]':''\}</button>`;\par
    buyList.appendChild(rBtn);\par
  \}\par
\par
  // Modifier warning\par
  if(priceMult>1)\{\par
    buyList.innerHTML+=`<div style="background:#1a0808;border:2px solid #660000;border-radius:4px;padding:6px 8px;margin-bottom:8px;font-family:'VT323',monospace;font-size:14px;color:#ff8888;">\f4\u-10179?\u-9032?\f2  \f0 GREEDY SHOPS active \f2\emdash  prices +$\{Math.round((priceMult-1)*100)\}%!</div>`;\par
  \}\par
\par
  G.shopStock.forEach((it,idx)=>\{\par
    const adjustedCost=Math.ceil((it.shopCost||30)*priceMult/5)*5;\par
    const canAfford=G.player.gold>=adjustedCost;\par
    const div=document.createElement('div');\par
    div.className='shop-item';\par
    const affixBadge=it.affixName?`<span class="affix-tag $\{it.affixClass||''\}">$\{it.affixEmoji||'\f1\u10022?\f0 '\} $\{it.affixName\}</span>`:'';\par
    div.innerHTML=`<div class="shop-emoji">$\{it.emoji\}</div>\par
      <div class="shop-info">\par
        <div class="shop-name">$\{it.name\}$\{it.tier?' <span class="tier-'+it.tier+'">[T'+it.tier+']</span>':''\} $\{affixBadge\}</div>\par
        <div class="shop-desc">$\{fmtSt(it)||it.desc||''\}</div>\par
      </div>\par
      <div class="shop-cost $\{canAfford?'':'cant-afford'\}">$\{adjustedCost\}g</div>`;\par
    div.onclick=()=>buyItem(idx,adjustedCost);\par
    buyList.appendChild(div);\par
  \});\par
\par
  // Expand inventory\par
  const expandEl=document.getElementById('shop-expand');\par
  expandEl.innerHTML='';\par
  const currentSlots=G.maxInvSlots;\par
  if(currentSlots<16)\{\par
    const cost=currentSlots*60;\par
    const canAfford=G.player.gold>=cost;\par
    expandEl.innerHTML=`\par
      <div class="inv-slots-display">Current: $\{currentSlots\} slots \f5\u8594?\f2  \f0 $\{currentSlots+2\} slots</div>\par
      <div class="shop-item shop-upgrade" onclick="buyInventoryExpand()">\par
        <div class="shop-emoji">\f4\u-10180?\u-8302?\f0 </div>\par
        <div class="shop-info"><div class="shop-name">+2 Inventory Slots</div><div class="shop-desc">More room for more junk!</div></div>\par
        <div class="shop-cost $\{canAfford?'':'cant-afford'\}">$\{cost\}g</div>\par
      </div>`;\par
  \}else\{\par
    expandEl.innerHTML=`<div class="inv-slots-display" style="color:var(--gold)">MAX SLOTS (16) \f2\emdash  You're a hoarder.</div>`;\par
  \}\par
\}\par
\par
function rerollShop()\{\par
  if(G.shopRerollsLeft>0)\{G.shopRerollsLeft--;G.shopStock=[];\}\par
  else if(G.player.gold>=50)\{G.player.gold-=50;G.shopStock=[];\}\par
  else\{addLog('Need 50g to reroll shop!','damage');return;\}\par
  addLog('\f4\u-10179?\u-8959?\f2  \f0 Shop restocked!','shop');\par
  openShop();updateHUD();saveG();\par
\}\par
\par
function buyItem(idx,overrideCost)\{\par
  const it=G.shopStock[idx];if(!it)return;\par
  const cost=overrideCost||it.shopCost;\par
  if(G.player.gold<cost)\{addLog(`Not enough gold! Need $\{cost\}g`,'damage');return;\}\par
  if(G.inventory.length>=G.maxInvSlots)\{addLog('Inventory full! Sell or drop something first.','damage');return;\}\par
  G.player.gold-=cost;\par
  G.inventory.push(\{...it,uid:Math.random().toString(36).slice(2)\});\par
  G.shopStock.splice(idx,1);\par
  addLog(`\f4\u-10179?\u-8494?\f2  \f0 Bought $\{it.emoji\} $\{it.name\} for $\{cost\}g`,'shop');\par
  sfx('rgba(255,215,0,.2)',200);\par
  updateHUD();openShop();saveG();\par
\}\par
\par
function buyInventoryExpand()\{\par
  const cost=G.maxInvSlots*60;\par
  if(G.player.gold<cost)\{addLog(`Not enough gold! Need $\{cost\}g`,'damage');return;\}\par
  G.player.gold-=cost;G.maxInvSlots+=2;\par
  addLog(`\f4\u-10180?\u-8302?\f2  \f0 Inventory expanded to $\{G.maxInvSlots\} slots!`,'shop');\par
  sfx('rgba(68,255,136,.2)',200);\par
  updateHUD();openShop();saveG();\par
\}\par
\par
function sellItem(it)\{\par
  if(it===G.equippedWeapon||it===G.equippedArmor||it===G.equippedRing)\{\par
    addLog('Unequip it first before selling!','info');return;\par
  \}\par
  const price=Math.floor((it.value||20)*.5);\par
  G.player.gold+=price;\par
  G.inventory.splice(G.inventory.indexOf(it),1);\par
  addLog(`\f4\u-10179?\u-9032?\f2  \f0 Sold $\{it.emoji\} $\{it.name\} for $\{price\}g`,'shop');\par
  spPt(window.innerWidth*.5,window.innerHeight*.6,'#ffd700',8,\{speed:3,spread:4,grav:.1,decay:.05,ch:'\f4\u-10179?\u-9040?\f0 '\});\par
  updateHUD();openShop();saveG();\par
\}\par
\par
// \f1\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\f0\par
// FUSION\par
// \f1\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\f0\par
function openFuseSelect(slotNum)\{\par
  fuseSelectTarget=slotNum;\par
  const grid=document.getElementById('fuse-select-grid');grid.innerHTML='';\par
  const fusable=G.inventory.filter(it=>['weapon','armor','ring','hp_pot','mp_pot'].includes(it.type));\par
  if(fusable.length===0)\{grid.innerHTML='<div style="font-size:7px;color:var(--gray);padding:12px">No fusable items in inventory.</div>';\par
  \}else\{\par
    fusable.forEach(it=>\{\par
      const d=document.createElement('div');d.className='isl';\par
      d.innerHTML=it.emoji;d.title=it.name+(it.tier?' T'+it.tier:'');\par
      if(it.tier)\{const t=document.createElement('span');t.className='isl-tier tier-'+(it.tier||1);t.textContent='T'+(it.tier||1);d.appendChild(t);\}\par
      d.onclick=()=>\{setFuseSlot(slotNum,it);closeFuseSelect();\};\par
      grid.appendChild(d);\par
    \});\par
  \}\par
  document.getElementById('fuse-select').style.display='flex';\par
\}\par
function closeFuseSelect()\{document.getElementById('fuse-select').style.display='none';\}\par
\par
function setFuseSlot(n,it)\{\par
  fuseSlot[n-1]=it;\par
  const icon=document.getElementById('fs'+n+'-icon');const name=document.getElementById('fs'+n+'-name');\par
  const sl=document.getElementById('fs'+n);\par
  icon.textContent=it.emoji;name.textContent=it.name+(it.tier?' [T'+it.tier+']':'');\par
  sl.classList.add('filled');\par
  checkFusionResult();\par
\}\par
\par
function checkFusionResult()\{\par
  const [a,b]=fuseSlot;\par
  const res=document.getElementById('fusion-result');\par
  const btn=document.getElementById('fusion-btn');\par
  if(!a||!b)\{res.innerHTML='<div style="font-size:8px;color:var(--gray)">Select 2 compatible items</div>';res.className='fusion-result';btn.disabled=true;return;\}\par
  const result=getFusionResult(a,b);\par
  const mods=getModEffects();\par
  const fusionCost=mods.fusionTax?100:50;\par
  const fusionLabel=mods.fusionTax?`FUSE ($\{fusionCost\}g) [TAX]`:`FUSE ($\{fusionCost\}g)`;\par
  if(!result)\{\par
    res.innerHTML=`<div style="font-size:7px;color:var(--red)">\f1\u10060?\f2  \f0 Incompatible! Need same type + same tier.</div>`;\par
    res.className='fusion-result';btn.disabled=true;\par
  \}else\{\par
    const affordable=G.player.gold>=fusionCost;\par
    res.className='fusion-result ready';\par
    res.innerHTML=`<div style="font-size:9px;color:var(--gold);margin-bottom:4px">$\{result.emoji\} $\{result.name\}</div>\par
      <div style="font-size:7px;color:var(--cyan)">$\{fmtSt(result)||'Upgraded!'\}</div>\par
      $\{result.tier?`<div class="tier-$\{result.tier\}" style="font-size:7px;margin-top:4px">[T$\{result.tier\} \f2\emdash  $\{TIER_NAMES[result.tier]||''\}]</div>`:''\}\par
      $\{mods.fusionTax?'<div style="font-size:7px;color:#ff8844;margin-top:4px">\f3\u9879?\u-497?\f2  \f0 Fusion Tax active! 20% chance: +1 bonus tier!</div>':''\}`;\par
    btn.disabled=!affordable;\par
    btn.textContent=affordable?`\f3\u9879?\u-497?\f2  \f0 $\{fusionLabel\}`:`\f3\u9879?\u-497?\f2  \f0 FUSE (need $\{fusionCost\}g)`;\par
  \}\par
\}\par
\par
function getFusionResult(a,b)\{\par
  if(!a||!b)return null;\par
  // Must be same item category\par
  const sameType=(a.type===b.type)||\par
    (a.isHp&&b.isHp)||(a.isMp&&b.isMp);\par
  if(!sameType)return null;\par
  if(a===b)return null; // can't fuse with itself\par
\par
  // Potions\par
  if(a.isHp&&b.isHp)return\{...CONSUMABLES[1],uid:Math.random().toString(36).slice(2),fusedFrom:true\};\par
  if(a.isMp&&b.isMp)return\{...CONSUMABLES[3],uid:Math.random().toString(36).slice(2),fusedFrom:true\};\par
\par
  // Equipment: must be same tier\par
  const tierA=a.tier||1,tierB=b.tier||1;\par
  if(tierA!==tierB)return null;\par
  const newTier=Math.min(5,tierA+1);\par
\par
  if(a.type==='weapon'&&b.type==='weapon')\{\par
    const result=makeItem('weapon',newTier-1,Math.floor(Math.random()*4));\par
    return result;\par
  \}\par
  if(a.type==='armor'&&b.type==='armor')\{\par
    return makeItem('armor',newTier-1,0);\par
  \}\par
  if(a.type==='ring'&&b.type==='ring')\{\par
    return makeItem('ring',newTier-1,0);\par
  \}\par
  return null;\par
\}\par
\par
function doFusion()\{\par
  const [a,b]=fuseSlot;\par
  if(!a||!b)return;\par
  let result=getFusionResult(a,b);\par
  if(!result)return;\par
  const mods=getModEffects();\par
  const fusionCost=mods.fusionTax?100:50;\par
  if(G.player.gold<fusionCost)\{addLog(`Need $\{fusionCost\}g to fuse!`,'damage');return;\}\par
  if(G.inventory.length-2+1>G.maxInvSlots)\{addLog('Not enough inventory space for result!','damage');return;\}\par
  G.player.gold-=fusionCost;\par
  G.fusionCount=(G.fusionCount||0)+1;\par
  // Fusion Tax modifier: 20% chance +1 extra tier\par
  if(mods.fusionTax&&Math.random()<.20&&result.tier)\{\par
    result=\{...result,tier:Math.min(5,result.tier+1),uid:Math.random().toString(36).slice(2)\};\par
    addLog('\f3\u9879?\u-497?\f2  \f0 FUSION TAX MIRACLE! Bonus tier!','loot');\par
  \}\par
  // Remove source items\par
  [a,b].forEach(it=>\{\par
    const idx=G.inventory.indexOf(it);if(idx>=0)G.inventory.splice(idx,1);\par
    if(it===G.equippedWeapon)\{G.equippedWeapon=null;G.player.atk-=it.effect?.atk||0;\}\par
    if(it===G.equippedArmor)\{G.equippedArmor=null;G.player.def-=it.effect?.def||0;\}\par
    if(it===G.equippedRing)\{G.equippedRing=null;\}\par
  \});\par
  G.inventory.push(result);\par
  fuseSlot=[null,null];\par
  ['1','2'].forEach(n=>\{\par
    document.getElementById('fs'+n+'-icon').textContent='?';\par
    document.getElementById('fs'+n+'-name').textContent='Tap to pick';\par
    document.getElementById('fs'+n).classList.remove('filled');\par
  \});\par
  document.getElementById('fusion-result').innerHTML='<div style="font-size:8px;color:var(--gray)">Select 2 compatible items</div>';\par
  document.getElementById('fusion-result').className='fusion-result';\par
  document.getElementById('fusion-btn').disabled=true;\par
\par
  addLog(`\f3\u9879?\u-497?\f2  \f0 Fused into: $\{result.emoji\} $\{result.name\}$\{result.tier?' [T'+result.tier+']':''\}!`,'loot');\par
  sfx('rgba(170,68,255,.4)',400);\par
  spPt(window.innerWidth*.5,window.innerHeight*.5,'#aa44ff',20,\{speed:5,spread:5,grav:0,decay:.04\});\par
  spRi(window.innerWidth*.5,window.innerHeight*.5,'#aa44ff');\par
  updateHUD();openFusePanel();saveG();\par
\}\par
\par
function openFusePanel()\{\par
  checkFusionResult();\par
\}\par
\par
// \f1\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\f0\par
// PANELS\par
// \f1\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\f0\par
function togglePanel(n)\{\par
  if(openPanel===n)\{closeAllPanels();return;\}\par
  closeAllPanels(true);\par
  document.getElementById('panel-'+n).classList.add('open');\par
  document.getElementById('bkdrop').classList.add('on');\par
  openPanel=n;\par
  if(n==='shop')openShop();\par
  if(n==='fuse')openFusePanel();\par
  if(n==='blacksmith')openBlacksmith();\par
  if(n==='alchemist')openAlchemist();\par
  if(n==='doom')openDoomPanel();\par
  if(n==='log')setTimeout(()=>\{const l=document.getElementById('log-list');l.scrollTop=l.scrollHeight;\},50);\par
\}\par
function closeAllPanels()\{\par
  ['inv','shop','fuse','stats','log','menu','blacksmith','alchemist','doom'].forEach(n=>document.getElementById('panel-'+n).classList.remove('open'));\par
  document.getElementById('bkdrop').classList.remove('on');\par
  openPanel=null;\par
\}\par
\par
// \f1\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\f0\par
// QUICKUSE\par
// \f1\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\f0\par
function quickUse(t)\{\par
  const pot=G.inventory.find(i=>t==='hp'?i.isHp:i.isMp);\par
  if(!pot)\{addLog(`No $\{t.toUpperCase()\} potions!`,'info');return;\}\par
  applyEffect(pot);G.inventory.splice(G.inventory.indexOf(pot),1);\par
  addLog(`Used $\{pot.emoji\} $\{pot.name\}!`,'heal');\par
  spawnDmg(pot.effect.hp||G.player.maxHp,t==='hp'?'#44ff88':'#44aaff',true);\par
  if(t==='hp')sfx('rgba(68,255,136,.2)',200);else sfx('rgba(68,136,255,.2)',200);\par
  updateHUD();saveG();\par
\}\par
\par
// \f1\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\f0\par
// MOVEMENT\par
// \f1\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\f0\par
function handleMove(dx,dy)\{\par
  if(G.inCombat)return;\par
  const p=G.player,nx=p.x+dx,ny=p.y+dy;\par
  if(nx<0||ny<0||nx>=MW||ny>=MH)return;\par
  const cell=G.map.cells[ny][nx];if(cell.type==='wall')return;\par
  const en=G.enemies.find(e=>e.x===nx&&e.y===ny);if(en)\{startCombat(en);return;\}\par
  p.x=nx;p.y=ny;G.turn++;\par
  if(cell.entity==='stairs')addLog('\f3\u11015?\u-497?\f2  \f0 Stairs here! Tap GRAB or G to descend.','info');\par
  if(cell.entity==='shop')\{addLog('\f4\u-10180?\u-8214?\f2  \f0 Welcome to the Shop!','shop');sfx('rgba(255,200,50,.15)',300);setTimeout(()=>togglePanel('shop'),120);\}\par
  if(cell.entity==='blacksmith')\{addLog('\f4\u-10179?\u-8920?\f2  \f0 Blacksmith! Craft gear from materials.','info');sfx('rgba(255,140,0,.15)',300);setTimeout(()=>togglePanel('blacksmith'),120);\}\par
  if(cell.entity==='alchemist')\{\par
    if(G.player.classType==='mage')addLog('\f3\u9879?\u-497?\f2  \f0 Alchemist! Brew potions & transmute (Mage bonuses active).','info');\par
    else addLog('\f3\u9879?\u-497?\f2  \f0 Alchemist! You can buy basic brews. (Mage gets extra recipes.)','info');\par
    sfx('rgba(170,68,255,.15)',300);setTimeout(()=>togglePanel('alchemist'),120);\par
  \}\par
  const it=G.items.find(i=>i.x===nx&&i.y===ny);if(it)addLog(`Spotted: $\{it.emoji\} $\{it.name\} \f2\emdash  GRAB!`,'info');\par
  doETs();\par
  if(G.turn%3===0&&p.mp<p.maxMp)p.mp=Math.min(p.maxMp,p.mp+2);\par
  updateVision(p.x,p.y);renderMap();updateHUD();saveG();\par
\}\par
function doWait()\{if(G.inCombat)return;doETs();G.turn++;const p=G.player;if(p.mp<p.maxMp)p.mp=Math.min(p.maxMp,p.mp+4);if(p.hp<p.maxHp&&Math.random()<.15)\{p.hp=Math.min(p.maxHp,p.hp+3);addLog('\f4\u-10179?\u-9052?\f2  \f0 +3 HP','heal');\}updateVision(p.x,p.y);renderMap();updateHUD();saveG();\}\par
function tryPickup()\{if(G.inCombat)return;const p=G.player,cell=G.map.cells[p.y][p.x];if(cell.entity==='stairs')\{descend();return;\}if(cell.entity==='shop')\{togglePanel('shop');return;\}if(cell.entity==='blacksmith')\{togglePanel('blacksmith');return;\}if(cell.entity==='alchemist')\{togglePanel('alchemist');return;\}const it=G.items.find(i=>i.x===p.x&&i.y===p.y);if(it)pickupItem(it);else addLog('Nothing here to grab.','info');\}\par
function dpPress(dx,dy)\{handleMove(dx,dy);dpIv=setInterval(()=>handleMove(dx,dy),180);\}\par
function dpRelease()\{clearInterval(dpIv);dpIv=null;\}\par
\par
// \f1\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\f0\par
// ENEMY TURNS\par
// \f1\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\f0\par
function doETs()\{\par
  const p=G.player;\par
  for(const en of G.enemies)\{\par
    if(!G.map.cells[en.y]?.[en.x]?.visible)continue;\par
    // Frozen/stunned skip turn\par
    if(en.status?.frozen>0)\{en.status.frozen--;continue;\}\par
    if(en.status?.stun>0)\{en.status.stun--;continue;\}\par
    const dx=p.x-en.x,dy=p.y-en.y,dist=Math.abs(dx)+Math.abs(dy);\par
    if(dist===1)\{\par
      const dmg=Math.max(1,en.atk-p.def+Math.floor(Math.random()*4));p.hp=Math.max(0,p.hp-dmg);\par
      addLog(`$\{en.emoji\} $\{en.name\} LV$\{en.level\} hits you for $\{dmg\}!`,'damage');\par
      if(Math.random()<.3)addLog(`\f4\u-10179?\u-9044?\f2  \f0 "$\{en.taunt[Math.floor(Math.random()*en.taunt.length)]\}"`,'funny');\par
      if(p.hp<=0)\{gameOver(en.name);return;\}\par
    \}else if(dist<=6)\{\par
      const dirs=[[Math.sign(dx),0],[0,Math.sign(dy)],[-Math.sign(dx),0],[0,-Math.sign(dy)]];\par
      for(const[ex,ey]of dirs)\{if(!ex&&!ey)continue;const tx=en.x+ex,ty=en.y+ey;if(tx<0||ty<0||tx>=MW||ty>=MH)continue;if(G.map.cells[ty][tx].type==='wall')continue;if(G.enemies.some(e=>e!==en&&e.x===tx&&e.y===ty))continue;if(tx===p.x&&ty===p.y)break;en.x=tx;en.y=ty;break;\}\par
    \}\par
    // Tick status effects (new system)\par
    if(en.status)\{\par
      if(en.status.poison>0)\{const pd=Math.floor(en.maxHp*.05);en.hp-=pd;en.status.poison--;addLog(`\f3\u9760?\u-497?\f2  \f0 $\{en.name\} takes $\{pd\} poison!`,'damage');if(en.hp<=0)\{defeatEnemy(en,false);break;\}\}\par
      if(en.status.burn>0)\{const bd=Math.floor(en.maxHp*.04)+3;en.hp-=bd;en.status.burn--;addLog(`\f4\u-10179?\u-8923?\f2  \f0 $\{en.name\} burns $\{bd\}!`,'damage');if(en.hp<=0)\{defeatEnemy(en,false);break;\}\}\par
    \}\par
    // Legacy poison field\par
    if(en.poisoned>0)\{const pd=Math.floor(en.maxHp*.05);en.hp-=pd;en.poisoned--;addLog(`\f3\u9760?\u-497?\f2  \f0 $\{en.name\} takes $\{pd\} poison!`,'damage');if(en.hp<=0)\{defeatEnemy(en,false);break;\}\}\par
    // Enemy regen modifier (out of combat)\par
    if(getModEffects().enemyRegen)\{en.hp=Math.min(en.maxHp,en.hp+Math.floor(en.maxHp*.03));\}\par
  \}\par
\}\par
\par
// \f1\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\f0\par
// COMBAT\par
// \f1\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\f0\par
function startCombat(en)\{\par
  G.inCombat=true;G.currentEnemy=en;\par
  const p=G.player;\par
  updCS();\par
  document.getElementById('cpname').textContent=p.className;\par
  document.getElementById('cpwpn').textContent=G.equippedWeapon?`$\{G.equippedWeapon.emoji\} $\{G.equippedWeapon.name\}`:'\f1\u9994?\f2  \f0 Bare Fists';\par
  document.getElementById('cesprite').textContent=en.emoji;\par
  document.getElementById('cename').textContent=en.name;\par
  document.getElementById('cewpn').textContent=en.wpn||'\f4\u-10179?\u-9054?\f2  \f0 Claws';\par
  document.getElementById('celvl').textContent=`LV.$\{en.level\}`;\par
  document.getElementById('clog').innerHTML='';\par
  const sk=document.getElementById('cskill');sk.innerHTML=`<span class="ci">\f1\u10024?\f0 </span>$\{p.classData.skill.name\}`;\par
  clog(`\f3\u9876?\u-497?\f2  \f0 Fighting $\{en.name\} LV$\{en.level\}!`,'#ff8888');\par
  if(en.boss)clog('\f4\u-10179?\u-9135?\f2  \f0 BOSS BATTLE!','#ffdd00');\par
  updCUI();document.getElementById('combatov').classList.add('active');\par
\}\par
function updCUI()\{\par
  const p=G.player,en=G.currentEnemy;\par
  document.getElementById('cphp').style.width=`$\{(p.hp/p.maxHp)*100\}%`;\par
  document.getElementById('cphpv').textContent=`$\{p.hp\}/$\{p.maxHp\}`;\par
  document.getElementById('cehp').style.width=`$\{Math.max(0,(en.hp/en.maxHp)*100)\}%`;\par
  document.getElementById('cehpv').textContent=`$\{Math.max(0,en.hp)\}/$\{en.maxHp\}`;\par
  document.getElementById('cskill').disabled=p.mp<p.classData.skill.cost;\par
  // Show status badges on enemy name\par
  const enName=document.getElementById('cename');\par
  const badges=getStatusBadges(en);\par
  enName.innerHTML=en.name+(badges?` $\{badges\}`:'');\par
\}\par
function clog(tx,col='#e8e8f0')\{const lg=document.getElementById('clog'),d=document.createElement('div');d.style.color=col;d.textContent=tx;lg.appendChild(d);lg.scrollTop=lg.scrollHeight;\}\par
\par
function ca(action)\{\par
  const p=G.player,en=G.currentEnemy;if(!en)return;let pd=0;\par
  const mods=getModEffects();\par
\par
  if(action==='attack')\{\par
    const crit=Math.random()*100<p.crit,base=Math.max(1,p.atk-Math.floor(en.def/2)+Math.floor(Math.random()*6));\par
    let dmg=crit?base*2:base;\par
    if(mods.dmgBoost)dmg=Math.floor(dmg*mods.dmgBoost);\par
    dmg=applyAffixOnHit(p,en,dmg);\par
    pd=dmg;\par
    clog(`You hit for $\{pd\}$\{crit?' \f4\u-10179?\u-9051?\f2  \f0 CRIT!':''\}`,'#88ff88');\par
    doVfx(crit?'crit':'slash');hfl('enemy');spawnDmg(pd,crit?'#ffdd00':'#ff8888');\par
    if(p.perks.lifesteal||mods.lifeStealBoost)\{const lsR=(p.perks.lifesteal||0)+(mods.lifeStealBoost||0);const ls=Math.floor(pd*lsR);if(ls>0)\{p.hp=Math.min(p.maxHp,p.hp+ls);clog(`\f3\u-10178?\u-8584?\f2  \f0 +$\{ls\}HP`,'#44ff88');spawnDmg(ls,'#44ff88',true);\}\}\par
    // Affix: thorns refund\par
    if(p.affix_effect?.thorns)\{const tr=Math.floor(pd*p.affix_effect.thorns);en.hp-=tr;clog(`\f4\u-10180?\u-8395?\f2  \f0 Thorns $\{tr\}!`,'#88ff44');\}\par
  \}else if(action==='skill')\{\par
    if(p.mp<p.classData.skill.cost)\{clog('Not enough MP!','#ff4444');return;\}\par
    p.mp-=p.classData.skill.cost;\par
    if(p.classType==='mage')addCorruption(2); // chaos spell corruption\par
    pd=useSkill(p.classData.skill.fn);\par
  \}else if(action==='item')\{\par
    const pot=G.inventory.find(i=>i.isHp||i.isMp)||G.inventory.find(i=>i.type==='consumable');\par
    if(!pot)\{clog('No usable items!','#ff4444');return;\}\par
    applyEffect(pot);G.inventory.splice(G.inventory.indexOf(pot),1);clog(`Used $\{pot.emoji\} $\{pot.name\}`,'#ffd700');\par
    if(pot.isHp)\{spawnDmg(pot.effect.hp||G.player.maxHp,'#44ff88',true);sfx('rgba(68,255,136,.2)',200);\}\par
    updCUI();updateHUD();eAtk();return;\par
  \}else if(action==='flee')\{\par
    if(mods.noFlee)\{clog('\f1\u10060?\f2  \f0 Inescapable! Cannot flee!','#ff4444');eAtk();return;\}\par
    if(Math.random()<.5)\{clog('Fled! Dignity gone.','#88aaff');addLog(`Fled from $\{en.name\}. Coward.`,'funny');endCombat();return;\}\par
    else\{clog("Failed! Cape grabbed!",'#ff4444');eAtk();return;\}\par
  \}\par
\par
  // MP drain modifier\par
  if(mods.mpDrain&&action!=='flee')\{p.mp=Math.max(0,p.mp-mods.mpDrain);\}\par
\par
  // Tick status effects\par
  tickStatusEnemy(en);\par
  tickStatusPlayer();\par
\par
  en.hp-=pd;\par
  if(en.hp<=0)\{defeatEnemy(en,true);return;\}\par
\par
  // Enemy regen modifier\par
  if(mods.enemyRegen)\{const regen=Math.floor(en.maxHp*.03);en.hp=Math.min(en.maxHp,en.hp+regen);if(regen)clog(`\f4\u-10179?\u-8956?\f2  \f0 $\{en.name\} regens $\{regen\}HP!`,'#ff6644');\}\par
\par
  eAtk();\par
\}\par
\par
function useSkill(fn)\{\par
  const p=G.player,en=G.currentEnemy;let dmg=0;\par
  if(!en.status)en.status=\{\};\par
  if(fn==='powerBonk')\{dmg=Math.max(1,p.atk*3-en.def);clog(`\f4\u-10179?\u-9051?\f2  \f0 POWER BONK! $\{dmg\}!`,'#ffdd00');doVfx('crit');hfl('enemy');spawnDmg(dmg,'#ff4400');\}\par
  else if(fn==='mysterySpell')\{\par
    const sp=[\par
      ()=>\{dmg=Math.max(1,40+Math.floor(Math.random()*20)-en.def);clog(`\f4\u-10179?\u-8923?\f2  \f0 Fireball! $\{dmg\}!`,'#ff8844');doVfx('bomb');hfl('enemy');applyStatus(en,'burn',3);\},\par
      ()=>\{p.hp=Math.min(p.maxHp,p.hp+35);clog('\f4\u-10179?\u-9062?\f2  \f0 Accidental +35HP','#44ff88');sfx('rgba(68,255,136,.3)',200);spawnDmg(35,'#44ff88',true);\},\par
      ()=>\{dmg=1;clog('\f4\u-10179?\u-9048?\f2  \f0 Fart cloud. 1 dmg.','#88ff88');\},\par
      ()=>\{dmg=p.atk*4;clog(`\f3\u-10180?\u-8406?\u-497?\f2  \f0 CHAOS BOLT! $\{dmg\}!`,'#ff44ff');doVfx('magic');hfl('enemy');\},\par
      ()=>\{en.def=Math.max(0,en.def-5);clog('\f3\u-10178?\u-8572?\f2  \f0 Enemy DEF-5!','#aa44ff');doVfx('magic');\},\par
      ()=>\{applyStatus(en,'frozen',2);clog('\f3\u-10178?\u-8758?\f2  \f0 Enemy FROZEN for 2 turns!','#44ccff');doVfx('magic');\},\par
      ()=>\{addCorruption(5);dmg=p.atk*5;clog(`\f1\u9889?\f2  \f0 CHAOS SURGE! $\{dmg\}! (+5% Doom)`, '#ff44ff');doVfx('magic');hfl('enemy');\},\par
    ];sp[Math.floor(Math.random()*sp.length)]();if(dmg)spawnDmg(dmg,'#aa44ff');\par
  \}else if(fn==='poisonStab')\{dmg=Math.max(1,p.atk-Math.floor(en.def/2));applyStatus(en,'poison',5);clog(`\f3\u9760?\u-497?\f2  \f0 Poison Stab! $\{dmg\}+5t poison!`,'#88ff44');doVfx('poison');hfl('enemy');spawnDmg(dmg,'#88ff44');\}\par
  else if(fn==='holyBonk')\{const h=30+Math.floor(Math.random()*20);p.hp=Math.min(p.maxHp,p.hp+h);dmg=Math.floor(Math.max(1,p.atk*1.5-en.def));clog(`\f1\u10024?\f2  \f0 +$\{h\}HP, $\{dmg\}dmg!`,'#ffdd88');doVfx('holy');hfl('enemy');spawnDmg(h,'#44ff88',true);spawnDmg(dmg,'#ffdd44');\}\par
  return Math.floor(dmg);\par
\}\par
\par
function eAtk()\{\par
  const p=G.player,en=G.currentEnemy;\par
  // Frozen/stunned enemy skips attack\par
  if(en.status?.frozen>0)\{en.status.frozen--;clog(`\f3\u-10178?\u-8758?\f2  \f0 $\{en.name\} is frozen! Skips attack.`,'#44ccff');updCUI();updateHUD();return;\}\par
  if(en.status?.stun>0)\{en.status.stun--;clog(`\f4\u-10179?\u-9045?\f2  \f0 $\{en.name\} is stunned! Skips attack.`,'#8888ff');updCUI();updateHUD();return;\}\par
  let dmg=Math.max(1,en.atk-p.def+Math.floor(Math.random()*5));\par
  // Thorns on equipped armor\par
  if(G.equippedArmor?.affix_effect?.thorns)\{const tr=Math.floor(dmg*G.equippedArmor.affix_effect.thorns);en.hp-=tr;clog(`\f4\u-10180?\u-8395?\f2  \f0 Thorns! $\{tr\} reflected!`,'#88ff44');if(en.hp<=0)\{defeatEnemy(en,true);return;\}\}\par
  p.hp=Math.max(0,p.hp-dmg);\par
  clog(`$\{en.emoji\} hits $\{dmg\}!$\{Math.random()<.4?' "'+en.taunt[Math.floor(Math.random()*en.taunt.length)]+'"':''\}`,'#ff4444');\par
  doVfx('enemy');hfl('player');spawnDmg(dmg,'#ff4444');updCUI();updateHUD();\par
  if(p.hp<=0)\{gameOver(en.name);return;\}\par
  // Legacy poisoned field (kept for save compat) + new status system\par
  if(en.poisoned>0)\{const pd=Math.floor(en.maxHp*.05);en.hp-=pd;en.poisoned--;clog(`\f3\u9760?\u-497?\f2  \f0 Poison $\{pd\}!`,'#88ff44');if(en.hp<=0)\{defeatEnemy(en,true);return;\}updCUI();\}\par
\}\par
\par
function defeatEnemy(en,fc)\{\par
  const p=G.player;G.kills++;\par
  const mods=getModEffects();\par
  const killMult=mods.killBoost||1;\par
  const gb=en.gold+Math.floor(Math.random()*8);\par
  let g=p.perks.goldBoost?Math.floor(gb*(1+p.perks.goldBoost)):gb;\par
  g=Math.floor(g*(1+(G.metaBonus?.goldBonus||0)));\par
  g=Math.floor(g*killMult);\par
  p.gold+=g;G.goldTotal+=g;\par
  let xp=Math.floor(en.xp*(1+(G.metaBonus?.xpBonus||0))*killMult);\par
  p.xp+=xp;\par
\par
  // Corruption gain\par
  const corrSlow=G.metaBonus?.corruptionSlow||0;\par
  const corrGain=en.boss?8:1;\par
  addCorruption(Math.max(0,corrGain*(1-corrSlow)));\par
\par
  if(en.boss)\{G.bossKills=(G.bossKills||0)+1;addCorruption(5);\}\par
\par
  if(fc)\{\par
    clog(`\f4\u-10179?\u-9088?\f2  \f0 Victory! +$\{xp\}XP +$\{g\}g`,'#ffd700');\par
    const ec=gctr('enemy');spPt(ec.x,ec.y,'#ffd700',10,\{speed:3,spread:4,grav:.1,decay:.04,ch:'\f4\u-10179?\u-9040?\f0 '\});\par
    if(p.perks.cannibal&&Math.random()<p.perks.cannibal)\{const eh=Math.floor(en.maxHp*.3);p.hp=Math.min(p.maxHp,p.hp+eh);clog(`\f4\u-10179?\u-8693?\f2  \f0 Nom nom! +$\{eh\}HP`,'#44ff88');\}\par
    // Modifier: explode on death\par
    if(mods.enemyExplode)\{\par
      const exDmg=Math.floor(p.maxHp*.15);\par
      p.hp=Math.max(1,p.hp-exDmg);\par
      clog(`\f4\u-10179?\u-9051?\f2  \f0 $\{en.name\} EXPLODES! $\{exDmg\} dmg!`,'#ff8800');\par
      doVfx('bomb');\par
    \}\par
    setTimeout(()=>endCombat(),750);\par
  \}\par
  G.enemies=G.enemies.filter(e=>e.id!==en.id);\par
  addLog(`\f4\u-10179?\u-9088?\f2  \f0 Defeated $\{en.emoji\} $\{en.name\} LV$\{en.level\}! +$\{xp\}XP +$\{g\}g`,'loot');\par
  if(p.xp>=p.level*100)\{p.xp-=p.level*100;p.level++;\par
    setTimeout(showLU,fc?850:0);\par
  \}\par
\par
  // Material drop\par
  const matChance=en.boss?1.0:0.35;\par
  if(Math.random()<matChance)\{\par
    const numMats=en.boss?2+Math.floor(Math.random()*2):1;\par
    for(let m=0;m<numMats;m++)\{\par
      const mat=rollMaterialDrop(G.floor,en.boss||false);\par
      if(mat&&G.inventory.length<G.maxInvSlots)\{G.inventory.push(mat);addLog(`\f3\u-10178?\u-8536?\f2  \f0 Got $\{mat.emoji\} $\{mat.name\}!`,'loot');\}\par
      else if(mat)G.items.push(\{...mat,x:en.x,y:en.y\});\par
    \}\par
  \}\par
  // Gear drop \f2\emdash  30% base + meta drop bonus\par
  const dropChance=.30+(G.metaBonus?.dropBonus||0);\par
  if(Math.random()<dropChance)\{\par
    const roll=Math.random();let d;\par
    let flTier=Math.min(4,Math.floor((G.floor-1)/1.2));\par
    if(mods.lootCurse)flTier=Math.max(0,flTier-1); // cursed loot: lower tier\par
    if(roll<.35)d=\{...CONSUMABLES[Math.floor(Math.random()*4)],uid:Math.random().toString(36).slice(2)\};\par
    else if(roll<.6)d=rollAffix(makeItem('weapon',Math.max(0,flTier-1+Math.floor(Math.random()*2)),Math.floor(Math.random()*4)));\par
    else if(roll<.8)d=rollAffix(makeItem('armor',Math.max(0,flTier-1),0));\par
    else d=rollAffix(makeItem('ring',Math.max(0,Math.min(4,flTier-1)),0));\par
    G.items.push(\{...d,x:en.x,y:en.y,uid:Math.random().toString(36).slice(2)\});\par
    const affixTxt=d.affixName?` [$\{d.affixEmoji\}$\{d.affixName\}]`:'';\par
    addLog(`\f1\u10024?\f2  \f0 Dropped $\{d.emoji\} $\{d.name\}$\{d.tier?' [T'+d.tier+']':''\}$\{affixTxt\}!`,'loot');\par
  \}\par
  renderMap();updateHUD();saveG();\par
\}\par

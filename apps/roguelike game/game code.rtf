const META_SK='doomed_meta_v1';\par
\par
const META_UPGRADES = [\par
  \{id:'inv_slots',   name:'BOTTOMLESS POCKETS', emoji:'\f4\u-10180?\u-8302?\f0 ', desc:'+2 inventory slots per level. (Max +8)', maxLevel:4, baseCost:3, costPerLevel:3, apply:(lvl)=>(\{invBonus:lvl*2\})\},\par

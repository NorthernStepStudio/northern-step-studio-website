function showIP(it)\{\par
  CI=it;\par
  document.getElementById('ipic').textContent=it.emoji;\par
  document.getElementById('ipnm').textContent=it.name;\par
  const tierEl=document.getElementById('ipti');\par
  const affixBadge=it.affix?`<br>$\{getAffixBadge(it)\}`:'';\par
  tierEl.innerHTML=it.tier?`<span class="tier-$\{it.tier\}">[T$\{it.tier\} \f2\emdash  $\{TIER_NAMES[it.tier]||''\}]</span>$\{affixBadge\}`:affixBadge;\par
  document.getElementById('ipds').textContent=it.desc||'';\par
  const statsText=fmtSt(it)+(it.affixDesc?`\\n\f1\u10022?\f2  \f0 $\{it.affixDesc\}`:'');\par
  document.getElementById('ipst').textContent=statsText;\par
  const btns=document.getElementById('ipbtns');btns.innerHTML='';\par
  const isMat=it.type==='material';\par
  const isElixir=it.type==='elixir';\par
  const useLabel=it.isHp||it.isMp||it.type==='consumable'||isElixir?'\f3\u-10178?\u-8726?\f2  \f0 USE':(isMat?null:'\f3\u9876?\u-497?\f2  \f0 EQUIP');\par
  const useBtn=useLabel?`<button class="icbtn g" onclick="useItem(CI)">$\{useLabel\}</button>`:'';\par
  const sellPrice=Math.floor((it.value||20)*.5);\par
  const sellBtn=`<button class="icbtn y" onclick="sellItemFromPopup(CI)">\f4\u-10179?\u-9032?\f2  \f0 SELL ($\{sellPrice\}g)</button>`;\par
  const fuseBtn=`<button class="icbtn" style="border-color:var(--purple);color:var(--purple)" onclick="sendToFuse(CI)">\f3\u9879?\u-497?\f2  \f0 FUSE</button>`;\par
  const closeBtn=`<button class="icbtn" onclick="closeIP()">\f1\u10060?\f0 </button>`;\par
  const dropBtn=`<button class="icbtn r" onclick="dropItem(CI)">\f3\u-10179?\u-8751?\u-497?\f0 </button>`;\par
  btns.innerHTML=useBtn+sellBtn+fuseBtn+closeBtn+dropBtn;\par
  document.getElementById('itempop').classList.add('active');\par
\}\par
function closeIP()\{document.getElementById('itempop').classList.remove('active');CI=null;\}\par
function sellItemFromPopup(it)\{if(!it)return;if(it===G.equippedWeapon||it===G.equippedArmor||it===G.equippedRing)\{addLog('Unequip before selling!','info');return;\}const p=Math.floor((it.value||20)*.5);G.player.gold+=p;G.inventory.splice(G.inventory.indexOf(it),1);addLog(`\f4\u-10179?\u-9032?\f2  \f0 Sold $\{it.emoji\} $\{it.name\} for $\{p\}g`,'shop');spPt(window.innerWidth*.5,window.innerHeight*.6,'#ffd700',8,\{speed:3,spread:4,grav:.1,decay:.05,ch:'\f4\u-10179?\u-9040?\f0 '\});closeIP();updateHUD();saveG();\}\par
function sendToFuse(it)\{if(!it)return;closeIP();setFuseSlot(1,it);togglePanel('fuse');\}\par
\par
function useItem(it)\{\par
  if(!it)return;const p=G.player;\par
  if(it.isHp||it.isMp||it.type==='consumable'||it.type==='elixir')\{applyEffect(it);G.inventory.splice(G.inventory.indexOf(it),1);addLog(`Used $\{it.emoji\}!`,'heal');\}\par
  else if(it.type==='weapon')\{\par
    if(G.equippedWeapon)\{p.atk-=G.equippedWeapon.effect.atk||0;if(G.equippedWeapon.effect.crit)p.crit-=G.equippedWeapon.effect.crit;if(G.equippedWeapon.effect.def)p.def-=G.equippedWeapon.effect.def||0;applyAffixOnEquip(G.equippedWeapon,false);\}\par
    G.equippedWeapon=it;p.atk+=it.effect.atk||0;if(it.effect.crit)p.crit+=it.effect.crit;if(it.effect.def)p.def+=it.effect.def||0;applyAffixOnEquip(it,true);\par
    addLog(`Equipped $\{it.emoji\} $\{it.name\}$\{it.affixName?' ['+it.affixEmoji+it.affixName+']':''\}!`,'info');\par
  \}else if(it.type==='armor')\{\par
    if(G.equippedArmor)\{const oe=G.equippedArmor.effect;p.def-=oe.def||0;if(oe.spd)p.spd-=oe.spd;if(oe.crit)p.crit-=oe.crit;applyAffixOnEquip(G.equippedArmor,false);\}\par
    G.equippedArmor=it;const ae=it.effect;p.def+=ae.def||0;if(ae.spd)p.spd+=ae.spd;if(ae.crit)p.crit+=ae.crit;applyAffixOnEquip(it,true);\par
    addLog(`Equipped $\{it.emoji\} $\{it.name\}!`,'info');\par
  \}\par
  else if(it.type==='ring')\{if(G.equippedRing)\{const re=G.equippedRing.effect;if(re.spd)p.spd-=re.spd;if(re.crit)p.crit-=re.crit;if(re.atk)p.atk-=re.atk;\}G.equippedRing=it;const e=it.effect;if(e.spd)p.spd+=e.spd;if(e.crit)p.crit+=e.crit;if(e.atk)p.atk+=e.atk;addLog(`Equipped $\{it.emoji\}!`,'info');\}\par
  updateHUD();closeIP();saveG();\par
\}\par
function applyEffect(it)\{\par
  const p=G.player,e=it.effect,b=p.perks.potBoost||0;\par
  const mods=getModEffects();\par
  const healMult=mods.healMult||1;\par
  if(e.hp)p.hp=Math.min(p.maxHp,p.hp+Math.floor(e.hp*(1+b)*healMult));\par
  if(e.hpFull)p.hp=p.maxHp;if(e.mp)p.mp=Math.min(p.maxMp,p.mp+e.mp);if(e.mpFull)p.mp=p.maxMp;\par
  if(e.gold)p.gold+=p.perks.goldBoost?Math.floor(e.gold*(1+p.perks.goldBoost)):e.gold;\par
  if(e.bomb&&G.currentEnemy)\{const bd=Math.floor(e.bomb*(1+(p.perks.bombBoost||0)));G.currentEnemy.hp-=bd;clog(`\f4\u-10179?\u-9053?\f2  \f0 BOMB! $\{bd\}!`,'#ff8800');doVfx('bomb');hfl('enemy');\}\par
  if(e.elixirAtk)\{p.atk+=e.elixirAtk;G.elixirBuffs=G.elixirBuffs||[];G.elixirBuffs.push(\{stat:'atk',val:e.elixirAtk\});addLog(`\f4\u-10179?\u-8908?\f2  \f0 +$\{e.elixirAtk\} ATK (elixir)!`,'heal');\}\par
  if(e.elixirDef)\{p.def+=e.elixirDef;G.elixirBuffs=G.elixirBuffs||[];G.elixirBuffs.push(\{stat:'def',val:e.elixirDef\});addLog(`\f6\u-10179?\u-8220?\f2  \f0 +$\{e.elixirDef\} DEF (elixir)!`,'heal');\}\par
  if(e.elixirSpd)\{p.spd+=e.elixirSpd;G.elixirBuffs=G.elixirBuffs||[];G.elixirBuffs.push(\{stat:'spd',val:e.elixirSpd\});addLog(`\f1\u9889?\f2  \f0 +$\{e.elixirSpd\} SPD (elixir)!`,'heal');\}\par
  if(e.elixirCrit)\{p.crit+=e.elixirCrit;G.elixirBuffs=G.elixirBuffs||[];G.elixirBuffs.push(\{stat:'crit',val:e.elixirCrit\});addLog(`\f1\u9889?\f2  \f0 +$\{e.elixirCrit\} CRIT (elixir)!`,'heal');\}\par
  if(e.chaos)\{\par
    const outcomes=[\par
      ()=>\{p.hp=p.maxHp;addLog('\f4\u-10180?\u-8448?\f2  \f0 Chaos: Full heal!','heal');\},\par
      ()=>\{p.mp=p.maxMp;addLog('\f4\u-10180?\u-8448?\f2  \f0 Chaos: Full MP!','heal');\},\par
      ()=>\{p.atk+=15;addLog('\f4\u-10180?\u-8448?\f2  \f0 Chaos: +15 ATK!','heal');\},\par
      ()=>\{p.hp=Math.max(1,p.hp-30);addLog('\f4\u-10180?\u-8448?\f2  \f0 Chaos: Ouch. -30 HP.','damage');\},\par
      ()=>\{p.gold+=100;addLog('\f4\u-10180?\u-8448?\f2  \f0 Chaos: +100 gold!','loot');\},\par
      ()=>\{p.crit+=25;addLog('\f4\u-10180?\u-8448?\f2  \f0 Chaos: +25 CRIT!','heal');\},\par
    ];\par
    outcomes[Math.floor(Math.random()*outcomes.length)]();\par
  \}\par
  updateHUD();\par
\}\par
function dropItem(it)\{\par
  if(!it)return;const p=G.player;\par
  if(it===G.equippedWeapon)\{p.atk-=it.effect.atk||0;if(it.effect.crit)p.crit-=it.effect.crit;if(it.effect.def)p.def-=it.effect.def||0;G.equippedWeapon=null;\}\par
  if(it===G.equippedArmor)\{const ae=it.effect;p.def-=ae.def||0;if(ae.spd)p.spd-=ae.spd;if(ae.crit)p.crit-=ae.crit;G.equippedArmor=null;\}\par
  if(it===G.equippedRing)\{const e=it.effect;if(e.spd)p.spd-=e.spd;if(e.crit)p.crit-=e.crit;if(e.atk)p.atk-=e.atk;G.equippedRing=null;\}\par
  G.inventory.splice(G.inventory.indexOf(it),1);G.items.push(\{...it,x:p.x,y:p.y,uid:Math.random().toString(36).slice(2)\});\par
  addLog(`Dropped $\{it.emoji\}.`,'info');updateHUD();renderMap();closeIP();saveG();\par
\}\par

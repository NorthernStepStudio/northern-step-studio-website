function pickupItem(it)\{\par
  if(G.inventory.length>=G.maxInvSlots)\{addLog('Inventory full! Sell or drop.','info');return;\}\par
  if(it.type==='gold')\{const g=it.effect.gold,fg=G.player.perks.goldBoost?Math.floor(g*(1+G.player.perks.goldBoost)):g;G.player.gold+=fg;addLog(`\f4\u-10179?\u-9040?\f2  \f0 Got $\{fg\} gold!`,'loot');\}\par
  else\{G.inventory.push(it);addLog(`Picked up $\{it.emoji\} $\{it.name\}$\{it.tier?' [T'+it.tier+']':''\}!`,'loot');if(it.isHp||it.isMp)addLog(`\f4\u-10179?\u-9055?\f2  \f0 Q=HP pot, E=MP pot`,'info');\}\par
  G.items=G.items.filter(i=>i.uid!==it.uid);updateHUD();renderMap();saveG();\par
\}\par
\par
function fmtSt(it)\{\par
  if(!it)return'';\par
  if(it.type==='material')return`\f3\u-10178?\u-8536?\f2  \f0 Crafting material \f2\bullet  Rarity: $\{'\f1\u9733?\f0 '.repeat(it.rarity||1)\}`;\par
  if(!it.effect)return'';\par
  const e=it.effect,ps=[];\par
  if(e.hp)ps.push(`\f3\u10084?\u-497?\f0 +$\{e.hp\}`);if(e.mp)ps.push(`\f1\u10024?\f0 +$\{e.mp\}`);\par
  if(e.hpFull)ps.push('\f3\u10084?\u-497?\f2  \f0 FULL');if(e.mpFull)ps.push('\f1\u10024?\f2  \f0 FULL');\par
  if(e.atk)ps.push(`\f3\u9876?\u-497?\f0 +$\{e.atk\}`);if(e.def)ps.push(`\f3\u-10179?\u-8479?\u-497?\f0 +$\{e.def\}`);\par
  if(e.spd)ps.push(`\f4\u-10179?\u-9048?\f0 +$\{e.spd\}`);if(e.crit)ps.push(`\f4\u-10180?\u-8273?\f0 +$\{e.crit\}%`);\par
  if(e.gold)ps.push(`\f4\u-10179?\u-9040?\f0 +$\{e.gold\}`);if(e.bomb)ps.push(`\f4\u-10179?\u-9051?\f0 $\{e.bomb\}dmg`);\par
  if(e.elixirAtk)ps.push(`\f3\u9876?\u-497?\f0 +$\{e.elixirAtk\} (floor)`);\par
  if(e.elixirDef)ps.push(`\f3\u-10179?\u-8479?\u-497?\f0 +$\{e.elixirDef\} (floor)`);\par
  if(e.elixirSpd)ps.push(`\f4\u-10179?\u-9048?\f0 +$\{e.elixirSpd\} (floor)`);\par
  if(e.elixirCrit)ps.push(`\f4\u-10180?\u-8273?\f0 +$\{e.elixirCrit\}% (floor)`);\par
  if(e.chaos)ps.push('\f4\u-10180?\u-8448?\f2  \f0 CHAOS effect');\par
  return ps.join(' ')||'Mysterious';\par
\}\par

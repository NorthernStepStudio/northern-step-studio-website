\pard\sa200\sl276\slmult1\f0\fs22\lang9 <!DOCTYPE html>\par
<html lang="en">\par
<head>\par
<meta charset="UTF-8">\par
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">\par
<title>DOOMED: A Very Silly Dungeon</title>\par
<style>\par
@import url('https://fonts.googleapis.com/css2?family=Press+Start+2P&family=VT323&display=swap');\par
:root\{\par
  --bg:#0a0a0f;--bg2:#12121a;--panel:#0d0d1a;--border:#2a2a4a;\par
  --gold:#ffd700;--gold2:#ffaa00;--red:#ff4444;--green:#44ff88;\par
  --blue:#44aaff;--purple:#aa44ff;--cyan:#44ffee;--white:#e8e8f0;\par
  --gray:#888899;--wall:#1a1a2a;--floor:#0f0f1c;\par
  --cell:28px;\par
\}\par
*\{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;\}\par
html,body\{background:var(--bg);color:var(--white);font-family:'Press Start 2P',monospace;font-size:10px;height:100%;overflow:hidden;touch-action:none;user-select:none;\}\par
body::after\{content:'';position:fixed;inset:0;background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,0.04) 2px,rgba(0,0,0,0.04) 4px);pointer-events:none;z-index:9999;\}\par
\par
/* \f1\u9552?\u9552?\f2  \f0 TITLE \f1\u9552?\u9552?\f2  \f0 */\par
#title-screen\{position:fixed;inset:0;background:var(--bg);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:14px;padding:16px;overflow-y:auto;z-index:500;\}\par
.title-big\{font-size:clamp(16px,5vw,28px);color:var(--gold);text-shadow:0 0 20px var(--gold2),4px 4px 0 #7a5800;text-align:center;animation:pulse 2s ease-in-out infinite;\}\par
@keyframes pulse\{0%,100%\{text-shadow:0 0 20px var(--gold2),4px 4px 0 #7a5800;\}50%\{text-shadow:0 0 40px var(--gold),0 0 60px var(--gold2),4px 4px 0 #7a5800;\}\}\par
.title-sub\{font-size:clamp(6px,2vw,9px);color:var(--cyan);text-shadow:0 0 10px var(--cyan);text-align:center;\}\par
.class-grid\{display:grid;grid-template-columns:repeat(2,1fr);gap:8px;width:100%;max-width:460px;\}\par
.class-card\{border:3px solid var(--border);background:var(--panel);padding:10px 8px;cursor:pointer;text-align:center;transition:all .1s;\}\par
.class-card:hover,.class-card.selected\{border-color:var(--gold);background:#1a1a2e;transform:translateY(-3px);box-shadow:0 6px 0 #7a5800;\}\par
.class-icon\{font-size:24px;display:block;margin-bottom:5px;\}\par
.class-name\{color:var(--gold);font-size:7px;display:block;margin-bottom:3px;\}\par
.class-desc\{color:var(--gray);font-family:'VT323',monospace;font-size:13px;line-height:1.4;\}\par
.class-weapon\{color:#ff9944;font-family:'VT323',monospace;font-size:12px;margin-top:3px;\}\par
.class-stats\{color:var(--cyan);font-family:'VT323',monospace;font-size:12px;margin-top:3px;\}\par
.continue-btn\{background:#1a2a1a;border:3px solid var(--green);color:var(--green);font-family:'Press Start 2P',monospace;font-size:9px;padding:10px 20px;cursor:pointer;width:100%;max-width:460px;\}\par
.continue-btn:hover\{background:var(--green);color:var(--bg);\}\par
.start-btn\{background:var(--panel);border:3px solid var(--gold);color:var(--gold);font-family:'Press Start 2P',monospace;font-size:9px;padding:10px 20px;cursor:pointer;width:100%;max-width:460px;position:relative;transition:all .1s;\}\par
.start-btn::after\{content:'';position:absolute;bottom:-5px;right:-5px;width:100%;height:100%;background:#7a5800;z-index:-1;\}\par
.start-btn:hover\{background:var(--gold);color:var(--bg);transform:translate(-2px,-2px);\}\par
.start-btn:disabled\{opacity:.4;cursor:not-allowed;transform:none;\}\par
\par
/* \f1\u9552?\u9552?\f2  \f0 GAME LAYOUT \f1\u9552?\u9552?\f2  \f0 */\par
#game-screen\{display:none;position:fixed;inset:0;flex-direction:column;background:var(--bg);\}\par
\par
/* HUD */\par
#hud\{background:var(--panel);border-bottom:3px solid var(--border);padding:5px 8px;display:flex;align-items:center;gap:6px;flex-shrink:0;\}\par
.hud-sprite\{width:28px;height:28px;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;\}\par
.hud-sprite img\{width:28px;height:28px;object-fit:contain;image-rendering:pixelated;\}\par
.hud-info\{display:flex;flex-direction:column;gap:2px;flex-shrink:0;\}\par
.hud-name\{font-size:6px;color:var(--gold);\}\par
.hud-level\{font-size:6px;color:var(--purple);\}\par
.hud-bars\{display:flex;flex-direction:column;gap:3px;flex:1;min-width:80px;\}\par
.bar-row\{display:flex;align-items:center;gap:3px;\}\par
.bar-lbl\{font-size:6px;color:var(--gray);width:14px;\}\par
.bar-track\{flex:1;height:9px;border:2px solid;overflow:hidden;\}\par
.bar-track.ht\{border-color:#660000;background:#1a0000;\}\par
.bar-track.mt\{border-color:#002266;background:#00001a;\}\par
.bar-fill\{height:100%;transition:width .3s;\}\par
.bar-fill.hp\{background:linear-gradient(90deg,#ff2222,#ff6666);\}\par
.bar-fill.mp\{background:linear-gradient(90deg,#2244ff,#44aaff);\}\par
.bar-val\{font-size:6px;color:var(--white);width:46px;text-align:right;\}\par
.hud-r\{display:flex;flex-direction:column;gap:2px;align-items:flex-end;flex-shrink:0;\}\par
.hbadge\{font-size:6px;\}\par
.hbadge.fl\{color:var(--purple);\}\par
.hbadge.go\{color:var(--gold);\}\par
.hbadge.ki\{color:var(--gray);\}\par
\par
/* QUICKSLOTS */\par
#qs\{background:#080812;border-bottom:2px solid var(--border);padding:3px 8px;display:flex;gap:4px;align-items:center;flex-shrink:0;\}\par
.qs-lbl\{font-size:6px;color:var(--gray);\}\par
.qs-slot\{width:28px;height:28px;background:#0d0d1a;border:2px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:15px;cursor:pointer;position:relative;border-radius:3px;transition:all .1s;\}\par
.qs-slot:active\{transform:scale(.9);\}\par
.qs-slot.qs-hp\{border-color:#441111;\}\par
.qs-slot.qs-mp\{border-color:#111144;\}\par
.qs-slot.qs-empty\{opacity:.25;cursor:default;\}\par
.qs-cnt\{position:absolute;bottom:0;right:1px;font-size:6px;color:var(--gold);font-family:'Press Start 2P',monospace;\}\par
.qs-key\{position:absolute;top:0;left:1px;font-size:5px;color:var(--gray);\}\par
.qs-wpn\{flex:1;font-family:'VT323',monospace;font-size:13px;color:#ff9944;margin-left:4px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;\}\par
.qs-right\{display:flex;gap:6px;align-items:center;flex-shrink:0;\}\par
.qs-atk\{font-size:6px;color:var(--cyan);\}\par
/* ZOOM BUTTONS */\par
.zoom-btn\{background:#0d0d1a;border:2px solid var(--border);color:var(--white);font-size:12px;width:22px;height:22px;display:flex;align-items:center;justify-content:center;cursor:pointer;border-radius:3px;\}\par
.zoom-btn:active\{border-color:var(--gold);\}\par
\par
/* XP */\par
#xp-strip\{height:3px;background:#080812;flex-shrink:0;\}\par
#xp-fill\{height:100%;background:linear-gradient(90deg,#7700cc,#aa44ff);transition:width .4s;\}\par
\par
/* MAP */\par
#map-wrap\{flex:1;overflow:hidden;position:relative;background:var(--bg);\}\par
#map-scroll\{position:absolute;top:0;left:0;overflow:hidden;width:100%;height:100%;\}\par
#dungeon-map\{display:grid;gap:0;image-rendering:pixelated;position:absolute;\}\par
\par
.cell\{display:flex;align-items:center;justify-content:center;position:relative;cursor:default;transition:background .1s;\}\par
.cell.wall\{background:var(--wall);\}\par
.cell.floor\{background:var(--floor);\}\par
.cell.fog\{background:#040407;\}\par
.cell.seen\{filter:brightness(.35);\}\par
.ce\{line-height:1;display:block;\}\par
.ce.bob\{animation:bob 1s ease-in-out infinite;\}\par
.ce.idle\{animation:idle 1.5s ease-in-out infinite;\}\par
.pmap\{object-fit:contain;image-rendering:pixelated;animation:idle 1.5s ease-in-out infinite;\}\par
@keyframes bob\{0%,100%\{transform:translateY(0)\}50%\{transform:translateY(-2px)\}\}\par
@keyframes idle\{0%,100%\{transform:scale(1)\}50%\{transform:scale(1.06)\}\}\par
\par
/* MINIMAP */\par
#mmwrap\{position:absolute;top:6px;right:6px;background:rgba(6,6,14,.92);border:2px solid var(--border);padding:3px;border-radius:3px;z-index:10;\}\par
#minimap\{display:grid;gap:1px;\}\par
.mc\{width:4px;height:4px;\}\par
.mc.mw\{background:#1a1a28;\}.mc.mf\{background:#141424;\}.mc.mg\{background:#040406;\}\par
.mc.mp\{background:#44ff88;\}.mc.me\{background:#ff4444;\}.mc.mi\{background:#ffd700;\}\par
.mc.ms\{background:#44ffee;\}.mc.msh\{background:#ff88ff;\}.mc.msm\{background:#ff8800;\}.mc.mal\{background:#aa44ff;\}\par
\par
/* BLUEPRINT CARDS */\par
.bp-card\{background:#0a0a14;border:2px solid var(--border);border-radius:6px;padding:8px;margin-bottom:6px;cursor:default;transition:all .1s;\}\par
.bp-card.bp-ready\{border-color:#ff8800;cursor:pointer;\}\par
.bp-card.bp-ready:hover\{background:#140a00;border-color:var(--gold);\}\par
.bp-card:active\{transform:scale(.98);\}\par
.bp-header\{display:flex;align-items:center;gap:8px;margin-bottom:5px;\}\par
.bp-icon\{font-size:22px;flex-shrink:0;\}\par
.bp-info\{flex:1;\}\par
.bp-name\{font-size:7px;color:var(--white);margin-bottom:2px;\}\par
.bp-stats\{font-size:6px;color:var(--cyan);\}\par
.bp-cost\{font-size:7px;color:var(--gold);flex-shrink:0;\}\par
.bp-mats\{display:flex;flex-wrap:wrap;gap:3px;margin-top:4px;\}\par
.mat-tag\{font-family:'VT323',monospace;font-size:12px;padding:1px 5px;border-radius:3px;border:1px solid;\}\par
.mat-ok\{border-color:#2a4a2a;background:#0a1a0a;color:#44ff88;\}\par
.mat-missing\{border-color:#4a2a2a;background:#1a0a0a;color:#ff6666;\}\par
.bp-hint\{font-size:6px;color:var(--gray);margin-top:3px;font-family:'VT323',monospace;font-size:11px;\}\par
\par
/* CONTROLS */\par
#ctrl\{background:var(--panel);border-top:3px solid var(--border);padding:5px;display:flex;flex-direction:column;align-items:center;gap:4px;flex-shrink:0;\}\par
#abtns\{display:flex;gap:4px;justify-content:center;width:100%;\}\par
.abtn\{background:#0d0d1a;border:2px solid var(--border);color:var(--white);font-family:'Press Start 2P',monospace;font-size:5px;padding:4px 4px;cursor:pointer;flex:1;max-width:68px;display:flex;flex-direction:column;align-items:center;gap:2px;transition:all .1s;\}\par
.abtn .ai\{font-size:14px;\}\par
.abtn:active\{background:var(--bg2);border-color:var(--gold);transform:scale(.95);\}\par
.abtn.highlight\{border-color:var(--gold);color:var(--gold);\}\par
#dpad\{display:grid;grid-template-columns:repeat(3,48px);grid-template-rows:repeat(3,48px);gap:3px;\}\par
.dp\{background:#1a1a2e;border:2px solid var(--border);font-size:18px;display:flex;align-items:center;justify-content:center;cursor:pointer;user-select:none;border-radius:4px;transition:all .08s;\}\par
.dp:active\{background:#2a2a4e;border-color:var(--gold);transform:scale(.9);\}\par
.dp.dpc\{background:#0d0d1a;border-color:#1a1a2e;font-size:13px;color:var(--gray);\}\par
.dp.dpe\{background:transparent;border-color:transparent;pointer-events:none;\}\par
\par
/* SLIDE PANELS */\par
.spanel\{position:fixed;bottom:0;left:0;right:0;background:var(--panel);border-top:3px solid var(--border);z-index:300;transform:translateY(100%);transition:transform .25s cubic-bezier(.4,0,.2,1);max-height:75vh;overflow-y:auto;border-radius:12px 12px 0 0;\}\par
.spanel.open\{transform:translateY(0);\}\par
.sph\{display:flex;align-items:center;justify-content:space-between;padding:10px 14px;border-bottom:2px solid var(--border);position:sticky;top:0;background:var(--panel);z-index:1;\}\par
.spt\{color:var(--gold);font-size:9px;text-shadow:0 0 8px var(--gold2);\}\par
.spc\{background:none;border:2px solid var(--border);color:var(--gray);font-family:'Press Start 2P',monospace;font-size:8px;padding:4px 8px;cursor:pointer;\}\par
.spc:hover\{border-color:var(--red);color:var(--red);\}\par
.spb\{padding:10px 12px;\}\par
\par
/* INVENTORY PANEL TABS */\par
.inv-tabs\{display:flex;gap:0;margin-bottom:10px;border:2px solid var(--border);border-radius:4px;overflow:hidden;\}\par
.inv-tab\{flex:1;background:#0a0a14;border:none;color:var(--gray);font-family:'Press Start 2P',monospace;font-size:7px;padding:7px 4px;cursor:pointer;transition:all .1s;\}\par
.inv-tab.active\{background:var(--border);color:var(--gold);\}\par
\par
#inv-grid\{display:grid;grid-template-columns:repeat(4,1fr);gap:6px;margin-bottom:10px;\}\par
.isl\{aspect-ratio:1;background:#0a0a14;border:2px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:22px;cursor:pointer;border-radius:4px;transition:all .1s;position:relative;\}\par
.isl:active\{transform:scale(.92);\}\par
.isl.equipped\{border-color:var(--green);background:#0a1a0a;box-shadow:0 0 8px rgba(68,255,136,.25);\}\par
.isl.empty\{cursor:default;opacity:.2;\}\par
.isl .isl-lvl\{position:absolute;bottom:1px;right:2px;font-size:6px;color:var(--gold);font-family:'Press Start 2P',monospace;\}\par
.isl .isl-tier\{position:absolute;top:1px;left:2px;font-size:6px;font-family:'Press Start 2P',monospace;\}\par
\par
/* SHOP PANEL */\par
.shop-section\{margin-bottom:14px;\}\par
.shop-section-title\{font-size:7px;color:var(--cyan);margin-bottom:8px;padding-bottom:4px;border-bottom:1px solid var(--border);\}\par
.shop-item\{display:flex;align-items:center;gap:8px;padding:8px;background:#0a0a14;border:2px solid var(--border);border-radius:4px;margin-bottom:6px;cursor:pointer;transition:all .1s;\}\par
.shop-item:hover\{border-color:var(--gold);\}\par
.shop-item:active\{transform:scale(.98);\}\par
.shop-emoji\{font-size:22px;flex-shrink:0;\}\par
.shop-info\{flex:1;\}\par
.shop-name\{font-size:7px;color:var(--white);margin-bottom:2px;\}\par
.shop-desc\{font-family:'VT323',monospace;font-size:13px;color:var(--gray);\}\par
.shop-cost\{font-size:7px;color:var(--gold);flex-shrink:0;\}\par
.shop-cost.cant-afford\{color:var(--red);\}\par
.shop-upgrade\{background:#0a1400;border-color:#2a4400;\}\par
.shop-upgrade:hover\{border-color:var(--green);\}\par
.inv-slots-display\{font-size:7px;color:var(--gray);text-align:center;padding:6px;background:#0a0a14;border:2px solid var(--border);border-radius:4px;margin-bottom:8px;\}\par
\par
/* FUSION PANEL */\par
.fusion-grid\{display:grid;grid-template-columns:1fr auto 1fr;align-items:center;gap:8px;margin-bottom:12px;\}\par
.fusion-slot\{background:#0a0a14;border:2px dashed var(--border);border-radius:6px;padding:16px 8px;text-align:center;cursor:pointer;min-height:70px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:4px;transition:all .1s;\}\par
.fusion-slot:hover\{border-color:var(--purple);\}\par
.fusion-slot.filled\{border-color:var(--purple);background:#0d0a1a;border-style:solid;\}\par
.fusion-slot-icon\{font-size:28px;\}\par
.fusion-slot-name\{font-size:6px;color:var(--purple);\}\par
.fusion-arrow\{font-size:20px;color:var(--purple);text-align:center;\}\par
.fusion-result\{background:#0a0a14;border:2px solid var(--border);border-radius:6px;padding:12px;text-align:center;margin-bottom:10px;\}\par
.fusion-result.ready\{border-color:var(--gold);background:#1a1400;\}\par
.fusion-btn\{background:#0d0d1a;border:3px solid var(--purple);color:var(--purple);font-family:'Press Start 2P',monospace;font-size:8px;padding:10px;cursor:pointer;width:100%;border-radius:4px;transition:all .1s;\}\par
.fusion-btn:hover:not(:disabled)\{background:var(--purple);color:var(--bg);\}\par
.fusion-btn:disabled\{opacity:.3;cursor:not-allowed;\}\par
.fusion-rule\{font-family:'VT323',monospace;font-size:14px;color:var(--gray);margin-bottom:4px;padding:4px 8px;background:#080810;border-radius:3px;\}\par
\par
/* STATS */\par
.sgrid\{display:grid;grid-template-columns:1fr 1fr;gap:5px;\}\par
.sgi\{background:#0a0a14;border:2px solid var(--border);padding:7px;display:flex;justify-content:space-between;align-items:center;border-radius:4px;\}\par
.sgk\{font-size:7px;color:var(--gray);\}\par
.sgv\{font-size:8px;color:var(--cyan);\}\par
.plst\{margin-top:10px;\}\par
.ptag\{display:inline-block;background:#1a0a2a;border:2px solid var(--purple);color:var(--purple);font-size:6px;padding:3px 6px;margin:2px;border-radius:3px;\}\par
\par
/* LOG */\par
#log-list\{font-family:'VT323',monospace;font-size:16px;line-height:1.6;display:flex;flex-direction:column;\}\par
.le\{padding:1px 0;\}\par
.le.damage\{color:var(--red);\}.le.heal\{color:var(--green);\}.le.loot\{color:var(--gold);\}\par
.le.info\{color:var(--cyan);\}.le.funny\{color:#ff88ff;\}.le.shop\{color:#ffaa44;\}\par
\par
/* COMBAT */\par
#combatov\{display:none;position:fixed;inset:0;background:rgba(0,0,0,.88);z-index:400;align-items:flex-end;justify-content:center;\}\par
#combatov.active\{display:flex;\}\par
.cbox\{background:var(--panel);border:3px solid var(--red);border-bottom:none;border-radius:12px 12px 0 0;width:100%;max-width:500px;box-shadow:0 0 30px rgba(255,68,68,.3);\}\par
.ctitle\{text-align:center;color:var(--red);font-size:11px;padding:8px;border-bottom:2px solid #330000;text-shadow:0 0 12px var(--red);animation:cfl .6s ease infinite;\}\par
@keyframes cfl\{0%,100%\{opacity:1\}50%\{opacity:.75\}\}\par
.combatants\{display:flex;justify-content:space-around;align-items:center;padding:10px 14px;gap:8px;\}\par
.combatant\{text-align:center;flex:1;\}\par
.cswrap\{position:relative;display:inline-block;margin-bottom:4px;\}\par
.cswrap::after\{content:'';position:absolute;inset:0;background:white;opacity:0;border-radius:4px;pointer-events:none;transition:opacity .08s;\}\par
.cswrap.hflash::after\{opacity:.75;\}\par
.csprite\{font-size:44px;display:block;\}\par
.csprite img\{width:56px;height:56px;object-fit:contain;image-rendering:pixelated;\}\par
.cname\{font-size:7px;margin-bottom:2px;\}\par
.cwpn\{font-size:6px;color:#ff9944;font-family:'VT323',monospace;font-size:12px;margin-bottom:3px;\}\par
.clvl\{font-size:6px;color:var(--purple);\}\par
.chpbar\{height:8px;border:2px solid #660000;background:#1a0000;margin-bottom:3px;\}\par
.chpfill\{height:100%;transition:width .4s;\}\par
.chpfill.ph\{background:linear-gradient(90deg,#ff2222,#ff6666);\}\par
.chpfill.eh\{background:linear-gradient(90deg,#ff8800,#ffaa44);\}\par
.chpval\{font-size:6px;color:var(--green);\}\par
.vs\{font-size:14px;color:var(--red);text-shadow:0 0 8px var(--red);flex-shrink:0;\}\par
.clog\{background:#070710;border-top:2px solid var(--border);border-bottom:2px solid var(--border);height:64px;overflow-y:auto;padding:5px 12px;font-family:'VT323',monospace;font-size:15px;line-height:1.5;\}\par
.cactions\{display:grid;grid-template-columns:repeat(4,1fr);border-top:2px solid var(--border);\}\par
.cbtn\{background:#0d0d1a;border:none;border-right:2px solid var(--border);color:var(--white);font-family:'Press Start 2P',monospace;font-size:6px;padding:10px 4px;cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:3px;transition:all .1s;\}\par
.cbtn:last-child\{border-right:none;\}\par
.cbtn .ci\{font-size:18px;\}\par
.cbtn:active\{background:#1a1a2e;\}\par
.cbtn:disabled\{opacity:.35;cursor:not-allowed;\}\par
\par
/* VFX */\par
#vfxc\{position:fixed;inset:0;pointer-events:none;z-index:450;\}\par
#sflash\{position:fixed;inset:0;pointer-events:none;z-index:440;opacity:0;transition:opacity .05s;\}\par
\par
/* ITEM POPUP */\par
#itempop\{display:none;position:fixed;inset:0;background:rgba(0,0,0,.85);z-index:450;align-items:flex-end;justify-content:center;\}\par
#itempop.active\{display:flex;\}\par
.icard\{background:var(--panel);border:3px solid var(--gold);border-bottom:none;border-radius:12px 12px 0 0;width:100%;max-width:420px;padding:14px;\}\par
.icicon\{font-size:40px;display:block;margin-bottom:6px;text-align:center;\}\par
.icname\{color:var(--gold);font-size:9px;margin-bottom:4px;text-align:center;\}\par
.ictier\{font-size:7px;text-align:center;margin-bottom:4px;\}\par
.icdesc\{color:var(--gray);font-family:'VT323',monospace;font-size:16px;margin-bottom:6px;line-height:1.4;text-align:center;\}\par
.icstats\{color:var(--cyan);font-size:7px;margin-bottom:12px;line-height:2;text-align:center;\}\par
.icbtns\{display:flex;gap:5px;justify-content:center;flex-wrap:wrap;\}\par
.icbtn\{background:var(--panel);border:2px solid var(--border);color:var(--white);font-family:'Press Start 2P',monospace;font-size:7px;padding:7px 10px;cursor:pointer;border-radius:4px;transition:all .1s;\}\par
.icbtn.g\{border-color:var(--green);color:var(--green);\}\par
.icbtn.r\{border-color:var(--red);color:var(--red);\}\par
.icbtn.y\{border-color:var(--gold);color:var(--gold);\}\par
.icbtn:active\{transform:scale(.95);\}\par
\par
/* LEVEL UP */\par
#luov\{display:none;position:fixed;inset:0;background:rgba(0,0,0,.92);z-index:460;align-items:center;justify-content:center;padding:16px;\}\par
#luov.active\{display:flex;\}\par
.lubox\{background:var(--panel);border:3px solid var(--purple);border-radius:8px;padding:20px;width:100%;max-width:360px;text-align:center;box-shadow:0 0 40px rgba(170,68,255,.4);\}\par
.lutitle\{font-size:14px;color:var(--purple);text-shadow:0 0 15px var(--purple);margin-bottom:12px;animation:lp .5s infinite alternate;\}\par
@keyframes lp\{from\{text-shadow:0 0 15px var(--purple);\}to\{text-shadow:0 0 30px var(--purple),0 0 50px rgba(170,68,255,.5);\}\}\par
.ludesc\{font-size:7px;color:var(--gray);margin-bottom:10px;\}\par
.pkchoice\{background:#0a0a14;border:2px solid var(--border);color:var(--white);font-family:'Press Start 2P',monospace;font-size:7px;padding:10px;cursor:pointer;text-align:left;width:100%;margin-bottom:6px;border-radius:4px;line-height:1.6;transition:all .1s;\}\par
.pkchoice:hover,.pkchoice:active\{border-color:var(--purple);background:#1a0a2a;\}\par
.pn\{color:var(--purple);display:block;margin-bottom:3px;\}\par
.pd\{color:var(--gray);font-family:'VT323',monospace;font-size:14px;\}\par
\par
/* GAME OVER */\par
#gov\{display:none;position:fixed;inset:0;background:rgba(0,0,0,.96);z-index:500;align-items:center;justify-content:center;flex-direction:column;gap:14px;padding:20px;text-align:center;\}\par
#gov.active\{display:flex;\}\par
.gotitle\{font-size:clamp(18px,6vw,36px);color:var(--red);text-shadow:0 0 20px var(--red),3px 3px 0 #660000;\}\par
.goep\{font-family:'VT323',monospace;font-size:18px;color:var(--gray);max-width:340px;line-height:1.5;\}\par
.gost\{font-size:7px;color:var(--cyan);line-height:2.5;\}\par
.gobtn\{background:var(--panel);border:3px solid var(--red);color:var(--red);font-family:'Press Start 2P',monospace;font-size:9px;padding:12px 24px;cursor:pointer;\}\par
.gobtn:hover\{background:var(--red);color:var(--bg);\}\par
\par
/* DAMAGE FLOATERS */\par
.dmgf\{position:fixed;font-family:'Press Start 2P',monospace;font-size:13px;pointer-events:none;z-index:600;animation:dfloat 1s ease forwards;font-weight:bold;\}\par
@keyframes dfloat\{0%\{opacity:1;transform:translateY(0) scale(1);\}100%\{opacity:0;transform:translateY(-50px) scale(1.5);\}\}\par
\par
/* SHAKE */\par
@keyframes shake\{0%,100%\{transform:translateX(0)\}25%\{transform:translateX(-6px)\}75%\{transform:translateX(5px)\}\}\par
.shake\{animation:shake .3s ease;\}\par
@keyframes bigshake\{0%,100%\{transform:translate(0,0)\}20%\{transform:translate(-8px,3px)\}40%\{transform:translate(8px,-3px)\}60%\{transform:translate(-5px,5px)\}80%\{transform:translate(5px,-5px)\}\}\par
.bigshake\{animation:bigshake .4s ease;\}\par
\par
/* BACKDROP */\par
.bkdrop\{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:299;\}\par
.bkdrop.on\{display:block;\}\par
\par
/* TIER COLORS */\par
.tier-1\{color:#aaaaaa;\}\par
.tier-2\{color:#44ff88;\}\par
.tier-3\{color:#44aaff;\}\par
.tier-4\{color:#aa44ff;\}\par
.tier-5\{color:#ffd700;\}\par
\par
/* DOOM LEVELS */\par
.doom-0\{color:#888899;\}\par
.doom-1\{color:#ff8844;\}\par
.doom-2\{color:#ff4422;\}\par
.doom-3\{color:#ff2266;\}\par
.doom-4\{color:#ff00ff;\}\par
\par
/* MODIFIER BADGE */\par
.mod-badge\{display:inline-flex;align-items:center;gap:4px;background:#1a0010;border:1px solid #660033;border-radius:10px;padding:1px 6px;font-family:'VT323',monospace;font-size:12px;color:#ff6688;margin:1px 2px;white-space:nowrap;\}\par
.mod-badge.positive\{border-color:#226622;background:#0a1a0a;color:#66ff66;\}\par
\par
/* DOOM PANEL */\par
.doom-card\{background:#0d0005;border:2px solid #330011;border-radius:6px;padding:10px;margin-bottom:8px;\}\par
.doom-card.active-mod\{border-color:#cc0044;\}\par
.doom-threshold\{display:flex;align-items:center;gap:8px;padding:5px 0;border-bottom:1px solid #1a0010;font-size:6px;\}\par
.doom-threshold.reached\{color:#ff2266;\}\par
.doom-threshold.upcoming\{color:var(--gray);\}\par
\par
/* STATUS EFFECTS */\par
.status-tag\{display:inline-block;font-family:'VT323',monospace;font-size:12px;padding:1px 5px;border-radius:3px;margin:1px;\}\par
.status-poison\{background:#0a1a0a;border:1px solid #228822;color:#66ff66;\}\par
.status-burn\{background:#1a0a00;border:1px solid #884400;color:#ff8844;\}\par
.status-stun\{background:#0a0a1a;border:1px solid #4444aa;color:#8888ff;\}\par
.status-holy\{background:#1a1800;border:1px solid #888800;color:#ffff44;\}\par
.status-frozen\{background:#001a1a;border:1px solid #0088aa;color:#44ccff;\}\par
\par
/* AFFIX TAG */\par
.affix-tag\{display:inline-block;font-family:'VT323',monospace;font-size:12px;padding:1px 6px;border-radius:3px;border:1px solid;margin:1px;\}\par
.affix-vampiric\{border-color:#882244;background:#1a0010;color:#ff4488;\}\par
.affix-thorns\{border-color:#446622;background:#0a1400;color:#88ff44;\}\par
.affix-chaotic\{border-color:#884400;background:#1a0800;color:#ffaa44;\}\par
.affix-holy\{border-color:#886600;background:#1a1400;color:#ffee44;\}\par
.affix-poison\{border-color:#226633;background:#001a08;color:#44ff88;\}\par
.affix-swift\{border-color:#224488;background:#00081a;color:#4488ff;\}\par
.affix-runic\{border-color:#442288;background:#0a0018;color:#aa66ff;\}\par
\par
/* META UPGRADES */\par
.meta-upgrade-card\{background:#0d0020;border:2px solid #2a1a4a;border-radius:6px;padding:10px;margin-bottom:8px;display:flex;align-items:center;gap:10px;cursor:pointer;transition:all .1s;\}\par
.meta-upgrade-card:hover:not(.maxed)\{border-color:#cc44ff;background:#140028;\}\par
.meta-upgrade-card.maxed\{opacity:.5;cursor:default;\}\par
.meta-upgrade-card:active:not(.maxed)\{transform:scale(.98);\}\par
.meta-upgrade-icon\{font-size:24px;flex-shrink:0;\}\par
.meta-upgrade-info\{flex:1;\}\par
.meta-upgrade-name\{font-size:7px;color:#cc44ff;margin-bottom:2px;\}\par
.meta-upgrade-desc\{font-family:'VT323',monospace;font-size:13px;color:var(--gray);\}\par
.meta-upgrade-level\{font-size:6px;color:var(--gold);\}\par
.meta-upgrade-cost\{font-size:7px;color:#cc44ff;flex-shrink:0;text-align:right;\}\par
.meta-upgrade-cost.cant-afford\{color:var(--red);\}\par
\par
/* RUN SUMMARY STAT */\par
.rs-stat\{background:#0a0a14;border:2px solid var(--border);padding:7px;display:flex;justify-content:space-between;border-radius:4px;\}\par
.rs-stat-k\{font-size:6px;color:var(--gray);\}\par
.rs-stat-v\{font-size:7px;color:var(--cyan);\}\par
\par
/* ELITE ENEMY */\par
.elite-badge\{position:absolute;top:0;right:0;font-size:5px;color:#ffaa00;font-family:'Press Start 2P',monospace;line-height:1;background:rgba(0,0,0,.5);\}\par
\par
/* TITLE DOOM SHARDS DISPLAY */\par
#title-meta-btn\{background:#0d0020;border:2px solid #cc44ff;color:#cc44ff;font-family:'Press Start 2P',monospace;font-size:8px;padding:8px 16px;cursor:pointer;width:100%;max-width:460px;margin-bottom:-4px;\}\par
#title-meta-btn:hover\{background:#cc44ff;color:var(--bg);\}\par
</style>\par
</head>\par
<body>\par
<canvas id="vfxc"></canvas>\par
<div id="sflash"></div>\par
\par
<!-- TITLE -->\par
<div id="title-screen">\par
  <div><div class="title-big">\f3\u9876?\u-497?\f2  \f0 DOOMED \f3\u9876?\u-497?\f0 </div><div class="title-sub" style="margin-top:6px">A VERY SILLY DUNGEON v3</div></div>\par
  <button class="continue-btn" id="continue-btn" style="display:none" onclick="loadGame()">\f4\u-10179?\u-9026?\f2  \f0 CONTINUE (Floor <span id="sfl">?</span>)</button>\par
  <button id="title-meta-btn" onclick="openMetaScreen()">\f4\u-10179?\u-9056?\f2  \f0 META UPGRADES \f2\emdash  <span id="title-shard-count">0</span> Doom Shards</button>\par
  <div style="font-size:7px;color:var(--cyan);text-align:center">\emdash  PICK YOUR DOOMED HERO \emdash </div>\par
  <div class="class-grid">\par
    <div class="class-card" data-class="warrior" onclick="selectClass(this)">\par
      <span class="class-icon">\f3\u-10179?\u-8735?\u-497?\f0 </span><span class="class-name">BONK KNIGHT</span>\par
      <div class="class-desc">Hits things very hard. Strategy unknown.</div>\par
      <div class="class-weapon">\f3\u-10179?\u-8735?\u-497?\f2  \f0 Iron Sword</div><div class="class-stats">\f3\u10084?\u-497?\f0 120 \f3\u9876?\u-497?\f0 15 \f3\u-10179?\u-8479?\u-497?\f0 8 \f1\u10024?\f0 30</div>\par
    </div>\par
    <div class="class-card" data-class="mage" onclick="selectClass(this)">\par
      <span class="class-icon">\f4\u-10179?\u-8914?\f0 </span><span class="class-name">CHAOS WIZARD</span>\par
      <div class="class-desc">Spells may backfire. Glass cannon.</div>\par
      <div class="class-weapon">\f3\u-10178?\u-8572?\f2  \f0 Cursed Wand</div><div class="class-stats">\f3\u10084?\u-497?\f0 70 \f3\u9876?\u-497?\f0 8 \f3\u-10179?\u-8479?\u-497?\f0 3 \f1\u10024?\f0 100</div>\par
    </div>\par
    <div class="class-card" data-class="rogue" onclick="selectClass(this)">\par
      <span class="class-icon">\f3\u-10179?\u-8735?\u-497?\f0 </span><span class="class-name">SNEAKY STABBER</span>\par
      <div class="class-desc">Crits. Poison. Heroism optional.</div>\par
      <div class="class-weapon">\f4\u-10179?\u-8918?\f2  \f0 Shiv of Shame</div><div class="class-stats">\f3\u10084?\u-497?\f0 85 \f3\u9876?\u-497?\f0 12 \f3\u-10179?\u-8479?\u-497?\f0 5 \f1\u10024?\f0 50</div>\par
    </div>\par
    <div class="class-card" data-class="paladin" onclick="selectClass(this)">\par
      <span class="class-icon">\f3\u-10179?\u-8479?\u-497?\f0 </span><span class="class-name">HOLY YELLER</span>\par
      <div class="class-desc">Heals! Smites! Judges your choices.</div>\par
      <div class="class-weapon">\f4\u-10179?\u-8920?\f2  \f0 Holy Mallet</div><div class="class-stats">\f3\u10084?\u-497?\f0 100 \f3\u9876?\u-497?\f0 10 \f3\u-10179?\u-8479?\u-497?\f0 12 \f1\u10024?\f0 70</div>\par
    </div>\par
  </div>\par
  <div style="display:flex;align-items:center;gap:8px;font-size:7px;color:var(--gray);">\par
\f2     \f3\u-10179?\u-8772?\u-497?\f2  \f0 Custom sprite: <input type="file" id="sup" accept="image/*" style="font-size:9px;color:var(--cyan);" onchange="loadSprite(event)">\par
  </div>\par
  <button class="start-btn" id="start-btn" disabled onclick="startNewGame()">\f1\u9654?\f2  \f0 ENTER THE DUNGEON</button>\par
  <div style="font-size:6px;color:var(--gray);text-align:center;margin-top:-8px">WASD/Arrows or D-Pad \f2\bullet  Q=HP \bullet  E=MP \bullet  +/-=Zoom \bullet  M=Menu</div>\par
</div>\par
\par
<!-- GAME SCREEN -->\par
<div id="game-screen">\par
  <div id="hud">\par
    <div class="hud-sprite" id="hsprite">\f3\u-10179?\u-8735?\u-497?\f0 </div>\par
    <div class="hud-info"><div class="hud-name" id="hname">HERO</div><div class="hud-level" id="hlvl">LV.1</div></div>\par
    <div class="hud-bars">\par
      <div class="bar-row"><span class="bar-lbl">HP</span><div class="bar-track ht"><div class="bar-fill hp" id="bhp" style="width:100%"></div></div><span class="bar-val" id="thp">120/120</span></div>\par
      <div class="bar-row"><span class="bar-lbl">MP</span><div class="bar-track mt"><div class="bar-fill mp" id="bmp" style="width:100%"></div></div><span class="bar-val" id="tmp">30/30</span></div>\par
    </div>\par
    <div class="hud-r">\par
      <div class="hbadge fl" id="hfl">\f1\u11015?\f0 F1</div>\par
      <div class="hbadge go" id="hgo">\f4\u-10179?\u-9040?\f0 0</div>\par
      <div class="hbadge ki" id="hki">\f4\u-10179?\u-9088?\f0 0</div>\par
      <div class="hbadge" id="hds" style="color:#cc44ff;display:none">\f4\u-10179?\u-9056?\f0 0</div>\par
    </div>\par
  </div>\par
  <div id="qs">\par
    <span class="qs-lbl">Q:</span>\par
    <div class="qs-slot qs-hp" id="qshp" onclick="quickUse('hp')"><span class="qs-key">Q</span><span>\f3\u-10178?\u-8726?\f0 </span><span class="qs-cnt" id="qshpc">0</span></div>\par
    <span class="qs-lbl" style="margin-left:3px">E:</span>\par
    <div class="qs-slot qs-mp" id="qsmp" onclick="quickUse('mp')"><span class="qs-key">E</span><span>\f4\u-10179?\u-9049?\f0 </span><span class="qs-cnt" id="qsmpc">0</span></div>\par
    <div class="qs-wpn" id="qswpn">\f2\emdash  No weapon</div>\par
    <div class="qs-right">\par
      <div class="qs-atk" id="qsatk">ATK:0</div>\par
      <div class="zoom-btn" onclick="adjustZoom(-1)" title="Zoom out">\f5\u8722?\f0 </div>\par
      <div class="zoom-btn" onclick="adjustZoom(1)" title="Zoom in">+</div>\par
    </div>\par
  </div>\par
  <div id="xp-strip"><div id="xp-fill" style="width:0%"></div></div>\par
  <!-- DOOM CORRUPTION BAR -->\par
  <div id="doom-strip" style="height:6px;background:#0a0005;flex-shrink:0;position:relative;cursor:pointer" onclick="togglePanel('doom')" title="Doom Corruption">\par
    <div id="doom-fill" style="height:100%;width:0%;background:linear-gradient(90deg,#660033,#cc0044,#ff2266);transition:width .5s;box-shadow:0 0 8px #ff2266;"></div>\par
    <div id="doom-label" style="position:absolute;right:4px;top:-1px;font-size:5px;color:#ff2266;font-family:'Press Start 2P',monospace;line-height:8px">\f1\u9760?\f2  \f0 0%</div>\par
  </div>\par
  <!-- ACTIVE MODIFIERS TICKER -->\par
  <div id="mod-bar" style="display:none;background:#0d0005;border-bottom:2px solid #330011;padding:2px 8px;flex-shrink:0;overflow:hidden;white-space:nowrap;"></div>\par
  <div id="map-wrap">\par
    <div id="map-scroll">\par
      <div id="dungeon-map"></div>\par
    </div>\par
    <div id="mmwrap"><div id="minimap"></div></div>\par
  </div>\par
  <div id="ctrl">\par
    <div id="abtns">\par
      <button class="abtn" onclick="togglePanel('inv')"><span class="ai">\f4\u-10180?\u-8302?\f0 </span>ITEMS</button>\par
      <button class="abtn" onclick="togglePanel('fuse')"><span class="ai">\f3\u9879?\u-497?\f0 </span>FUSE</button>\par
      <button class="abtn" onclick="togglePanel('stats')"><span class="ai">\f4\u-10179?\u-9014?\f0 </span>STATS</button>\par
      <button class="abtn" onclick="togglePanel('log')"><span class="ai">\f4\u-10179?\u-8996?\f0 </span>LOG</button>\par
      <button class="abtn" onclick="doWait()"><span class="ai">\f1\u9203?\f0 </span>WAIT</button>\par
      <button class="abtn" onclick="tryPickup()"><span class="ai">\f4\u-10179?\u-9146?\f0 </span>GRAB</button>\par
      <button class="abtn" onclick="togglePanel('menu')"><span class="ai">\f1\u9776?\f0 </span>MENU</button>\par
    </div>\par
    <div id="dpad">\par
      <div class="dp dpe"></div>\par
      <div class="dp" ontouchstart="dpPress(0,-1)" ontouchend="dpRelease()" onmousedown="dpPress(0,-1)" onmouseup="dpRelease()">\f1\u9650?\f0 </div>\par
      <div class="dp dpe"></div>\par
      <div class="dp" ontouchstart="dpPress(-1,0)" ontouchend="dpRelease()" onmousedown="dpPress(-1,0)" onmouseup="dpRelease()">\f1\u9664?\f0 </div>\par
      <div class="dp dpc">\f1\u9876?\f0 </div>\par
      <div class="dp" ontouchstart="dpPress(1,0)" ontouchend="dpRelease()" onmousedown="dpPress(1,0)" onmouseup="dpRelease()">\f1\u9654?\f0 </div>\par
      <div class="dp dpe"></div>\par
      <div class="dp" ontouchstart="dpPress(0,1)" ontouchend="dpRelease()" onmousedown="dpPress(0,1)" onmouseup="dpRelease()">\f1\u9660?\f0 </div>\par
      <div class="dp dpe"></div>\par
    </div>\par
  </div>\par
</div>\par
\par
<!-- PANELS -->\par
<div class="bkdrop" id="bkdrop" onclick="closeAllPanels()"></div>\par
\par
<!-- INVENTORY -->\par
<div class="spanel" id="panel-inv">\par
  <div class="sph"><div class="spt">\f4\u-10180?\u-8302?\f2  \f0 INVENTORY (<span id="inv-count">0</span>/<span id="inv-max">8</span>)</div><button class="spc" onclick="closeAllPanels()">\f1\u10005?\f0 </button></div>\par

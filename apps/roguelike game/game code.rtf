function makeMaterial(id)\{\par
  const m=MATERIALS[id];if(!m)return null;\par
  return\{...m,type:'material',uid:Math.random().toString(36).slice(2)\};\par
\}\par
\par
// Material drop table keyed by floor range\par
function rollMaterialDrop(floor, isBoss=false)\{\par
  const pool=Object.values(MATERIALS).filter(m=>\{\par
    if(isBoss)return m.rarity>=3&&m.floor<=floor+1;\par
    if(floor<=1)return m.rarity===1;\par
    if(floor<=2)return m.rarity<=2;\par
    if(floor<=3)return m.rarity<=3;\par
    return true;\par
  \});\par
  if(!pool.length)return null;\par
  // Weight toward lower rarity\par
  const weighted=[];\par
  pool.forEach(m=>\{\par
    const w=isBoss?1:Math.max(1,5-m.rarity);\par
    for(let i=0;i<w;i++)weighted.push(m);\par
  \});\par
  const m=weighted[Math.floor(Math.random()*weighted.length)];\par
  return makeMaterial(m.id);\par
\}\par

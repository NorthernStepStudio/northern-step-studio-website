// \f1\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\f0\par
// \f1\u9472?\u9472?\u9472?\u9472?\u9472?\f2  \f0 STATUS EFFECTS \f1\u9472?\u9472?\u9472?\u9472?\u9472?\f0\par
// \f1\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\f0\par
// status: \{poison, burn, stun, frozen, holy\} \f2\emdash  counts of remaining turns\par
\par
function applyStatus(target, status, stacks=1)\{\par
  if(!target.status)target.status=\{\};\par
  target.status[status]=(target.status[status]||0)+stacks;\par
\}\par
\par
function tickStatusEnemy(en)\{\par
  if(!en.status)return;\par
  const logs=[];\par
  if(en.status.poison>0)\{const d=Math.max(1,Math.floor(en.maxHp*.06));en.hp-=d;en.status.poison--;logs.push(`\f3\u9760?\u-497?\f2  \f0 $\{en.name\} poison $\{d\}!`);\}\par
  if(en.status.burn>0)\{const d=Math.max(1,Math.floor(en.maxHp*.05)+5);en.hp-=d;en.status.burn--;logs.push(`\f4\u-10179?\u-8923?\f2  \f0 $\{en.name\} burn $\{d\}!`);\}\par
  if(en.status.frozen>0)\{en.status.frozen--;logs.push(`\f3\u-10178?\u-8758?\f2  \f0 $\{en.name\} frozen!`);\}\par
  logs.forEach(l=>clog(l,'#88ff44'));\par
\}\par
\par
function tickStatusPlayer()\{\par
  const p=G.player;\par
  if(!p.status)return;\par
  if(p.status.poison>0)\{const d=Math.max(1,Math.floor(p.maxHp*.04));p.hp=Math.max(1,p.hp-d);p.status.poison--;clog(`\f3\u9760?\u-497?\f2  \f0 You're poisoned! $\{d\} dmg`,'#88ff44');if(p.hp<=1&&p.status.poison>0)\{gameOver('Poison');return;\}\}\par
  if(p.status.burn>0)\{const d=4+Math.floor(Math.random()*4);p.hp=Math.max(1,p.hp-d);p.status.burn--;clog(`\f4\u-10179?\u-8923?\f2  \f0 Burning! $\{d\} dmg`,'#ff8844');\}\par
\}\par
\par
function getStatusBadges(entity)\{\par
  if(!entity.status)return'';\par
  const s=entity.status;\par
  const parts=[];\par
  if(s.poison>0)parts.push(`<span class="status-tag status-poison">\f1\u9760?\f0 $\{s.poison\}</span>`);\par
  if(s.burn>0)parts.push(`<span class="status-tag status-burn">\f4\u-10179?\u-8923?\f0 $\{s.burn\}</span>`);\par
  if(s.stun>0)parts.push(`<span class="status-tag status-stun">\f4\u-10179?\u-9045?\f0 $\{s.stun\}</span>`);\par
  if(s.frozen>0)parts.push(`<span class="status-tag status-frozen">\f3\u-10178?\u-8758?\f0 $\{s.frozen\}</span>`);\par
  if(s.holy>0)parts.push(`<span class="status-tag status-holy">\f1\u10024?\f0 $\{s.holy\}</span>`);\par
  return parts.join('');\par
\}\par
\par
// \f1\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\f0\par
// \f1\u9472?\u9472?\u9472?\u9472?\u9472?\f2  \f0 AFFIXES SYSTEM \f1\u9472?\u9472?\u9472?\u9472?\u9472?\f0\par
// \f1\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\u9552?\f0\par
const AFFIXES = [\par
  \{id:'vampiric', name:'Vampiric', emoji:'\f3\u-10178?\u-8584?\f0 ', desc:'Lifesteal 12% on hit.', cls:'affix-vampiric', apply:(it)=>\{it.affix_effect=\{lifesteal:.12\};\}\},\par
  \{id:'thorns',   name:'Thorns',   emoji:'\f4\u-10180?\u-8395?\f0 ', desc:'Reflect 15% dmg taken.', cls:'affix-thorns',   apply:(it)=>\{it.affix_effect=\{thorns:.15\};\}\},\par
  \{id:'chaotic',  name:'Chaotic',  emoji:'\f4\u-10180?\u-8448?\f0 ', desc:'Attacks have wild crits (double range).', cls:'affix-chaotic',apply:(it)=>\{it.affix_effect=\{chaotic:true\};\}\},\par
  \{id:'holy',     name:'Holy',     emoji:'\f1\u10024?\f0 ', desc:'Attacks may heal 8 HP.', cls:'affix-holy',    apply:(it)=>\{it.affix_effect=\{holyStrike:.25\};\}\},\par
  \{id:'poison',   name:'Venomous', emoji:'\f3\u9760?\u-497?\f0 ', desc:'Attacks apply 2 turns poison.', cls:'affix-poison',apply:(it)=>\{it.affix_effect=\{poisonStrike:2\};\}\},\par
  \{id:'swift',    name:'Swift',    emoji:'\f1\u9889?\f0 ', desc:'+5 SPD while equipped.', cls:'affix-swift',  apply:(it)=>\{it.affix_effect=\{spdBonus:5\};\}\},\par
  \{id:'runic',    name:'Runic',    emoji:'\f4\u-10179?\u-8914?\f0 ', desc:'+20 Max MP while equipped.', cls:'affix-runic', apply:(it)=>\{it.affix_effect=\{mpBonus:20\};\}\},\par
  \{id:'burning',  name:'Burning',  emoji:'\f4\u-10179?\u-8923?\f0 ', desc:'Attacks apply 2 turns burn.', cls:'affix-chaotic', apply:(it)=>\{it.affix_effect=\{burnStrike:2\};\}\},\par
];\par
\par
// Roll a random affix onto an item (only gear, not consumables)\par
function rollAffix(it)\{\par
  if(!it||it.type==='material'||it.type==='consumable'||it.isHp||it.isMp)return it;\par
  if(Math.random()>.35)return it; // 35% chance\par
  const aff=AFFIXES[Math.floor(Math.random()*AFFIXES.length)];\par
  it.affix=aff.id;\par
  it.affixName=aff.name;\par
  it.affixClass=aff.cls;\par
  it.affixDesc=aff.desc;\par
  it.affixEmoji=aff.emoji;\par
  aff.apply(it);\par
  return it;\par
\}\par
\par
function getAffixBadge(it)\{\par
  if(!it.affix)return'';\par
  return`<span class="affix-tag $\{it.affixClass||''\}">$\{it.affixEmoji||'\f1\u10022?\f0 '\} $\{it.affixName\}</span>`;\par
\}\par
\par
// Apply affix effects during combat\par
function applyAffixOnHit(attacker, target, dmg)\{\par
  if(!attacker.affix_effect&&!G.equippedWeapon?.affix_effect)return dmg;\par
  const eff=(attacker===G.player?G.equippedWeapon?.affix_effect:null)||attacker.affix_effect||\{\};\par
  const p=G.player;\par
\par
  if(eff.lifesteal)\{const ls=Math.floor(dmg*eff.lifesteal);p.hp=Math.min(p.maxHp,p.hp+ls);if(ls>0)clog(`\f3\u-10178?\u-8584?\f2  \f0 Vampiric +$\{ls\}HP`,'#ff4488');\}\par
  if(eff.holyStrike&&Math.random()<eff.holyStrike)\{const h=8;p.hp=Math.min(p.maxHp,p.hp+h);clog(`\f1\u10024?\f2  \f0 Holy Strike +$\{h\}HP`,'#ffff44');\}\par
  if(eff.poisonStrike&&target.status)applyStatus(target,'poison',eff.poisonStrike);\par
  if(eff.burnStrike&&target.status)applyStatus(target,'burn',eff.burnStrike);\par
  if(eff.chaotic&&Math.random()<.3)\{dmg=Math.floor(dmg*(1.5+Math.random()*2.5));clog(`\f4\u-10180?\u-8448?\f2  \f0 Chaotic crit! $\{dmg\}!`,'#ffaa44');\}\par
  return dmg;\par
\}\par
\par
function applyAffixOnEquip(it, equip=true)\{\par
  if(!it.affix_effect)return;\par
  const p=G.player,eff=it.affix_effect,m=equip?1:-1;\par
  if(eff.spdBonus)p.spd+=eff.spdBonus*m;\par
  if(eff.mpBonus)\{p.maxMp+=eff.mpBonus*m;if(equip)p.mp=Math.min(p.maxMp,p.mp+eff.mpBonus);\}\par
\}\par

{
  "expo": {
    "name": "NooBS: Investing Companion",
    "slug": "noobs-investing",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/noobs-brand-square.png",
    "scheme": "noobsinvesting",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/noobs-brand-square.png",
      "resizeMode": "contain",
      "backgroundColor": "#080808"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.noobs.investing",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/noobs-brand-square.png",
        "backgroundColor": "#080808"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite"
    ],
    "owner": "northernstep",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "companyName": "Northern Step Studio",
      "developerName": "Northern Step Studio",
      "router": {},
      "eas": {
        "projectId": "fce5b93c-73cc-4782-bb9a-31992eb69951"
      }
    }
  }
}

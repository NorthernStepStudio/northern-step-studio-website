{
    "name": "@nexusbuild/backend",
    "version": "1.0.0",
    "description": "NexusBuild API Backend - Node.js/TypeScript",
    "main": "dist/index.js",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "npm run prisma:generate && tsc",
        "postinstall": "prisma generate",
        "start": "node dist/index.js",
        "test": "tsx --test tests/buildTools.test.ts tests/testers.test.ts",
        "migrate": "prisma migrate deploy",
        "migrate:dev": "prisma migrate dev",
        "prisma:generate": "prisma generate",
        "prisma:studio": "prisma studio",
        "db:seed": "tsx src/scripts/seed.ts",
        "seed:admin": "tsx src/scripts/seedAdmin.ts",
        "smoke": "node ../../scripts/smoke-backend.mjs"
    },
    "keywords": [
        "nexusbuild",
        "api",
        "pc-building"
    ],
    "author": "NexusBuild Team",
    "license": "MIT",
    "dependencies": {
        "@prisma/client": "^5.22.0",
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jsonwebtoken": "^9.0.6",
        "@types/multer": "^1.4.11",
        "@types/node": "^20.14.10",
        "@types/nodemailer": "^6.4.15",
        "apify-client": "^2.21.0",
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "crawlee": "^3.16.0",
        "dotenv": "^16.4.5",
        "express": "^4.19.2",
        "jsonwebtoken": "^9.0.2",
        "multer": "^1.4.5-lts.1",
        "nodemailer": "^6.9.13",
        "playwright": "^1.58.2",
        "prisma": "^5.22.0",
        "tsx": "^4.16.2",
        "typescript": "^5.5.3",
        "zod": "^3.23.8"
    },
    "engines": {
        "node": ">=20.0.0"
    }
}


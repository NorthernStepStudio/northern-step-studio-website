generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              Int               @id @default(autoincrement())
  username        String            @unique @db.VarChar(80)
  email           String            @unique @db.VarChar(120)
  passwordHash    String            @map("password_hash") @db.VarChar(255)
  bio             String?
  profileImage    String?           @map("profile_image")
  isAdmin         Boolean           @default(false) @map("is_admin")
  isModerator     Boolean           @default(false) @map("is_moderator")
  isSuspended     Boolean           @default(false) @map("is_suspended")
  avatarFrame     String            @default("basic") @map("avatar_frame") @db.VarChar(50)
  showcaseBuildId Int?              @map("showcase_build_id")
  isPublicProfile Boolean           @default(true) @map("is_public_profile")
  tokens          Int               @default(0)
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  bugReports      BugReport[]
  builds          Build[]
  aiUsage         DailyAIUsage[]
  entitlements    UserEntitlement[]

  @@map("users")
}

model Build {
  id               Int      @id @default(autoincrement())
  userId           Int      @map("user_id")
  name             String   @db.VarChar(200)
  description      String?
  totalPrice       Float    @default(0) @map("total_price")
  imageUrl         String?  @map("image_url")
  performanceScore Float?   @map("performance_score")
  isPublic         Boolean  @default(true) @map("is_public")
  likesCount       Int      @default(0) @map("likes_count")
  isFeatured       Boolean  @default(false) @map("is_featured")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  parts            Part[]

  @@index([userId])
  @@index([isPublic, isFeatured])
  @@map("builds")
}

model Part {
  id             Int      @id @default(autoincrement())
  buildId        Int      @map("build_id")
  name           String   @db.VarChar(255)
  category       String   @db.VarChar(100)
  price          Float    @default(0)
  url            String?
  imageUrl       String?  @map("image_url")
  specifications Json?    @db.Json
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  build          Build    @relation(fields: [buildId], references: [id], onDelete: Cascade)

  @@index([buildId])
  @@index([category])
  @@map("parts")
}

model BugReport {
  id          Int      @id @default(autoincrement())
  userId      Int?     @map("user_id")
  email       String?  @db.VarChar(255)
  description String
  category    String?  @db.VarChar(50)
  imageUrl    String?  @map("image_url") @db.VarChar(500)
  images      Json?    @db.Json
  status      String   @default("pending") @db.VarChar(20)
  priority    String   @default("medium") @db.VarChar(20)
  adminNotes  String?  @map("admin_notes")
  createdAt   DateTime @default(now()) @map("created_at")
  user        User?    @relation(fields: [userId], references: [id])

  @@index([status])
  @@index([userId])
  @@map("bug_reports")
}

model UserEntitlement {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  tier      String    @db.VarChar(50)
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_entitlements")
}

model DailyAIUsage {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  date      DateTime @db.Date
  count     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
  @@map("daily_ai_usage")
}

model NstepTester {
  id          Int      @id @default(autoincrement())
  email       String   @db.VarChar(255)
  name        String   @default("") @db.VarChar(120)
  appSlug     String?  @map("app_slug") @db.VarChar(120)
  reason      String   @default("") @db.Text
  status      String   @default("pending") @db.VarChar(20)
  adminNotes  String   @default("") @map("admin_notes") @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([email])
  @@index([status])
  @@index([appSlug])
  @@index([createdAt])
  @@map("nstep_testers")
}

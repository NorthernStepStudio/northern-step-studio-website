{
  "name": "nexusbuild-app",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "bootstrap:backend:local": "powershell -ExecutionPolicy Bypass -File .\\scripts\\bootstrap-local-backend.ps1",
    "dev:api": "npm --workspace apps/backend run dev",
    "dev:worker": "npm --workspace apps/backend-worker run dev --",
    "dev:mobile:ci": "npm --workspace apps/mobile run start:ci",
    "dev:mobile:ci:tunnel": "npm --workspace apps/mobile run start:ci:tunnel",
    "start:api": "npm --workspace apps/backend run start",
    "dev:mobile": "npm --workspace apps/mobile start",
    "version:mobile:sync": "npm --workspace apps/mobile run version:sync",
    "version:mobile:patch": "npm --workspace apps/mobile run version:patch",
    "version:mobile:minor": "npm --workspace apps/mobile run version:minor",
    "version:mobile:major": "npm --workspace apps/mobile run version:major",
    "dev:web": "npm --workspace apps/web run dev",
    "dev:web-amazon": "npm --workspace apps/web-amazon run dev",
    "dev:reco": "npm --workspace apps/reco run start",
    "verify:static": "node ./scripts/verify.mjs backend web web-amazon",
    "verify:all": "node ./scripts/verify.mjs all",
    "smoke:backend": "node ./scripts/smoke-backend.mjs",
    "smoke:staging": "node ./scripts/smoke-backend.mjs"
  },
  "dependencies": {
    "metro-runtime": "^0.83.3"
  }
}

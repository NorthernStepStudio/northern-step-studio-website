{
  "expo": {
    "name": "PasoScore",
    "slug": "pasoscore",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1b26"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.northernstepstudio.pasoscore"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1b26"
      },
      "package": "com.northernstepstudio.pasoscore"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "companyName": "Northern Step Studio",
      "developerName": "Northern Step Studio"
    }
  }
}

{
  "name": "provly",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:backend": "npm --prefix apps/backend run dev",
    "dev:mobile": "npm --prefix apps/mobile run start --",
    "android:mobile": "npm --prefix apps/mobile run android",
    "build:shared": "npm --prefix packages/shared run build",
    "agent:smoke": "npm --prefix apps/backend run agent:smoke",
    "phone:prepare": "node scripts/prepare-phone-env.mjs",
    "phone:test": "node scripts/phone-test.mjs"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "expo": "~54.0.33",
    "expo-auth-session": "^7.0.10",
    "expo-localization": "~17.0.8",
    "i18next": "^25.7.4",
    "multer": "^2.0.2",
    "react-native-gesture-handler": "2.28.0",
    "react-i18next": "^16.5.3"
  },
  "overrides": {
    "expo": "~54.0.33",
    "expo-font": "~14.0.11",
    "react-native-gesture-handler": "2.28.0"
  },
  "author": "Northern Step Studio"
}

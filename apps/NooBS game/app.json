{
  "expo": {
    "name": "NooBS Investing",
    "slug": "noobs-investing",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "sdkVersion": "54.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/noobs-investing"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.noobs.investinggame"
    },
    "android": {
      "package": "com.noobs.investinggame",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "permissions": [
        "NOTIFICATIONS"
      ]
    },
    "web": {
      "backgroundColor": "#000000"
    },
    "extra": {
      "companyName": "Northern Step Studio",
      "developerName": "Northern Step Studio"
    }
  }
}

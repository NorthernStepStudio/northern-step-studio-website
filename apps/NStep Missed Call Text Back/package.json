{
  "name": "nss-missed-call-ai",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "generate:credential-key": "node --env-file=.env server/generate-credential-key.mjs",
    "gateway:start": "node --env-file=.env server/index.mjs",
    "gateway:dev": "npm run gateway:start",
    "gateway:public": "node --env-file=.env server/start-gateway-public.mjs",
    "smoke:gateway": "node --env-file=.env server/smoke.mjs",
    "dev": "vite",
    "dev:all": "node --env-file=.env server/dev-all.mjs",
    "build": "tsc && vite build",
    "check": "npm run build && npm run smoke:gateway",
    "preview": "vite preview"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.100.0",
    "dotenv": "^17.3.1",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "twilio": "^5.12.2"
  },
  "devDependencies": {
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "5.8.3",
    "vite": "^7.1.3"
  }
}

{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "northern-step-studio-website",
	"main": "./src/worker/index.ts",
	"compatibility_date": "2025-06-17",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"rules": [
		{
			"type": "Text",
			"globs": [
				"**/*.html*"
			],
			"fallthrough": true
		}
	],
	"observability": {
		"enabled": true
	},
	"upload_source_maps": true,
	"assets": {
		"directory": "dist",
		"not_found_handling": "single-page-application"
	},
	"services": [],
	"workers_dev": true,
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "northern-step-studio-website-db",
			"database_id": "local-db"
		}
	]
}
